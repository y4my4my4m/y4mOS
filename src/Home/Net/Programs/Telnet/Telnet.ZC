// Telnet client for ZealOS by y4my4m
// Public Domain

Cd(__DIR__);;

#define TELNET_PORT 23
#define BUF_SIZE 819200
#define INPUT_BUF_SIZE 32
#define TIMEOUT_DURATION 500000

#define NEGOTIATE 0xFF

#define ANSI_ESC 0x1B
#define ANSI_CSI 0x5B // [

#define MAX_ANSI_PARAMS 32

#include "TelnetClass"
#include "TelnetHelpers"
#include "TelnetNegotiation"
#include "TelnetANSI"

// If you're using a custom palette, the colors might not seem right.
CBGR24 original_palette[COLORS_NUM];
Bool original_colors = FALSE;
Bool force_disconnect = FALSE;

U0 HandleControlCodes(U8 ch) {
  switch (ch)
  {
    case 0: // NUL - ignored
      break;
    case 7: // BEL
      Beep;
      break;
    case 8: // BS
      if (term.csr_col)
        term.csr_col--;
      break;
    case 9: // HT: next 8-column tab stop
      term.csr_col = (term.csr_col & ~7) + 8;
      if (term.csr_col >= term.window_width)
        term.csr_col = term.window_width - 1;
      break;
    case 10: // LF
    case 11: // VT behaves like LF
      TermLineFeed;
      break;
    case 12: // FF
      TermClear;
      break;
    case 13: // CR
      term.csr_col = 0;
      break;
    default:
      if (ch >= 32) // printable + CP437 high glyphs
        TermPutChar(ch);
      // remaining C0 control codes: ignored
      break;
  }
}

U0 TelnetByteProcess(U8 ch)
{ // Stream state machine: one byte at a time, state persists in term across
  // TCPSocketReceive calls, so telnet commands and ANSI escape sequences split
  // over TCP segment boundaries are parsed correctly instead of printed as garbage.
  switch (term.parse_state) {
    case TELNET_STATE_NORMAL:
      if (ch == NEGOTIATE)
        term.parse_state = TELNET_STATE_IAC;
      else if (ch == ANSI_ESC)
        term.parse_state = TELNET_STATE_ESC;
      else
        HandleControlCodes(ch);
      break;

    case TELNET_STATE_IAC:
      switch (ch) {
        case NEGOTIATE: // IAC IAC is an escaped literal 0xFF data byte
          HandleControlCodes(NEGOTIATE);
          term.parse_state = TELNET_STATE_NORMAL;
          break;
        case WILL:
        case WONT:
        case DO:
        case DONT:
          term.iac_cmd = ch;
          term.parse_state = TELNET_STATE_IAC_OPT;
          break;
        case SB:
          term.sb_len = 0;
          term.parse_state = TELNET_STATE_SB;
          break;
        default: // NOP, GA, AYT, ... : consume and ignore
          term.parse_state = TELNET_STATE_NORMAL;
          break;
      }
      break;

    case TELNET_STATE_IAC_OPT:
      if (term.sock_ready)
        TelnetNegotiateOption(term.sock, term.iac_cmd, ch);
      term.parse_state = TELNET_STATE_NORMAL;
      break;

    case TELNET_STATE_SB:
      if (ch == NEGOTIATE)
        term.parse_state = TELNET_STATE_SB_IAC;
      else if (term.sb_len < TELNET_SB_BUF_SIZE)
        term.sb_buf[term.sb_len++] = ch;
      break;

    case TELNET_STATE_SB_IAC:
      if (ch == SE) { // IAC SE terminates the subnegotiation
        if (term.sock_ready)
          TelnetSubnegotiate(term.sock, term.sb_buf, term.sb_len);
        term.parse_state = TELNET_STATE_NORMAL;
      }
      else if (ch == NEGOTIATE) { // IAC IAC inside SB: literal 0xFF payload byte
        if (term.sb_len < TELNET_SB_BUF_SIZE)
          term.sb_buf[term.sb_len++] = NEGOTIATE;
        term.parse_state = TELNET_STATE_SB;
      }
      else // malformed subnegotiation, bail out
        term.parse_state = TELNET_STATE_NORMAL;
      break;

    case TELNET_STATE_ESC:
      switch (ch)
      {
        case ANSI_CSI:
          term.seq_len = 0;
          term.parse_state = TELNET_STATE_CSI;
          break;
        case '(': // charset designation: swallow the byte that follows
        case ')':
          term.parse_state = TELNET_STATE_ESC_CHARSET;
          break;
        case '7': // save cursor
          term.saved_row = term.csr_row;
          term.saved_col = term.csr_col;
          term.parse_state = TELNET_STATE_NORMAL;
          break;
        case '8': // restore cursor
          TermCursorSet(term.saved_row, term.saved_col);
          term.parse_state = TELNET_STATE_NORMAL;
          break;
        case 'M': // reverse index: up, scroll down at top
          if (term.csr_row)
            term.csr_row--;
          else
            TermScrollDown;
          term.parse_state = TELNET_STATE_NORMAL;
          break;
        case 'D': // index: down
          TermLineFeed;
          term.parse_state = TELNET_STATE_NORMAL;
          break;
        case 'E': // next line
          term.csr_col = 0;
          TermLineFeed;
          term.parse_state = TELNET_STATE_NORMAL;
          break;
        case 'c': // full reset
          term.cur_attr = TERM_DEFAULT_ATTR;
          term.bold = FALSE;
          TermClear;
          term.parse_state = TELNET_STATE_NORMAL;
          break;
        default: // unknown ESC x: swallow
          term.parse_state = TELNET_STATE_NORMAL;
          break;
      }
      break;

    case TELNET_STATE_ESC_CHARSET:
      term.parse_state = TELNET_STATE_NORMAL; // designation byte consumed
      break;

    case TELNET_STATE_CSI:
      if (IsAlpha(ch) || term.seq_len >= TELNET_SEQ_BUF_SIZE - 2) {
        term.seq_buf[term.seq_len++] = ch; // final byte (or overlong sequence force-cut)
        term.seq_buf[term.seq_len] = '\0';
        HandleANSISequence(term.seq_buf);
        term.parse_state = TELNET_STATE_NORMAL;
      }
      else
        term.seq_buf[term.seq_len++] = ch;
      break;
  }
}

U0 ANSIParse()
{
  I64 i;

  term.view_offset = 0; // new output snaps the view back to live

  for (i = 0; i < term.buffer_len; i++)
    TelnetByteProcess(term.buffer[i]);
}

U0 TermPutS(U8 *s)
{ // Local status text, fed through the same parser so it can use ANSI colors.
  term.parse_state = TELNET_STATE_NORMAL; // never inherit a half-parsed server sequence
  while (*s)
    TelnetByteProcess(*s++);
}

#include "TelnetXfer" // needs TermPutS, used by TerminalTask below

I64 TelnetOpen(U8 *host, U16 port) {
  I64 sock;
  U8 *msg;

  if (host == NULL) {
    return -1;
  }

  msg = MStrPrint("\x1B[32mConnecting to %s:%d.\x1B[0m\r\n", host, port);
  TermPutS(msg);
  Free(msg);

  sock = TCPConnectionCreate(host, port);
  if (sock <= 0) {
    PopUpOk("\n\n\tFailed to connect\n\n");
    return sock;
  }

  return sock; // caller sets the socket timeout for poll-mode receive
}

U0 TerminalTask() {
  I64 received;

  while (!force_disconnect) {
    // Claim busy BEFORE checking sock_ready: TelnetDisconnect clears sock_ready
    // then waits on task_idle, so this order means it can never observe a stale
    // idle flag while we are about to touch the socket.
    term.task_idle = FALSE;

    if (!term.sock_ready) {
      term.task_idle = TRUE; // main task may now safely close/free the socket
      Sleep(50);
    }
    else if (term.xfer_mode) { // transfer requested; we own the socket, run it here
      XferRun(NULL, 0);
    }
    else {
      received = TCPSocketReceive(term.sock, term.buffer, BUF_SIZE - 1);

      if (received > 0) {
        if (term.xfer_mode) { // bytes just read belong to the transfer, hand them over
          XferRun(term.buffer, received);
        }
        else {
          term.buffer_len = received;
          ANSIParse;
        }
      }
      else if (received == 0) { // orderly close or reset by remote
        term.sock_ready = 0;
        TermPutS("\r\n\x1B[1;37;41mConnection closed by remote host. Shift-Esc for splash.\x1B[0m\r\n");
      }
      else
        Sleep(20); // non-blocking receive: nothing pending yet
    }
  }

  term.task_idle = TRUE;
}

U0 TelnetDisconnect()
{ // Close the current socket without racing TerminalTask's receive path.
  if (term.sock == 0)
    return;

  term.sock_ready = 0;

  while (!term.task_idle)
    Sleep(10); // wait for TerminalTask to finish its in-flight receive

  term.sock(CTCPSocket *)->timeout = 500; // bounded graceful FIN handshake
  TCPSocketClose(term.sock);
  term.sock = 0;
}

U8 TermPaletteColor(U8 c, Bool invert)
{ // The grid stores canonical ANSI/VGA indices (0 = black, 15 = white).
  // ZealOS dark themes swap palette entries 0 and 15, so translate at draw
  // time; the middle colors are theme-tuned but keep their hue.
  if (invert)
  {
    if (c == BLACK)
      return WHITE;
    if (c == WHITE)
      return BLACK;
  }
  return c;
}

U0 TelnetDrawIt(CTask *task, CDC *dc)
{ // Blit the visible rows (scrollback + live grid), one background rect per
  // same-attribute run, then glyphs.
  I64 r, c, i, run_start, csr_col, view_start, idx, ring;
  U8 attr, ch;
  U8 *row_ch, *row_attr;
  Bool invert;

  no_warn task;

  // Detect swapped-endpoint palettes (ZealOS dark theme) each frame, so
  // Alt+T standard-palette toggling and theme changes stay correct.
  invert = gr_palette[BLACK].b + gr_palette[BLACK].g + gr_palette[BLACK].r >
           gr_palette[WHITE].b + gr_palette[WHITE].g + gr_palette[WHITE].r;

  // Visible window starts view_offset rows back into the combined
  // [history ring][live screen] row sequence.
  view_start = term.back_count - term.view_offset;

  for (r = 0; r < term.window_height; r++)
  {
    idx = view_start + r;
    if (idx < term.back_count)
    { // history row: translate combined index to ring slot
      ring = (term.back_head - term.back_count + idx + TERM_SCROLLBACK_ROWS) % TERM_SCROLLBACK_ROWS;
      row_ch   = term.back_ch   + ring * TERM_MAX_COLS;
      row_attr = term.back_attr + ring * TERM_MAX_COLS;
    }
    else
    { // live screen row
      row_ch   = term.screen_ch   + (idx - term.back_count) * TERM_MAX_COLS;
      row_attr = term.screen_attr + (idx - term.back_count) * TERM_MAX_COLS;
    }

    c = 0;
    while (c < term.window_width)
    {
      run_start = c;
      attr = row_attr[c];
      while (c < term.window_width && row_attr[c] == attr)
        c++;

      dc->color = TermPaletteColor(attr >> 4, invert); // background
      GrRect(dc, run_start * FONT_WIDTH, r * FONT_HEIGHT,
             (c - run_start) * FONT_WIDTH, FONT_HEIGHT);

      dc->color = TermPaletteColor(attr & 0x0F, invert); // foreground glyphs
      for (i = run_start; i < c; i++)
      {
        ch = row_ch[i];
        if (ch != ' ')
          GrPutChar(dc, i * FONT_WIDTH, r * FONT_HEIGHT, ch);
      }
    }
  }

  if (term.view_offset)
  { // scrolled into history: yellow marker bar along the top edge
    dc->color = TermPaletteColor(YELLOW, invert);
    GrRect(dc, 0, 0, term.window_width * FONT_WIDTH, 2);
  }
  else if (term.csr_visible && term.sock_ready)
  { // underline-style cursor, live view only
    csr_col = term.csr_col;
    if (csr_col >= term.window_width) // deferred-wrap position parks past the edge
      csr_col = term.window_width - 1;

    dc->color = TermPaletteColor(term.cur_attr & 0x0F, invert);
    GrRect(dc, csr_col * FONT_WIDTH,
           term.csr_row * FONT_HEIGHT + FONT_HEIGHT - 2, FONT_WIDTH, 2);
  }
}

U0 Telnet(U8 *host=NULL, U16 port=TELNET_PORT) {
  CHostForm form;
  term.window_width = 80;
  term.window_height = 25;
  term.doc = Fs->display_doc;
  term.win_task = Fs;
  term.waiting_for_input = TRUE;
  term.sock = 0;
  term.sock_ready = 0;
  term.task_idle = TRUE;
  term.parse_state = TELNET_STATE_NORMAL;
  term.buffer_len = 0;
  term.cur_attr = TERM_DEFAULT_ATTR;
  term.bold = FALSE;
  term.csr_visible = TRUE;
  term.csr_row = 0;
  term.csr_col = 0;
  term.saved_row = 0;
  term.saved_col = 0;
  term.xfer_mode = XFER_NONE; // globals are NOT zeroed by the JIT, init explicitly
  term.xfer_proto = XPROTO_YMODEM;
  term.xfer_abort = FALSE;
  term.xfer_path[0] = 0;
  force_disconnect = FALSE; // reset the global so a second run doesn't exit instantly
  I64 art_path = "::/Home/Net/Programs/Telnet/Art/TelnetSplash.ans";
  GrPaletteGet(original_palette);
  AutoComplete(OFF);

  TermClear;

  // Single receive task for the whole session; it idles while sock_ready is 0.
  term.task = Spawn(&TerminalTask, NULL, "Telnet");

  DocMax;
  DocCursor(OFF);
  DocClear;

  SettingsPush;
  MenuPush(
    "Telnet {"
    " Connect(,SCF_ALT+'n');"
    " Exit(,CH_SHIFT_ESC);"
    "}"
    "Load {"
    "  ANSIArt(,SCF_ALT);"
    "}"
    "Transfer {"
    "  Upload(,SCF_ALT+'u');"
    "  Download(,SCF_ALT+'r');"
    "}"
    "Config {"
    "  TogglePalette(,SCF_ALT);"
    "}"
		"About {"
		"	Info(,SCF_ALT);"
		"}"
  );

  StrCopy(Fs->task_title, "TELNET");
  Fs->border_src  = BDS_CONST;
  Fs->title_src = TTS_LOCKED_CONST;
  DocClear(Fs->border_doc, TRUE);

  Fs->win_width = term.window_width;
  WinHorz((TEXT_COLS / 2) - (Fs->win_width / 2),
          (TEXT_COLS / 2) - (Fs->win_width / 2) +
              (Fs->win_width - 1),
          Fs);
  Fs->win_height = term.window_height;
  WinVert((TEXT_ROWS / 2) - (Fs->win_height / 2),
          (TEXT_ROWS / 2) - (Fs->win_height / 2) +
              (Fs->win_height - 1),
          Fs);

  // From here the window content is the cell grid, not the doc.
  Fs->draw_it = &TelnetDrawIt;

show_splash:
  Fs->border_attr = WHITE << 4 + LTRED;
  term.cur_attr = TERM_DEFAULT_ATTR;
  term.bold = FALSE;
  TermScrollbackClear;
  TermClear;

  term.buffer_len = ANSIArtLoad(art_path, term.buffer);
  if (term.buffer_len > 0) {
    term.buffer[term.buffer_len] = '\0';
    term.parse_state = TELNET_STATE_NORMAL; // don't inherit half-parsed state from a dropped connection
    ANSIParse;
  }
  else {
    TermClear;
    TermPutS("Error: Could not load splash screen.\r\n");
  }

init_connection:
  while (!term.waiting_for_input || host != NULL)
  {
    TelnetDisconnect; // safely drop any previous connection first

    term.sock = TelnetOpen(host, port);
    if (term.sock <= 0) {
      term.sock = 0;
      term.waiting_for_input = TRUE;
      host = NULL;
      goto show_splash;
    }

    // Poll-mode receives: TerminalTask paces itself, and close paths never
    // have to wait out a long blocking receive on a soon-to-be-freed socket.
    term.sock(CTCPSocket *)->timeout = 0;
    term.parse_state = TELNET_STATE_NORMAL;

    Fs->border_attr = WHITE << 4 + GREEN;
    term.sock_ready = 1; // Signal that the socket is ready
    term.waiting_for_input = FALSE;

    TermPutS("\x1B[1;32mConnected\x1B[0m\r\n");
    Sleep(600);
    term.cur_attr = TERM_DEFAULT_ATTR;
    term.bold = FALSE;
    TermScrollbackClear;
    TermClear;
    break;
  }

  I64 sc;
	try
	{
    while (!force_disconnect) {
      U8 key = KeyGet(&sc);

      if (term.xfer_mode)
      { // transfer owns the socket: swallow keys, ESC aborts
        if (key == CH_ESC || key == CH_SHIFT_ESC)
          term.xfer_abort = TRUE;
      }
      // ALT
      else if (sc & SCF_ALT && !(sc & SCF_CTRL))
      {
        switch (key)
        {
          case 'n':
            TelnetPrompt(&form);
            host = form.host;
            port = form.port;
            term.waiting_for_input = FALSE;
            goto init_connection;
            break;
          case 'o':
            art_path = ANSIArtBrowser;
            if (art_path != NULL) {
              term.sock_ready = 0;
              term.waiting_for_input = TRUE;
              goto show_splash;
            }
            else {
              TermPutS("Error: Could not load art.\r\n");
            }
            break;
          case 't':
            original_colors = !original_colors;
            if (original_colors) PaletteSetStd(FALSE);
            else {
              GrPaletteSet(original_palette);
              LFBFlush;
            }
            break;
          case 'u': // upload a file (XMODEM/YMODEM)
            if (term.sock_ready)
            {
              U8 *pick = PopUpPickFile("::/Home");
              if (pick && *pick)
              {
                StrCopy(term.xfer_path, pick);
                if (PopUpNoYes("\n\n\tUpload with YMODEM?\n\t(No = XMODEM-128)\n\n"))
                  term.xfer_proto = XPROTO_YMODEM;
                else
                  term.xfer_proto = XPROTO_XMODEM;
                term.xfer_abort = FALSE;
                term.xfer_mode = XFER_SEND; // TerminalTask picks it up
              }
              Free(pick);
            }
            break;
          case 'r': // receive/download a file (X/YMODEM auto-detected)
            if (term.sock_ready)
            {
              U8 *save_name = PopUpGetStr("Save as (blank = YMODEM name, bare names go to ::/Tmp/Downloads):");
              if (save_name)
              {
                I64 name_len;
                StrCopy(term.xfer_path, save_name);
                Free(save_name);
                // StrGet keeps the trailing newline; strip it and stray spaces
                name_len = StrLen(term.xfer_path);
                while (name_len && term.xfer_path[name_len - 1] <= ' ')
                  term.xfer_path[--name_len] = 0;
                term.xfer_abort = FALSE;
                term.xfer_mode = XFER_RECV; // TerminalTask picks it up within ~20ms
              }
            }
            break;
          case 'l':
            PopUpOk("\n\n Not all BBS will work perfectly (yet). \n\n You can load ANSi artwork with Alt+O","\n\n\n\t\tMade by y4my4m\n\n");
            break;
        }
      }
      else {      // fix the bug of holding Ctrl triggers all the CH_CTRL, needs to be handled like in Demo/Graphics/FontEd.ZC:104
        switch (key)
        {
          case 0:
            switch (sc.u8[0])
            {
              case SC_CURSOR_LEFT: if (term.sock_ready) TCPSocketSendString(term.sock, "\x1B[D");  break;
              case SC_CURSOR_RIGHT: if (term.sock_ready) TCPSocketSendString(term.sock, "\x1B[C"); break;
              case SC_CURSOR_UP: // offline (art viewing): scroll history
                if (term.sock_ready) TCPSocketSendString(term.sock, "\x1B[A");
                else TermViewScroll(1);
                break;
              case SC_CURSOR_DOWN:
                if (term.sock_ready) TCPSocketSendString(term.sock, "\x1B[B");
                else TermViewScroll(-1);
                break;
              case SC_PAGE_UP: // Shift+PgUp scrolls history even while connected
                if (term.sock_ready && !(sc & SCF_SHIFT)) TCPSocketSendString(term.sock, "\033[V");
                else TermViewScroll(term.window_height - 1);
                break;
              case SC_PAGE_DOWN:
                if (term.sock_ready && !(sc & SCF_SHIFT)) TCPSocketSendString(term.sock, "\033[U");
                else TermViewScroll(-(term.window_height - 1));
                break;
              case SC_HOME:     if (term.sock_ready) TCPSocketSendString(term.sock, "\033[H"); break;
              case SC_END:      if (term.sock_ready) TCPSocketSendString(term.sock, "\033[K"); break;
              case SC_DELETE:   if (term.sock_ready) TCPSocketSendString(term.sock, "\x7F"); break;
              case SC_F1:       if (term.sock_ready) TCPSocketSendString(term.sock, "\033OP"); break;
              case SC_F2:       if (term.sock_ready) TCPSocketSendString(term.sock, "\033OQ"); break;
              case SC_F3:       if (term.sock_ready) TCPSocketSendString(term.sock, "\033OR"); break;
              case SC_F4:       if (term.sock_ready) TCPSocketSendString(term.sock, "\033OS"); break;
              case SC_F5:       if (term.sock_ready) TCPSocketSendString(term.sock, "\033Ot"); break;
              case SC_F6:       if (term.sock_ready) TCPSocketSendString(term.sock, "\033[17~"); break;
              case SC_F7:       if (term.sock_ready) TCPSocketSendString(term.sock, "\033[18~"); break;
              case SC_F8:       if (term.sock_ready) TCPSocketSendString(term.sock, "\033[19~"); break;
              case SC_F9:       if (term.sock_ready) TCPSocketSendString(term.sock, "\033[20~"); break;
              case SC_F10:      if (term.sock_ready) TCPSocketSendString(term.sock, "\033[21~"); break;
              case SC_F11:      if (term.sock_ready) TCPSocketSendString(term.sock, "\033[23~"); break;
              case SC_F12:      if (term.sock_ready) TCPSocketSendString(term.sock, "\033[24~"); break;
              default:
                break;
            }
            break;
          case 9:
            switch (sc.u8[0])
            {
              case SC_TAB:
                if (term.sock_ready) TCPSocketSendString(term.sock, "\x09");
                break;
              default:
                break;
            }
            break; // was falling through and sending backspace codes on every TAB
          case CH_BACKSPACE:
            if (term.sock_ready) TCPSocketSendString(term.sock, "\x08\x7F");
            break;
          case CH_SHIFT_ESC:
            if (term.sock)
            { // covers both live connections and remote-closed sockets not yet freed
              term.waiting_for_input = TRUE;
              host = NULL;
              TelnetDisconnect;
              TermClear;
              TermPutS("Telnet connection closed.\r\n");
              Sleep(100);
              goto show_splash;
            }
            else
              force_disconnect = TRUE;
            break;
          case CH_ESC:
            if (term.sock_ready) TCPSocketSendString(term.sock, "\x1B");
            break;
          // send buffer on enter
          case '\n':
            if (term.sock_ready) TCPSocketSendString(term.sock, "\r\n");
            break;
          case CH_CTRLU:
            if(term.sock_ready) TCPSocketSendString(term.sock, "\x15");
            break;
          default:
            if (key >= ' ' && key <= '~') {
              // Handle regular keys
              U8 input_buf[2];
              input_buf[0] = key;
              input_buf[1] = '\0';
              if (term.sock_ready) TCPSocketSend(term.sock, input_buf, 1);
            }
            break;
        }
      }

    }
  }
  catch
    PutExcept;

  // Tear down: stop the receive task, then free any remaining socket.
  force_disconnect = TRUE;
  TelnetDisconnect;

  Fs->draw_it = NULL;
  MenuPop;
  SettingsPop;
  GrPaletteSet(original_palette);
  LFBFlush;
}

// dev server
// Telnet("localhost", 8888);

// ZealOS's official BBS zealos
// Telnet("bbs.zealos.net", 4001);

Telnet;


