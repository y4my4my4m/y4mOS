/*	Zinc: a GUI web browser for ZealOS. Public Domain.

	A small browser engine in four parts (Zinc/ directory):
	  HTML.ZC    tag-soup parser -> DOM tree
	  CSS.ZC     CSS subset (colors/bold/underline/display) -> 16-color VGA
	  JS.ZC      small JavaScript interpreter with DOM bindings
	  Render.ZC  styled DOM -> DolDoc with clickable links/forms

	Features: http + https (TLS 1.3, encrypted but NOT authenticated -- see
	Protocols/TLS.ZC), <style> blocks, inline style=, up to four external
	stylesheets, inline <script>, GET forms, back/forward history, titles.
	Not done: images (ZincGX has PNG), external scripts, POST, cookies, frames.

	Run:  Zinc;               (opens the built-in welcome page)
	      Zinc("http://frogfind.com/");

	Mouse: click the address bar, links, buttons, [input] fields.
	Keyboard: type an address and press ENTER (scheme optional), or the
	short commands b f r g h q, l<n> links, i<n> widgets.

	Built-in pages: zinc:welcome, zinc:test (JS engine self-checks),
	zinc:css (CSS renderer self-checks; best viewed in ZincGX).

	No literal dollar signs allowed in this file (DolDoc source rule). */

Cd(__DIR__);;

#include "HTML"
#include "CSS"
#include "JS"
#include "SVG"
#include "Render"

#define ZINC_HISTORY	64
#define ZINC_BAR_WIDTH	60

CZNode	  *zinc_dom = NULL;
CJsInterp *zinc_js	= NULL;
CHttpUrl   zinc_base;			// parsed current URL, for resolving links
Bool	   zinc_base_ok = FALSE;
U8		   zinc_note[144];		// one-line status shown in the chrome
U8		  *zinc_post_body = NULL; // set by a POST form submit, consumed by the next nav fetch

U8	*zinc_back[ZINC_HISTORY], *zinc_fwd[ZINC_HISTORY];
I64	 zinc_back_count = 0, zinc_fwd_count = 0;

