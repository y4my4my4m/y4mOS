#define JP_INSTOF	289	// `instanceof` keyword, at relational level

/* AST node types */
#define JN_NUM		1
#define JN_STR		2
#define JN_IDENT	3
#define JN_BIN		4
#define JN_UN		5
#define JN_ASSIGN	6
#define JN_CALL		7
#define JN_MEMBER	8
#define JN_INDEX	9
#define JN_COND		10
#define JN_PREINC	11
#define JN_POSTINC	12
#define JN_ARRLIT	13
#define JN_OBJLIT	14
#define JN_PROP		15
#define JN_VAR		16
#define JN_VARDECL	17
#define JN_IF		18
#define JN_WHILE	19
#define JN_FOR		20
#define JN_BLOCK	21
#define JN_FUNC		22
#define JN_RETURN	23
#define JN_BREAK	24
#define JN_EXPR		25
#define JN_NULLLIT	26
#define JN_UNDEFLIT	27
#define JN_FOROF	28	// for (x of/in it) body; op: 0 = of, 1 = in
#define JN_TRY		29	// a = try, b = catch (str = var), c = finally
#define JN_THROW	30
#define JN_NEW		31	// new-expression marker wrapping the constructor ref
#define JN_CLASS	32	// str = name, a = JN_PROP method chain
#define JN_SPREAD	33	// ...expr in call args / array literals; a = expr
#define JN_AWAIT	34	// await expr; unwraps our synchronous promises
#define JN_DESTRUCT	35	// const {a,b:c}=e / [x,y]=e; op: 0 obj 1 arr; a=init, b=idents
#define JN_REGEX	36	// regex literal -> stub RegExp object (no engine yet)
#define JN_SEQ		37	// comma/sequence: a, b, ... -> evaluate all, yield last
#define JN_CONTINUE	38
#define JN_DO		39	// do a while (b)
#define JN_SWITCH	40	// a = discriminant, b = JN_CASE chain
#define JN_CASE		41	// a = test expr (NULL = default), b = stmt chain

/* control flow states */
#define JF_NORMAL	0
#define JF_RETURN	1
#define JF_BREAK	2
#define JF_THROW	3
#define JF_CONTINUE	4	// cleared by the enclosing loop, propagates through blocks

class CJsAllocHdr
{
	CJsAllocHdr *next;
};

class CJsProp
{
	CJsProp *next;
	U8		*name;
	U64		 val;	// CJsVal*
};

class CJsVal
{
	I64		 type;
	F64		 num;
	U8		*str;
	CJsProp *props;		// JV_OBJ
	CZNode	*node;		// JSO_ELEMENT / JSO_STYLE
	U64		 func;		// CJsNode* for JV_FUNC
	I64		 native_id;	// JSN_* for JV_NATIVE, JSO_* for JV_OBJ
	CJsVal	**items;	// JV_ARR
	I64		 count, cap;
	U64		 fenv;		// CJsEnv*: env captured at definition (closures);
						// U64 because CJsEnv is declared later in this file
	CJsVal	*proto;		// prototype-chain link for property lookup
};

class CJsTimer
{ // one setTimeout/setInterval registration, or a pending async-XHR callback
	CJsTimer *next;
	I64		  id;
	CJsVal	 *fn;		// callback (JV_FUNC/JV_NATIVE); NULL for is_xhr timers
	CJsVal	 *this_val;	// 'this' for the callback (the XHR object, or NULL)
	F64		  due;		// tS at which it fires
	F64		  interval;	// repeat period in seconds; 0 = one-shot
	Bool	  active;
	Bool	  is_xhr;	// fire the XHR object's onreadystatechange/onload instead
};

class CJsListener
{ // an addEventListener registration, or an el.onX = fn property handler
	CJsListener *next;
	CZNode		*node;	// element the handler is bound to
	U8			*type;	// "click", "input", ... (no "on" prefix)
	CJsVal		*fn;
	Bool		 active;
	Bool		 is_prop; // set via el.onX= (replaces prior); FALSE = addEventListener
};

class CJsMicro
{ // one queued microtask (promise reaction); drained before timers each pump
	CJsMicro *next;
	CJsVal	 *fn;
	CJsVal	 *arg;
	Bool	  has_arg;
};

class CJsNode
{
	I64		 type;
	I64		 op;	// operator/punct code, or +1/-1 for inc/dec
	F64		 num;	// numeric literal value (JN_NUM only)
	U8		*str;
	CJsNode *a, *b, *c, *d, *next;
};

class CJsTok
{
	I64	 type;
	F64	 num;
	U8	*str;
	I64	 punct;
};

class CJsEnv
{
	CJsEnv	*parent;
	CJsProp *vars;
};

class CJsInterp
{
	CJsAllocHdr *allocs;
	CJsEnv	*genv, *env;
	CZNode	*dom_root;
	U8		*url;			// arena copy of the page URL
	U8		*navigate;		// set when a script assigns location.href
	U8		*write_buf;
	I64		 write_len;
	Bool	 dom_dirty;
	I64		 steps, depth, flow;
	CJsVal	*ret_val;
	CJsVal	*doc_obj, *loc_obj, *win_obj;
	U8		 err[144];
	Bool	 has_err;
	CJsTok	*toks;
	I64		 tok_count, pos;
	CJsTimer	*timers;		// setTimeout/setInterval/async-XHR queue
	CJsListener	*listeners;		// addEventListener + el.onX handlers
	I64			 next_timer_id;
	CJsVal		*exc;			// pending thrown value while flow == JF_THROW
	CJsMicro	*micro_head, *micro_tail; // promise reaction queue
};

/* forward declarations for the recursive parser/evaluator */
extern CJsNode *JsParseAssign(CJsInterp *ji);
extern CJsNode *JsParseExpr(CJsInterp *ji); // comma-sequence of assignments
extern CJsNode *JsParseClass(CJsInterp *ji); // "class" eaten; stmt AND expression
extern CJsNode *JsParseStmt(CJsInterp *ji);
extern CJsNode *JsParseFunc(CJsInterp *ji, Bool need_name);
extern U0 JsMicroDrain(CJsInterp *ji); // JN_AWAIT (in JsEval) drains before unwrap
extern CJsVal  *JsEval(CJsInterp *ji, CJsNode *node);
extern CJsVal  *JsCall(CJsInterp *ji, CJsVal *fn, CJsVal *this_val,
					   CJsVal **args, I64 argc);
// JsMemberSet (el.onX = fn) registers a listener; the definition is far below.
extern CJsListener *JsListenerAdd(CJsInterp *ji, CZNode *node, U8 *type,
								  CJsVal *fn, Bool is_prop);
// JsMemberSet (styleEl.textContent = css) ingests CSS-in-JS; defined below.
extern U0 JsStyleIngest(CJsInterp *ji, CZNode *node);

/* ---- arena ---- */

// Soft parse-error budget: unrecognized primaries are skipped, not fatal.
// First few are logged per script (reset in JsRun) so gaps stay visible.
I64 js_soft_errs = 0;

U8 *JsAlloc(CJsInterp *ji, I64 size)
{
	CJsAllocHdr *h = CAlloc(size + sizeof(CJsAllocHdr));

	h->next = ji->allocs;
	ji->allocs = h;

	return h(U8 *) + sizeof(CJsAllocHdr);
}

U8 *JsStrDup(CJsInterp *ji, U8 *s)
{
	U8	*d;
	I64	 len;

	if (!s)
		s = "";
	len = StrLen(s);
	d = JsAlloc(ji, len + 1);
	MemCopy(d, s, len + 1);

	return d;
}

U0 JsErr(CJsInterp *ji, U8 *msg)
{
	if (!ji->has_err)
	{
		StrPrint(ji->err, "JS: %s", msg);
		ji->has_err = TRUE;
	}
}

/* ---- values ---- */

CJsVal *JsValNew(CJsInterp *ji, I64 type)
{
	CJsVal *v = JsAlloc(ji, sizeof(CJsVal))(CJsVal *);

	v->type = type;

	return v;
}

CJsVal *JsUndefV(CJsInterp *ji)	{ return JsValNew(ji, JV_UNDEF); }
CJsVal *JsNullV(CJsInterp *ji)	{ return JsValNew(ji, JV_NULL); }

CJsVal *JsNumV(CJsInterp *ji, F64 n)
{
	CJsVal *v = JsValNew(ji, JV_NUM);

	v->num = n;

	return v;
}

CJsVal *JsBoolV(CJsInterp *ji, Bool b)
{
	CJsVal *v = JsValNew(ji, JV_BOOL);

	if (b)
		v->num = 1;

	return v;
}

CJsVal *JsStrV(CJsInterp *ji, U8 *s)
{
	CJsVal *v = JsValNew(ji, JV_STR);

	v->str = JsStrDup(ji, s);

	return v;
}

CJsVal *JsNativeV(CJsInterp *ji, I64 id)
{
	CJsVal *v = JsValNew(ji, JV_NATIVE);

	v->native_id = id;

	return v;
}

CJsVal *JsElemV(CJsInterp *ji, CZNode *node)
{
	CJsVal *v = JsValNew(ji, JV_OBJ);

	v->native_id = JSO_ELEMENT;
	v->node = node;

	return v;
}

CJsVal *JsArrV(CJsInterp *ji)
{
	CJsVal *v = JsValNew(ji, JV_ARR);

	v->cap = 8;
	v->items = JsAlloc(ji, v->cap * sizeof(U64))(CJsVal **);

	return v;
}

U0 JsArrPush(CJsInterp *ji, CJsVal *arr, CJsVal *item)
{
	CJsVal **grown;
	I64		 i;

	if (arr->count >= arr->cap)
	{
		arr->cap *= 2;
		grown = JsAlloc(ji, arr->cap * sizeof(U64))(CJsVal **);
		for (i = 0; i < arr->count; i++)
			grown[i] = arr->items[i];
		arr->items = grown;
	}
	arr->items[arr->count++] = item;
}

CJsVal *JsPropGet(CJsVal *obj, U8 *name)
{ // own properties first, then the prototype chain (depth-capped)
	CJsProp *p;
	I64		 depth = 0;

	while (obj && depth < 8)
	{
		p = obj->props;
		while (p)
		{
			if (!StrCompare(p->name, name))
				return p->val(CJsVal *);
			p = p->next;
		}
		obj = obj->proto;
		depth++;
	}

	return NULL;
}

U0 JsPropSet(CJsInterp *ji, CJsVal *obj, U8 *name, CJsVal *val)
{
	CJsProp *p = obj->props;

	while (p)
	{
		if (!StrCompare(p->name, name))
		{
			p->val = val(U64);
			return;
		}
		p = p->next;
	}
	p = JsAlloc(ji, sizeof(CJsProp))(CJsProp *);
	p->name = JsStrDup(ji, name);
	p->val	= val(U64);
	p->next = obj->props;
	obj->props = p;
}

/* ---- coercions ---- */

Bool JsToBool(CJsVal *v)
{
	switch (v->type)
	{
		case JV_UNDEF:
		case JV_NULL:
			return FALSE;
		case JV_BOOL:
		case JV_NUM:
			return v->num != 0;
		case JV_STR:
			return *v->str != 0;
	}

	return TRUE;
}

F64 JsToNum(CJsVal *v)
{
	switch (v->type)
	{
		case JV_BOOL:
		case JV_NUM:
			return v->num;
		case JV_STR:
			return Str2F64(v->str);
	}

	return 0;
}

U8 *JsNumToStr(CJsInterp *ji, F64 n)
{
	U8	buf[64];
	I64	i = ToI64(n);

	// ToF64/ToI64 intrinsics, NOT postfix casts: `i(F64)` is a no-op (gotcha #1),
	// which silently sent every integer down the %g branch (4 -> "4.00000000e0").
	if (ToF64(i) == n && Abs(n) < 1e15)
		StrPrint(buf, "%d", i);
	else
		StrPrint(buf, "%g", n);

	return JsStrDup(ji, buf);
}

U8 *JsToStr(CJsInterp *ji, CJsVal *v)
{
	U8	   *out, *piece;
	I64		i, len;
	CJsVal *w;

	switch (v->type)
	{
		case JV_UNDEF:	return "undefined";
		case JV_NULL:	return "null";
		case JV_BOOL:
			if (v->num)
				return "true";
			return "false";
		case JV_NUM:	return JsNumToStr(ji, v->num);
		case JV_STR:	return v->str;
		case JV_FUNC:
		case JV_NATIVE:	return "function";
		case JV_ARR:
			len = 1;
			for (i = 0; i < v->count; i++)
				len += StrLen(JsToStr(ji, v->items[i])) + 1;
			out = JsAlloc(ji, len + 1);
			*out = 0;
			for (i = 0; i < v->count; i++)
			{
				if (i)
					CatPrint(out, ",");
				piece = JsToStr(ji, v->items[i]);
				CatPrint(out, "%s", piece);
			}
			return out;
		case JV_OBJ:
			// custom toString()/valueOf() coercion is deferred: calling into a
			// corrupted-looking object here turned heap bugs into hard GP faults.
			// A plain object stringifies to the spec default.
			return "[object Object]";
	}

	return "[object Object]";
}

/* ---- lexer ---- */

Bool JsIdentCh(I64 ch, Bool first)
{
	if (('a' <= ch <= 'z') || ('A' <= ch <= 'Z') || ch == '_' || ch == 0x24)
		return TRUE;
	if (!first && '0' <= ch <= '9')
		return TRUE;

	return FALSE;
}

Bool JsLexRegexPos(CJsInterp *ji, I64 n)
{ // is a '/' here a REGEX literal (vs division)? Standard heuristic: regex
  // after nothing, after most puncts (not ')' / ']'), or after these keywords.
	CJsTok *pt;

	if (!n)
		return TRUE;
	pt = &ji->toks[n - 1];
	if (pt->type == JT_PUNCT)
		return pt->punct != ')' && pt->punct != ']';
	if (pt->type == JT_IDENT)
		return !StrCompare(pt->str, "return") || !StrCompare(pt->str, "typeof") ||
			   !StrCompare(pt->str, "case")   || !StrCompare(pt->str, "delete") ||
			   !StrCompare(pt->str, "void")   || !StrCompare(pt->str, "in") ||
			   !StrCompare(pt->str, "of")     || !StrCompare(pt->str, "instanceof") ||
			   !StrCompare(pt->str, "new")    || !StrCompare(pt->str, "else") ||
			   !StrCompare(pt->str, "do");

	return FALSE;
}

I64 JsLexRegex(CJsInterp *ji, U8 *p, CJsTok *t)
{ // scan /pattern/flags at p (p[0] == '/'). Fills t (JT_REGEX, str = pattern,
  // num = flag bits g1 i2 m4 s8 u16 y32); returns chars consumed, 0 = not a
  // one-line regex (caller lexes '/' as division instead).
	U8	 pat[512];
	I64	 i = 1, len = 0, fl = 0;
	Bool inclass = FALSE;

	while (p[i] && p[i] != '\n' && len < 508)
	{
		if (p[i] == '\\' && p[i + 1])
		{
			pat[len++] = p[i];
			pat[len++] = p[i + 1];
			i += 2;
		}
		else if (p[i] == '[')
		{
			inclass = TRUE;
			pat[len++] = p[i++];
		}
		else if (p[i] == ']')
		{
			inclass = FALSE;
			pat[len++] = p[i++];
		}
		else if (p[i] == '/' && !inclass)
			break;
		else
			pat[len++] = p[i++];
	}
	if (p[i] != '/' || !len)
		return 0;
	i++;
	while ('a' <= p[i] <= 'z')
	{
		if (p[i] == 'g')
			fl |= 1;
		else if (p[i] == 'i')
			fl |= 2;
		else if (p[i] == 'm')
			fl |= 4;
		else if (p[i] == 's')
			fl |= 8;
		else if (p[i] == 'u')
			fl |= 16;
		else if (p[i] == 'y')
			fl |= 32;
		i++;
	}
	pat[len] = 0;
	t->type	= JT_REGEX;
	t->str	= JsStrDup(ji, pat);
	t->num	= fl;

	return i;
}

Bool JsLex(CJsInterp *ji, U8 *src)
{
	U8	*p = src;
	I64	 cap = StrLen(src) + 16, n = 0, punct, len, quote;
	U8	 sbuf[1024];
	CJsTok *t;
	I64	 tpl_brace[8], tpl_sp = 0;	// template-literal nesting state

	// template literals desugar into extra tokens ( str + ( expr ) ... )
	while (*p)
	{
		if (*p == 0x60)
			cap += 8;
		p++;
	}
	p = src;

	// NOT arena-allocated: the token array is ~32 bytes per source CHAR (worst
	// case) and is only needed during parse - JsRun frees it right after. Token
	// strings are JsStrDup'd into the arena and shared by the AST, so they live
	// on. Zeroed alloc matters: the tail's type==0 (JT_EOF) terminates parsing.
	ji->toks = CAlloc(cap * sizeof(CJsTok))(CJsTok *);

	while (*p)
	{
		if (!(n & 2047))
			Yield; // big bundles: stay cooperative while tokenizing
		if (*p == ' ' || *p == '\t' || *p == '\r' || *p == '\n')
			p++;
		else if (p[0] == '/' && p[1] == '/')
		{
			while (*p && *p != '\n')
				p++;
		}
		else if (p[0] == '/' && p[1] == '*')
		{
			p += 2;
			while (*p && !(p[0] == '*' && p[1] == '/'))
				p++;
			if (*p)
				p += 2;
		}
		else if (n >= cap - 1)
		{
			JsErr(ji, "too many tokens");
			return FALSE;
		}
		else if ('0' <= *p <= '9' ||
				 (*p == '.' && '0' <= p[1] <= '9'))
		{
			t = &ji->toks[n++];
			t->type = JT_NUM;
			if (p[0] == '0' && (p[1] == 'x' || p[1] == 'X'))
			{
				t->num = Str2I64(p + 2, 16);
				p += 2;
				while (ZHexNibble(*p) >= 0)
					p++;
			}
			else
			{
				t->num = Str2F64(p);
				while ('0' <= *p <= '9')
					p++;
				if (*p == '.')
				{
					p++;
					while ('0' <= *p <= '9')
						p++;
				}
				if (*p == 'e' || *p == 'E')
				{
					p++;
					if (*p == '+' || *p == '-')
						p++;
					while ('0' <= *p <= '9')
						p++;
				}
			}
		}
		else if (*p == 0x60)
		{ // template literal: desugar to tokens ( "" + "part" + ( expr ) ... )
		  // The leading "" forces string concatenation semantics.
			if (tpl_sp >= 8)
			{
				JsErr(ji, "templates nested too deep");
				return FALSE;
			}
			tpl_brace[tpl_sp] = 0;
			tpl_sp++;
			t = &ji->toks[n++];
			t->type = JT_PUNCT;
			t->punct = '(';
			t = &ji->toks[n++];
			t->type = JT_STR;
			t->str = JsStrDup(ji, "");
			p++;
			goto js_tpl_part;
		}
		else if (*p == '}' && tpl_sp && !tpl_brace[tpl_sp - 1])
		{ // end of a template interpolation expression
			t = &ji->toks[n++];
			t->type = JT_PUNCT;
			t->punct = ')';
			p++;
			goto js_tpl_part;
		}
		else if (*p == '/' && p[1] != '/' && p[1] != '*' &&
				 JsLexRegexPos(ji, n) && (len = JsLexRegex(ji, p, &ji->toks[n])))
		{ // regex literal -> JT_REGEX token (stub RegExp object at runtime).
		  // Without this every minified bundle dies at the first /re/.
			n++;
			p += len;
		}
		else if (*p == '"' || *p == '\'')
		{ // string literal
			quote = *p++;
			len = 0;
			while (*p && *p != quote && len < 1020)
			{
				if (*p == '\\' && p[1])
				{
					p++;
					switch (*p)
					{
						case 'n':	sbuf[len++] = '\n';	break;
						case 't':	sbuf[len++] = '\t';	break;
						case 'r':	sbuf[len++] = '\r';	break;
						case '0':	sbuf[len++] = '?';	break;
						default:	sbuf[len++] = *p;	break;
					}
					p++;
				}
				else
					sbuf[len++] = *p++;
			}
			if (*p)
				p++;
			sbuf[len] = 0;
			t = &ji->toks[n++];
			t->type = JT_STR;
			t->str	= JsStrDup(ji, sbuf);
		}
		else if (JsIdentCh(*p, TRUE))
		{
			len = 0;
			while (JsIdentCh(*p, FALSE) && len < 120)
				sbuf[len++] = *p++;
			sbuf[len] = 0;
			t = &ji->toks[n++];
			t->type = JT_IDENT;
			t->str	= JsStrDup(ji, sbuf);
		}
		else
		{
			punct = 0;
			if (!StrNCompare(p, "...", 3))		{ punct = JP_SPREAD; p += 3; }
			else if (!StrNCompare(p, "?.", 2))	{ punct = JP_OPTCHAIN; p += 2; }
			else if (!StrNCompare(p, "??", 2))	{ punct = JP_NULLISH; p += 2; }
			else if (!StrNCompare(p, "===", 3))	{ punct = JP_EQ3;	p += 3; }
			else if (!StrNCompare(p, "!==", 3))	{ punct = JP_NE3;	p += 3; }
			else if (!StrNCompare(p, ">>>", 3))	{ punct = JP_SHR3;	p += 3; }
			else if (!StrNCompare(p, "&&=", 3))	{ punct = JP_ANDEQ;	p += 3; }
			else if (!StrNCompare(p, "||=", 3))	{ punct = JP_OREQ;	p += 3; }
			else if (!StrNCompare(p, "??=", 3))	{ punct = JP_NULEQ;	p += 3; }
			else if (!StrNCompare(p, "**=", 3))	{ punct = JP_POWEQ;	p += 3; }
			else if (!StrNCompare(p, "<<=", 3))	{ punct = JP_SHLEQ;	p += 3; }
			else if (!StrNCompare(p, ">>=", 3))	{ punct = JP_SHREQ;	p += 3; }
			else if (!StrNCompare(p, "**", 2))	{ punct = JP_POW;	p += 2; }
			else if (!StrNCompare(p, "&=", 2))	{ punct = JP_BANDEQ; p += 2; }
			else if (!StrNCompare(p, "|=", 2))	{ punct = JP_BOREQ;	p += 2; }
			else if (!StrNCompare(p, "^=", 2))	{ punct = JP_BXOREQ; p += 2; }
			else if (!StrNCompare(p, "<<", 2))	{ punct = JP_SHL;	p += 2; }
			else if (!StrNCompare(p, ">>", 2))	{ punct = JP_SHR;	p += 2; }
			else if (!StrNCompare(p, "==", 2))	{ punct = JP_EQ2;	p += 2; }
			else if (!StrNCompare(p, "!=", 2))	{ punct = JP_NE;	p += 2; }
			else if (!StrNCompare(p, "<=", 2))	{ punct = JP_LE;	p += 2; }
			else if (!StrNCompare(p, ">=", 2))	{ punct = JP_GE;	p += 2; }
			else if (!StrNCompare(p, "&&", 2))	{ punct = JP_AND;	p += 2; }
			else if (!StrNCompare(p, "||", 2))	{ punct = JP_OR;	p += 2; }
			else if (!StrNCompare(p, "++", 2))	{ punct = JP_INC;	p += 2; }
			else if (!StrNCompare(p, "--", 2))	{ punct = JP_DEC;	p += 2; }
			else if (!StrNCompare(p, "+=", 2))	{ punct = JP_ADDEQ;	p += 2; }
			else if (!StrNCompare(p, "-=", 2))	{ punct = JP_SUBEQ;	p += 2; }
			else if (!StrNCompare(p, "*=", 2))	{ punct = JP_MULEQ;	p += 2; }
			else if (!StrNCompare(p, "/=", 2))	{ punct = JP_DIVEQ;	p += 2; }
			else if (!StrNCompare(p, "%=", 2))	{ punct = JP_MODEQ;	p += 2; }
			else if (!StrNCompare(p, "=>", 2))	{ punct = JP_ARROW;	p += 2; }
			else
				punct = *p++;
			t = &ji->toks[n++];
			t->type	 = JT_PUNCT;
			t->punct = punct;
			if (tpl_sp)
			{ // track nested braces inside a template interpolation
				if (punct == '{')
					tpl_brace[tpl_sp - 1]++;
				else if (punct == '}')
					tpl_brace[tpl_sp - 1]--;
			}
		}
		goto js_lex_next; // normal path: skip the template-part scanner

js_tpl_part:
		// literal template text up to a backtick or an interpolation start
		len = 0;
		while (*p && *p != 0x60 && !(*p == 0x24 && p[1] == '{') && len < 1020)
		{
			if (*p == '\\' && p[1])
			{
				p++;
				if (*p == 'n')
					sbuf[len++] = '\n';
				else if (*p == 't')
					sbuf[len++] = '\t';
				else
					sbuf[len++] = *p;
				p++;
			}
			else
				sbuf[len++] = *p++;
		}
		sbuf[len] = 0;
		if (n >= cap - 8)
		{
			JsErr(ji, "too many tokens");
			return FALSE;
		}
		if (len)
		{
			t = &ji->toks[n++];
			t->type	 = JT_PUNCT;
			t->punct = '+';
			t = &ji->toks[n++];
			t->type = JT_STR;
			t->str = JsStrDup(ji, sbuf);
		}
		if (*p == 0x60)
		{ // template ends
			t = &ji->toks[n++];
			t->type	 = JT_PUNCT;
			t->punct = ')';
			tpl_sp--;
			p++;
		}
		else if (*p)
		{ // interpolation begins (0x24 '{')
			t = &ji->toks[n++];
			t->type	 = JT_PUNCT;
			t->punct = '+';
			t = &ji->toks[n++];
			t->type	 = JT_PUNCT;
			t->punct = '(';
			p += 2;
		}
		else
		{
			JsErr(ji, "unterminated template literal");
			return FALSE;
		}
js_lex_next:;
	}

	t = &ji->toks[n++];
	t->type = JT_EOF;
	ji->tok_count = n;
	ji->pos = 0;

	return TRUE;
}

/* ---- parser helpers ---- */

CJsTok *JsTok(CJsInterp *ji)
{
	return &ji->toks[ji->pos];
}

Bool JsIsPunct(CJsInterp *ji, I64 punct)
{
	return ji->toks[ji->pos].type == JT_PUNCT &&
		   ji->toks[ji->pos].punct == punct;
}

Bool JsEatPunct(CJsInterp *ji, I64 punct)
{
	if (JsIsPunct(ji, punct))
	{
		ji->pos++;
		return TRUE;
	}

	return FALSE;
}

Bool JsIsKw(CJsInterp *ji, U8 *kw)
{
	return ji->toks[ji->pos].type == JT_IDENT &&
		   !StrCompare(ji->toks[ji->pos].str, kw);
}

Bool JsEatKw(CJsInterp *ji, U8 *kw)
{
	if (JsIsKw(ji, kw))
	{
		ji->pos++;
		return TRUE;
	}

	return FALSE;
}

CJsNode *JsNode(CJsInterp *ji, I64 type)
{
	CJsNode *node = JsAlloc(ji, sizeof(CJsNode))(CJsNode *);

	node->type = type;

	return node;
}

/* ---- parser ---- */

CJsNode *JsParseArgs(CJsInterp *ji)
{ // '(' already eaten; returns arg list, eats ')'
	CJsNode *head = NULL, *tail = NULL, *arg;
	I64		 dep;

	if (JsEatPunct(ji, ')'))
		return NULL;
	do
	{
		if (JsEatPunct(ji, JP_SPREAD))
		{ // f(...arr): spread argument, flattened at call time
			arg = JsNode(ji, JN_SPREAD);
			arg->a = JsParseAssign(ji);
		}
		else
			arg = JsParseAssign(ji);
		if (!arg)
			return head;
		if (tail)
			tail->next = arg;
		else
			head = arg;
		tail = arg;
	}
	while (JsEatPunct(ji, ','));
	if (!JsEatPunct(ji, ')'))
	{ // desync RECOVERY: balanced-skip to this call's ) so the whole script
	  // survives (a hard parse error would kill the entire bundle).
		dep = 1;
		while (dep > 0 && JsTok(ji)->type != JT_EOF)
		{
			if (JsIsPunct(ji, '(') || JsIsPunct(ji, '[') || JsIsPunct(ji, '{'))
				dep++;
			else if (JsIsPunct(ji, ')') || JsIsPunct(ji, ']') || JsIsPunct(ji, '}'))
				dep--;
			ji->pos++;
		}
	}

	return head;
}

CJsNode *JsParseClass(CJsInterp *ji)
{ // "class" already eaten. class [Name] [extends E] { members }. Callable from
  // BOTH statement and expression positions (minified code uses class exprs).
	CJsNode *node = JsNode(ji, JN_CLASS), *item, *mtail = NULL;
	CJsTok	*t;

	t = JsTok(ji);
	if (t->type == JT_IDENT && StrCompare(t->str, "extends"))
	{ // optional class name (but not the `extends` keyword)
		node->str = t->str;
		ji->pos++;
	}
	if (JsEatKw(ji, "extends"))
		node->c = JsParseAssign(ji); // parsed, superclass ignored (no real super)
	if (!JsEatPunct(ji, '{'))
		return node;
	while (!JsIsPunct(ji, '}') && JsTok(ji)->type != JT_EOF && !ji->has_err)
	{
		if (JsEatPunct(ji, ';'))
		{ /* stray semicolons between members */ }
		else
		{
			// skip modifier keywords (static/async/get/set) when another member
			// token follows, else the modifier IS the member name.
			while (JsTok(ji)->type == JT_IDENT &&
				   (!StrCompare(JsTok(ji)->str, "static") ||
					!StrCompare(JsTok(ji)->str, "async") ||
					!StrCompare(JsTok(ji)->str, "get") ||
					!StrCompare(JsTok(ji)->str, "set")) &&
				   (ji->toks[ji->pos + 1].type == JT_IDENT ||
					ji->toks[ji->pos + 1].type == JT_STR ||
					(ji->toks[ji->pos + 1].type == JT_PUNCT &&
					 (ji->toks[ji->pos + 1].punct == '[' ||
					  ji->toks[ji->pos + 1].punct == '*'))))
				ji->pos++;
			JsEatPunct(ji, '*'); // generator method
			item = JsNode(ji, JN_PROP);
			if (JsEatPunct(ji, '['))
			{ // computed member name [expr]() - name discarded
				JsParseAssign(ji);
				if (!JsEatPunct(ji, ']'))
					JsErr(ji, "expected ] in class member");
				item->str = "_computed";
			}
			else
			{
				t = JsTok(ji);
				if (t->type != JT_IDENT && t->type != JT_STR && t->type != JT_NUM)
				{
					JsErr(ji, "bad class member");
					break;
				}
				ji->pos++;
				if (t->type == JT_NUM)
					item->str = "_num";
				else
					item->str = t->str;
			}
			if (JsIsPunct(ji, '('))
				item->a = JsParseFunc(ji, FALSE); // method (params){body}
			else
			{ // class field: name = expr;  (or just name;)
				if (JsEatPunct(ji, '='))
					item->a = JsParseAssign(ji);
				JsEatPunct(ji, ';');
			}
			if (mtail)
				mtail->next = item;
			else
				node->a = item;
			mtail = item;
		}
	}
	JsEatPunct(ji, '}');

	return node;
}

U0 JsTokDesc(CJsInterp *ji, I64 idx, U8 *out)
{ // short printable form of one token, for parse diagnostics. out >= 16 bytes.
	CJsTok *t;
	I64		n;

	out[0] = 0;
	if (idx < 0 || idx >= ji->tok_count)
		return;
	t = &ji->toks[idx];
	if (t->type == JT_IDENT || t->type == JT_STR)
	{
		n = StrLen(t->str);
		if (n > 12)
			n = 12;
		MemCopy(out, t->str, n);
		out[n] = 0;
	}
	else if (t->type == JT_NUM)
		StrPrint(out, "%d", ToI64(t->num));
	else if (t->type == JT_REGEX)
		StrPrint(out, "/re/");
	else if (t->punct < 256)
		StrPrint(out, "%c", t->punct);
	else
		StrPrint(out, "#%d", t->punct);
}

CJsNode *JsParsePrimary(CJsInterp *ji)
{
	CJsTok	*t = JsTok(ji);
	CJsNode *node, *item, *tail;
	U8		 numkey[24], embuf[96], emtk[16];
	I64		 emk;

	if (t->type == JT_NUM)
	{
		ji->pos++;
		node = JsNode(ji, JN_NUM);
		node->num = t->num;
		return node;
	}
	if (t->type == JT_STR)
	{
		ji->pos++;
		node = JsNode(ji, JN_STR);
		node->str = t->str;
		return node;
	}
	if (t->type == JT_REGEX)
	{
		ji->pos++;
		node = JsNode(ji, JN_REGEX);
		node->str = t->str;
		node->op  = t->num; // flag bits
		return node;
	}
	if (t->type == JT_IDENT)
	{
		if (JsIsKw(ji, "class"))
		{ // class expression: const X = class {..}; {k: class{}}
			ji->pos++;
			return JsParseClass(ji);
		}
		if (JsIsKw(ji, "function"))
		{
			ji->pos++;
			return JsParseFunc(ji, FALSE);
		}
		if (JsEatKw(ji, "new"))
		{ // real construction: JN_CALL sees the JN_NEW wrapper and constructs
			node = JsNode(ji, JN_NEW);
			node->a = JsParsePrimary(ji);
			return node;
		}
		if (JsEatKw(ji, "true"))
		{
			node = JsNode(ji, JN_NUM);
			node->num = 1;
			node->str = "bool";
			return node;
		}
		if (JsEatKw(ji, "false"))
		{
			node = JsNode(ji, JN_NUM);
			node->str = "bool";
			return node;
		}
		if (JsEatKw(ji, "null"))
			return JsNode(ji, JN_NULLLIT);
		if (JsEatKw(ji, "undefined"))
			return JsNode(ji, JN_UNDEFLIT);
		ji->pos++;
		node = JsNode(ji, JN_IDENT);
		node->str = t->str;
		return node;
	}
	if (JsIsKw(ji, "super"))
	{ // super(...) constructor call -> no-op; super.x / super.m() -> this.x/m()
		ji->pos++;
		if (JsEatPunct(ji, '('))
		{
			JsParseArgs(ji); // parse + discard args, eats ')'
			return JsNode(ji, JN_UNDEFLIT);
		}
		node = JsNode(ji, JN_IDENT);
		node->str = "this";
		return node;
	}
	if (JsIsKw(ji, "this"))
	{ // ensure `this` is a primary even though it's not otherwise a keyword
		ji->pos++;
		node = JsNode(ji, JN_IDENT);
		node->str = "this";
		return node;
	}
	if (JsEatPunct(ji, '('))
	{
		node = JsParseExpr(ji); // ( a, b ) sequence, and (0, fn)() idiom
		if (!JsEatPunct(ji, ')'))
		{ // desync RECOVERY: balanced-skip to this group's ) instead of a hard
		  // abort, and log the window so the offending construct is identifiable.
			StrPrint(embuf, "paren@%d:", ji->pos);
			for (emk = ji->pos - 4; emk <= ji->pos + 2 && StrLen(embuf) < 84; emk++)
			{
				if (emk >= 0)
				{
					JsTokDesc(ji, emk, emtk);
					CatPrint(embuf, " %s", emtk);
				}
			}
			for (emk = 0; embuf[emk]; emk++)
				if (embuf[emk] == 0x24)
					embuf[emk] = '?';
			if (++js_soft_errs <= 12)
				NetLog("JS: %s", embuf);
			emk = 1;
			while (emk > 0 && JsTok(ji)->type != JT_EOF)
			{
				if (JsIsPunct(ji, '(') || JsIsPunct(ji, '[') || JsIsPunct(ji, '{'))
					emk++;
				else if (JsIsPunct(ji, ')') || JsIsPunct(ji, ']') ||
						 JsIsPunct(ji, '}'))
					emk--;
				ji->pos++;
			}
		}
		return node;
	}
	if (JsEatPunct(ji, '['))
	{
		node = JsNode(ji, JN_ARRLIT);
		tail = NULL;
		if (!JsEatPunct(ji, ']'))
		{
			do
			{
				if (JsEatPunct(ji, JP_SPREAD))
				{ // [...a, b]: spread element, flattened at eval
					item = JsNode(ji, JN_SPREAD);
					item->a = JsParseAssign(ji);
				}
				else
					item = JsParseAssign(ji);
				if (!item)
					return node;
				if (tail)
					tail->next = item;
				else
					node->a = item;
				tail = item;
			}
			while (JsEatPunct(ji, ','));
			if (!JsEatPunct(ji, ']'))
			{ // desync RECOVERY: balanced-skip to this array's close so the whole
			  // script survives (a hard parse error would kill the entire bundle).
				emk = 1;
				while (emk > 0 && JsTok(ji)->type != JT_EOF)
				{
					if (JsIsPunct(ji, '{') || JsIsPunct(ji, '[') || JsIsPunct(ji, '('))
						emk++;
					else if (JsIsPunct(ji, '}') || JsIsPunct(ji, ']') ||
							 JsIsPunct(ji, ')'))
						emk--;
					ji->pos++;
				}
			}
		}
		return node;
	}
	if (JsEatPunct(ji, '{'))
	{
		node = JsNode(ji, JN_OBJLIT);
		tail = NULL;
		if (!JsEatPunct(ji, '}'))
		{
			do
			{
				if (JsIsPunct(ji, '}'))
					break; // tolerate a trailing comma: {a: 1,}
				// skip method modifiers get/set/async + generator '*' (only when a
				// key follows - else get/set/async is itself the property name)
				while (JsTok(ji)->type == JT_IDENT &&
					   (!StrCompare(JsTok(ji)->str, "get") ||
						!StrCompare(JsTok(ji)->str, "set") ||
						!StrCompare(JsTok(ji)->str, "async")) &&
					   (ji->toks[ji->pos + 1].type == JT_IDENT ||
						ji->toks[ji->pos + 1].type == JT_STR ||
						(ji->toks[ji->pos + 1].type == JT_PUNCT &&
						 (ji->toks[ji->pos + 1].punct == '[' ||
						  ji->toks[ji->pos + 1].punct == '*'))))
					ji->pos++;
				JsEatPunct(ji, '*'); // generator method shorthand
				if (JsEatPunct(ji, JP_SPREAD))
				{ // {...src}: props shallow-merged at eval
					item = JsNode(ji, JN_SPREAD);
					item->a = JsParseAssign(ji);
				}
				else if (JsEatPunct(ji, '['))
				{ // computed key {[expr]: val}; key resolved at eval (str = NULL)
					item = JsNode(ji, JN_PROP);
					item->b = JsParseAssign(ji);
					if (!JsEatPunct(ji, ']'))
						JsErr(ji, "expected ] in computed key");
					if (JsEatPunct(ji, ':'))
						item->a = JsParseAssign(ji);
					else if (JsIsPunct(ji, '('))
						item->a = JsParseFunc(ji, FALSE);
					else
						JsErr(ji, "expected : after computed key");
				}
				else
				{
					t = JsTok(ji);
					if (t->type == JT_NUM)
					{ // numeric key: stringify
						ji->pos++;
						item = JsNode(ji, JN_PROP);
						StrPrint(numkey, "%d", ToI64(t->num));
						item->str = JsStrDup(ji, numkey);
					}
					else if (t->type == JT_IDENT || t->type == JT_STR)
					{
						ji->pos++;
						item = JsNode(ji, JN_PROP);
						item->str = t->str;
					}
					else
					{
						JsErr(ji, "bad object key");
						return node;
					}
					if (JsEatPunct(ji, ':'))
						item->a = JsParseAssign(ji);
					else if (JsIsPunct(ji, '('))
						item->a = JsParseFunc(ji, FALSE); // method shorthand f(){}
					else
					{ // shorthand {x}
						item->a = JsNode(ji, JN_IDENT);
						item->a->str = item->str;
					}
				}
				if (tail)
					tail->next = item;
				else
					node->a = item;
				tail = item;
			}
			while (JsEatPunct(ji, ','));
			if (!JsEatPunct(ji, '}'))
			{ // desync RECOVERY: balanced-skip to this object's close so the whole
			  // script survives (a hard parse error would kill the entire bundle).
				emk = 1;
				while (emk > 0 && JsTok(ji)->type != JT_EOF)
				{
					if (JsIsPunct(ji, '{') || JsIsPunct(ji, '[') || JsIsPunct(ji, '('))
						emk++;
					else if (JsIsPunct(ji, '}') || JsIsPunct(ji, ']') ||
							 JsIsPunct(ji, ')'))
						emk--;
					ji->pos++;
				}
			}
		}
		return node;
	}

	// SOFT error: skip the token and keep parsing. One unrecognized construct
	// must not kill a 400KB bundle - the damage stays local to this expression
	// (callers treat the NULL as an empty node; JsRun's anti-stall advances).
	// Log a WINDOW of surrounding tokens so the exact construct is identifiable.
	StrPrint(embuf, "skip@%d:", ji->pos);
	emk = ji->pos - 4;
	if (emk < 0)
		emk = 0;
	while (emk <= ji->pos + 3 && StrLen(embuf) < 84)
	{
		JsTokDesc(ji, emk, emtk);
		if (emk == ji->pos)
			CatPrint(embuf, " >%s<", emtk);
		else
			CatPrint(embuf, " %s", emtk);
		emk++;
	}
	for (emk = 0; embuf[emk]; emk++)
		if (embuf[emk] == 0x24)
			embuf[emk] = '?'; // dollars are live DolDoc commands in the log
	if (++js_soft_errs <= 12)
		NetLog("JS: %s", embuf);
	ji->pos++;

	return NULL;
}

CJsNode *JsParsePostfix(CJsInterp *ji)
{
	CJsNode *node = JsParsePrimary(ji), *wrap;
	CJsTok	*t;
	Bool	 going = TRUE;
	I64		 dep;

	while (node && going && !ji->has_err)
	{
		if (JsEatPunct(ji, JP_OPTCHAIN))
		{ // a?.b: approximated as a.b (member-get on undef already yields undef,
		  // so there is no crash to guard). ?.( and ?.[ fall through to the
		  // call/index branches on the next loop pass.
			t = JsTok(ji);
			if (t->type == JT_IDENT)
			{
				ji->pos++;
				wrap = JsNode(ji, JN_MEMBER);
				wrap->a	  = node;
				wrap->str = t->str;
				node = wrap;
			}
		}
		else if (JsEatPunct(ji, '.'))
		{
			t = JsTok(ji);
			if (t->type != JT_IDENT)
			{
				JsErr(ji, "expected name after .");
				return node;
			}
			ji->pos++;
			wrap = JsNode(ji, JN_MEMBER);
			wrap->a	  = node;
			wrap->str = t->str;
			node = wrap;
		}
		else if (JsEatPunct(ji, '['))
		{
			wrap = JsNode(ji, JN_INDEX);
			wrap->a = node;
			wrap->b = JsParseExpr(ji); // full expr: obj[a, b] comma is legal
			if (!JsEatPunct(ji, ']'))
			{ // desync RECOVERY: balanced-skip to the closing ] so the whole
			  // script survives (a hard parse error would kill the bundle).
				dep = 1;
				while (dep > 0 && JsTok(ji)->type != JT_EOF)
				{
					if (JsIsPunct(ji, '{') || JsIsPunct(ji, '[') || JsIsPunct(ji, '('))
						dep++;
					else if (JsIsPunct(ji, '}') || JsIsPunct(ji, ']') ||
							 JsIsPunct(ji, ')'))
						dep--;
					ji->pos++;
				}
			}
			node = wrap;
		}
		else if (JsEatPunct(ji, '('))
		{
			wrap = JsNode(ji, JN_CALL);
			wrap->a = node;
			wrap->b = JsParseArgs(ji);
			node = wrap;
		}
		else if (JsIsPunct(ji, JP_INC) || JsIsPunct(ji, JP_DEC))
		{
			wrap = JsNode(ji, JN_POSTINC);
			if (JsTok(ji)->punct == JP_INC)
				wrap->op = 1;
			else
				wrap->op = -1;
			ji->pos++;
			wrap->a = node;
			node = wrap;
		}
		else
			going = FALSE;
	}

	return node;
}

CJsNode *JsParseUnary(CJsInterp *ji)
{ // ji->depth doubles as expression-nesting guard while parsing:
  // the 256KB task stack does not survive pathological nesting
	CJsNode *node;

	if (ji->depth > 80)
	{
		JsErr(ji, "expression too deep");
		ji->pos++;
		return NULL;
	}
	if (JsIsKw(ji, "async"))
	{ // async fn/arrow: transparent - our fetch/XHR run synchronously underneath,
	  // so the sync body semantics are already what the page gets.
		CJsTok *t2 = &ji->toks[ji->pos + 1];

		if (t2->type == JT_IDENT ||
			(t2->type == JT_PUNCT && t2->punct == '('))
			ji->pos++;
	}
	if (JsEatKw(ji, "await"))
	{ // await expr: evaluate + unwrap the (synchronously settled) promise
		node = JsNode(ji, JN_AWAIT);
		node->a = JsParseUnary(ji);
		return node;
	}
	if (JsEatPunct(ji, '!'))
	{
		node = JsNode(ji, JN_UN);
		node->op = '!';
		node->a = JsParseUnary(ji);
		return node;
	}
	if (JsEatPunct(ji, '~'))
	{
		node = JsNode(ji, JN_UN);
		node->op = '~';
		node->a = JsParseUnary(ji);
		return node;
	}
	if (JsEatPunct(ji, '-'))
	{
		node = JsNode(ji, JN_UN);
		node->op = '-';
		node->a = JsParseUnary(ji);
		return node;
	}
	if (JsEatPunct(ji, '+'))
	{ // unary plus -> numeric coercion
		node = JsNode(ji, JN_UN);
		node->op = 'p';
		node->a = JsParseUnary(ji);
		return node;
	}
	if (JsEatKw(ji, "void"))
	{
		node = JsNode(ji, JN_UN);
		node->op = 'v';
		node->a = JsParseUnary(ji);
		return node;
	}
	if (JsEatKw(ji, "delete"))
	{
		node = JsNode(ji, JN_UN);
		node->op = 'd';
		node->a = JsParseUnary(ji);
		return node;
	}
	if (JsEatKw(ji, "typeof"))
	{
		node = JsNode(ji, JN_UN);
		node->op = 't';
		node->a = JsParseUnary(ji);
		return node;
	}
	if (JsIsPunct(ji, JP_INC) || JsIsPunct(ji, JP_DEC))
	{
		node = JsNode(ji, JN_PREINC);
		if (JsTok(ji)->punct == JP_INC)
			node->op = 1;
		else
			node->op = -1;
		ji->pos++;
		node->a = JsParsePostfix(ji);
		return node;
	}

	return JsParsePostfix(ji);
}

CJsNode *JsParseBinLevel(CJsInterp *ji, I64 level)
{ // JS precedence, high to low: 0: **   1: * / %   2: + -   3: << >> >>>   4: rel
  // (< > <= >= in instanceof)   5: eq   6: &   7: ^   8: |   9: &&   10: ||   11: ??
	CJsNode *node, *wrap;
	I64		 op;
	Bool	 going = TRUE;

	if (level == 0)
		node = JsParseUnary(ji);
	else
		node = JsParseBinLevel(ji, level - 1);

	while (node && going && !ji->has_err)
	{
		op = -1;
		if (level == 4 && JsTok(ji)->type == JT_IDENT)
		{ // relational level also has the `in` and `instanceof` keyword operators
			if (!StrCompare(JsTok(ji)->str, "instanceof"))
				op = JP_INSTOF;
			else if (!StrCompare(JsTok(ji)->str, "in"))
				op = JP_IN;
		}
		if (op < 0 && JsTok(ji)->type == JT_PUNCT)
		{
			op = JsTok(ji)->punct;
			switch (level)
			{
				case 0:
					if (op != JP_POW)
						op = -1;
					break;
				case 1:
					if (op != '*' && op != '/' && op != '%')
						op = -1;
					break;
				case 2:
					if (op != '+' && op != '-')
						op = -1;
					break;
				case 3:
					if (op != JP_SHL && op != JP_SHR && op != JP_SHR3)
						op = -1;
					break;
				case 4:
					if (op != '<' && op != '>' && op != JP_LE && op != JP_GE)
						op = -1;
					break;
				case 5:
					if (op != JP_EQ2 && op != JP_NE && op != JP_EQ3 && op != JP_NE3)
						op = -1;
					break;
				case 6:
					if (op != '&')
						op = -1;
					break;
				case 7:
					if (op != '^')
						op = -1;
					break;
				case 8:
					if (op != '|')
						op = -1;
					break;
				case 9:
					if (op != JP_AND)
						op = -1;
					break;
				case 10:
					if (op != JP_OR)
						op = -1;
					break;
				case 11:
					if (op != JP_NULLISH)
						op = -1;
					break;
			}
		}
		if (op < 0)
			going = FALSE;
		else
		{
			ji->pos++;
			wrap = JsNode(ji, JN_BIN);
			wrap->op = op;
			wrap->a = node;
			if (level == 0)
				wrap->b = JsParseUnary(ji);
			else
				wrap->b = JsParseBinLevel(ji, level - 1);
			node = wrap;
		}
	}

	return node;
}

CJsNode *JsParseCond(CJsInterp *ji)
{
	CJsNode *node = JsParseBinLevel(ji, 11), *wrap; // top = ?? (11 levels incl **)

	if (node && JsEatPunct(ji, '?'))
	{
		wrap = JsNode(ji, JN_COND);
		wrap->a = node;
		wrap->b = JsParseAssign(ji);
		if (!JsEatPunct(ji, ':'))
			JsErr(ji, "expected : in ?:");
		wrap->c = JsParseAssign(ji);
		node = wrap;
	}

	return node;
}

CJsNode *JsParseAssign(CJsInterp *ji)
{
	CJsNode *node, *wrap, *fn, *param, *ptail, *ret, *blk;
	I64		 op = -1, k, j;
	Bool	 arrow = FALSE, plist = FALSE;

	if (JsIsKw(ji, "yield"))
	{ // generators run eagerly (no suspension): yield x just produces x
		ji->pos++;
		JsEatPunct(ji, '*'); // yield* delegate
		node = JsNode(ji, JN_UN);
		node->op = 'y';
		if (!JsIsPunct(ji, ';') && !JsIsPunct(ji, ')') && !JsIsPunct(ji, '}') &&
			!JsIsPunct(ji, ',') && !JsIsPunct(ji, ']') && JsTok(ji)->type != JT_EOF)
			node->a = JsParseAssign(ji);
		return node;
	}

	// async arrow: skip a leading `async` before an arrow shape so the detector
	// below sees `(..) =>` / `x =>` directly (async is transparent - our fetch is
	// synchronous, so the sync-body semantics are already correct).
	if (JsIsKw(ji, "async") && ji->pos + 2 < ji->tok_count &&
		(ji->toks[ji->pos + 1].punct == '(' ||
		 (ji->toks[ji->pos + 1].type == JT_IDENT &&
		  ji->toks[ji->pos + 2].type == JT_PUNCT &&
		  ji->toks[ji->pos + 2].punct == JP_ARROW)))
		ji->pos++;

	// arrow functions: name => body  |  ( a, b ) => body
	k = ji->pos;
	if (k + 1 < ji->tok_count &&
		ji->toks[k].type == JT_IDENT && ji->toks[k + 1].type == JT_PUNCT &&
		ji->toks[k + 1].punct == JP_ARROW)
		arrow = TRUE;
	else if (ji->toks[k].type == JT_PUNCT && ji->toks[k].punct == '(')
	{ // commit only when the shape between parens is exactly idents + commas
		j = k + 1;
		while (j + 1 < ji->tok_count && ji->toks[j].type == JT_IDENT &&
			   ji->toks[j + 1].type == JT_PUNCT && ji->toks[j + 1].punct == ',')
			j += 2;
		if (j + 1 < ji->tok_count && ji->toks[j].type == JT_IDENT &&
			ji->toks[j + 1].type == JT_PUNCT && ji->toks[j + 1].punct == ')')
			j += 2;
		else if (ji->toks[j].type == JT_PUNCT && ji->toks[j].punct == ')')
			j++;
		else
			j = 0;
		if (j > 0 && j < ji->tok_count && ji->toks[j].type == JT_PUNCT &&
			ji->toks[j].punct == JP_ARROW)
		{
			arrow = TRUE;
			plist = TRUE;
		}
	}
	if (arrow)
	{
		fn = JsNode(ji, JN_FUNC);
		ptail = NULL;
		if (plist)
		{
			ji->pos = k + 1;
			while (JsTok(ji)->type == JT_IDENT)
			{
				param = JsNode(ji, JN_IDENT);
				param->str = JsTok(ji)->str;
				ji->pos++;
				if (ptail)
					ptail->next = param;
				else
					fn->a = param;
				ptail = param;
				if (!JsEatPunct(ji, ','))
					break;
			}
			JsEatPunct(ji, ')');
		}
		else
		{
			param = JsNode(ji, JN_IDENT);
			param->str = ji->toks[k].str;
			fn->a = param;
			ji->pos = k + 1;
		}
		JsEatPunct(ji, JP_ARROW);
		if (JsIsPunct(ji, '{'))
			fn->b = JsParseStmt(ji); // consumes the block
		else
		{ // expression body: implicit return
			ret = JsNode(ji, JN_RETURN);
			ji->depth++;
			ret->a = JsParseAssign(ji);
			ji->depth--;
			blk = JsNode(ji, JN_BLOCK);
			blk->a = ret;
			fn->b = blk;
		}
		return fn;
	}

	ji->depth++;
	node = JsParseCond(ji);
	ji->depth--;
	if (!node)
		return NULL;
	op = JsTok(ji)->punct;
	if (JsTok(ji)->type != JT_PUNCT ||
		(op != '=' && op != JP_ADDEQ && op != JP_SUBEQ && op != JP_MULEQ &&
		 op != JP_DIVEQ && op != JP_MODEQ && op != JP_POWEQ && op != JP_BANDEQ &&
		 op != JP_BOREQ && op != JP_BXOREQ && op != JP_SHLEQ && op != JP_SHREQ &&
		 op != JP_ANDEQ && op != JP_OREQ && op != JP_NULEQ))
		op = -1;

	if (op >= 0)
	{
		if (node->type != JN_IDENT && node->type != JN_MEMBER &&
			node->type != JN_INDEX && node->type != JN_ARRLIT &&
			node->type != JN_OBJLIT)
		{ // unbindable target: accept but drop (parse-completeness over erroring)
			ji->pos++;
			JsParseAssign(ji);
			return node;
		}
		ji->pos++;
		wrap = JsNode(ji, JN_ASSIGN);
		wrap->op = op;
		wrap->a = node;
		wrap->b = JsParseAssign(ji);
		node = wrap;
	}

	return node;
}

CJsNode *JsParseBlock(CJsInterp *ji)
{ // '{' already eaten
	CJsNode *node = JsNode(ji, JN_BLOCK), *stmt, *tail = NULL;
	I64		 before;

	while (!JsIsPunct(ji, '}') && JsTok(ji)->type != JT_EOF && !ji->has_err)
	{
		before = ji->pos;
		stmt = JsParseStmt(ji);
		if (stmt)
		{
			if (tail)
				tail->next = stmt;
			else
				node->a = stmt;
			tail = stmt;
		}
		if (ji->pos == before)
			ji->pos++; // never stall
	}
	JsEatPunct(ji, '}');

	return node;
}

CJsNode *JsParseFunc(CJsInterp *ji, Bool need_name)
{ // "function" already eaten (or a method: name+params follow directly)
	CJsNode *node = JsNode(ji, JN_FUNC), *param, *tail = NULL;
	CJsTok	*t;
	I64		 dep;
	Bool	 is_rest;

	JsEatPunct(ji, '*'); // generator function*: parsed as a normal function
	t = JsTok(ji);
	if (t->type == JT_IDENT)
	{
		node->str = t->str;
		ji->pos++;
	}
	else if (need_name)
	{
		JsErr(ji, "function needs a name");
		return NULL;
	}

	if (!JsEatPunct(ji, '('))
	{
		JsErr(ji, "expected ( after function");
		return node;
	}
	if (!JsEatPunct(ji, ')'))
	{
		do
		{
			if (JsIsPunct(ji, ')'))
				break; // trailing comma
			is_rest = JsEatPunct(ji, JP_SPREAD); // function f(a, ...rest)
			if (JsIsPunct(ji, '{') || JsIsPunct(ji, '['))
			{ // destructured param {a,b} / [x,y]: skip the pattern (its names bind
			  // undefined - parse-completeness over full destructuring binding).
				dep = 0;
				do
				{
					if (JsIsPunct(ji, '{') || JsIsPunct(ji, '['))
						dep++;
					else if (JsIsPunct(ji, '}') || JsIsPunct(ji, ']'))
						dep--;
					ji->pos++;
				}
				while (dep > 0 && JsTok(ji)->type != JT_EOF);
				if (JsEatPunct(ji, '='))
					JsParseAssign(ji); // pattern default, discarded
			}
			else
			{
				t = JsTok(ji);
				if (t->type != JT_IDENT)
				{
					JsErr(ji, "bad parameter");
					return node;
				}
				ji->pos++;
				param = JsNode(ji, JN_IDENT);
				param->str = t->str;
				if (is_rest)
					param->op = 1; // rest marker; JsCall collects the tail args
				else if (JsEatPunct(ji, '='))
					param->a = JsParseAssign(ji); // default value (op stays 0)
				if (tail)
					tail->next = param;
				else
					node->a = param;
				tail = param;
			}
		}
		while (JsEatPunct(ji, ','));
		if (!JsEatPunct(ji, ')'))
			JsErr(ji, "expected ) after params");
	}
	if (!JsEatPunct(ji, '{'))
	{
		JsErr(ji, "expected { in function");
		return node;
	}
	node->b = JsParseBlock(ji);

	return node;
}

CJsNode *JsParseExpr(CJsInterp *ji)
{ // full expression = comma-sequence of assignments. Used in EXPRESSION
  // positions only (statement, paren, return, if/while test, for init/update) -
  // NOT call args / array literals / var declarators, where comma separates.
	CJsNode *node = JsParseAssign(ji), *seq, *tail;

	if (!JsIsPunct(ji, ','))
		return node;
	seq = JsNode(ji, JN_SEQ);
	seq->a = node;
	tail = node;
	while (JsEatPunct(ji, ','))
	{
		node = JsParseAssign(ji);
		if (!node)
			break;
		tail->next = node;
		tail = node;
	}

	return seq;
}

U0 JsSkipPattern(CJsInterp *ji)
{ // skip a balanced {..} or [..] destructuring pattern we don't bind. Assumes
  // the current token is the opening brace/bracket.
	I64 dep = 0;

	do
	{
		if (JsIsPunct(ji, '{') || JsIsPunct(ji, '['))
			dep++;
		else if (JsIsPunct(ji, '}') || JsIsPunct(ji, ']'))
			dep--;
		ji->pos++;
	}
	while (dep > 0 && JsTok(ji)->type != JT_EOF && !ji->has_err);
}

CJsNode *JsParseVar(CJsInterp *ji)
{ // var/let/const already eaten
	CJsNode *node = JsNode(ji, JN_VAR), *decl, *tail = NULL, *item, *ptail;
	CJsTok	*t;

	do
	{
		t = JsTok(ji);
		if (t->type == JT_PUNCT && (t->punct == '{' || t->punct == '['))
		{ // destructuring: const {a, b: c} = e; / const [x, y] = e;
		  // simple patterns only - no defaults, no nesting, no rest.
			decl = JsNode(ji, JN_DESTRUCT);
			if (t->punct == '[')
				decl->op = 1;
			ji->pos++;
			ptail = NULL;
			do
			{ // tolerant: bind the simple elements, skip what we can't, never
			  // error (a parse error would kill the whole script).
			  // item->op: 0 normal, 2 rest (...x), 3 hole/skip (bind nothing)
				if (JsIsPunct(ji, '}') || JsIsPunct(ji, ']'))
					break;
				item = JsNode(ji, JN_IDENT);
				if (JsIsPunct(ji, ','))
					item->op = 3; // array hole [, x]
				else if (JsEatPunct(ji, JP_SPREAD))
				{ // ...rest
					item->op = 2;
					t = JsTok(ji);
					if (t->type == JT_IDENT)
					{
						item->str = t->str;
						ji->pos++;
					}
					else
						item->op = 3;
				}
				else if (JsIsPunct(ji, '{') || JsIsPunct(ji, '['))
				{ // nested pattern in an array slot: skip, bind nothing
					JsSkipPattern(ji);
					item->op = 3;
					if (JsEatPunct(ji, '='))
						JsParseAssign(ji); // discard default
				}
				else
				{
					t = JsTok(ji);
					if (t->type != JT_IDENT && t->type != JT_STR && t->type != JT_NUM)
					{ // unknown element: skip one token, bind nothing
						ji->pos++;
						item->op = 3;
					}
					else
					{
						ji->pos++;
						if (t->type == JT_NUM)
							item->op = 3; // numeric key: skip binding (rare)
						else
							item->str = t->str;
						if (decl->op == 0 && JsEatPunct(ji, ':'))
						{ // {key: target} - target is an ident or a nested pattern
							if (JsIsPunct(ji, '{') || JsIsPunct(ji, '['))
							{
								JsSkipPattern(ji);
								item->op = 3;
							}
							else
							{
								t = JsTok(ji);
								if (t->type == JT_IDENT)
								{
									item->a = JsNode(ji, JN_IDENT);
									item->a->str = t->str;
									ji->pos++;
								}
							}
						}
						if (JsEatPunct(ji, '='))
							item->c = JsParseAssign(ji); // default value
					}
				}
				if (ptail)
					ptail->next = item;
				else
					decl->b = item;
				ptail = item;
			}
			while (JsEatPunct(ji, ','));
			if (decl->op == 1)
			{
				if (!JsEatPunct(ji, ']'))
					JsErr(ji, "expected ] in pattern");
			}
			else if (!JsEatPunct(ji, '}'))
				JsErr(ji, "expected } in pattern");
			if (JsEatPunct(ji, '='))
				decl->a = JsParseAssign(ji);
		}
		else
		{
			if (t->type != JT_IDENT)
			{
				JsErr(ji, "bad var name");
				return node;
			}
			ji->pos++;
			decl = JsNode(ji, JN_VARDECL);
			decl->str = t->str;
			if (JsEatPunct(ji, '='))
				decl->a = JsParseAssign(ji);
		}
		if (tail)
			tail->next = decl;
		else
			node->a = decl;
		tail = decl;
	}
	while (JsEatPunct(ji, ','));
	JsEatPunct(ji, ';');

	return node;
}

CJsNode *JsParseStmt(CJsInterp *ji)
{
	CJsNode *node, *item, *mtail, *ctail, *stmt2;
	CJsTok	*t;
	I64		 k;

	if (JsEatPunct(ji, ';'))
		return NULL;
	if (JsEatPunct(ji, '{'))
		return JsParseBlock(ji);
	if (JsIsKw(ji, "async") &&
		ji->toks[ji->pos + 1].type == JT_IDENT &&
		!StrCompare(ji->toks[ji->pos + 1].str, "function"))
		ji->pos++; // async function f(){} -> function f(){} (sync semantics)
	if (JsEatKw(ji, "function"))
		return JsParseFunc(ji, TRUE);
	if (JsEatKw(ji, "var") || JsEatKw(ji, "let") || JsEatKw(ji, "const"))
		return JsParseVar(ji);
	if (JsEatKw(ji, "throw"))
	{
		node = JsNode(ji, JN_THROW);
		node->a = JsParseAssign(ji);
		JsEatPunct(ji, ';');
		return node;
	}
	if (JsEatKw(ji, "try"))
	{
		node = JsNode(ji, JN_TRY);
		node->a = JsParseStmt(ji);
		if (JsEatKw(ji, "catch"))
		{
			if (JsEatPunct(ji, '('))
			{
				t = JsTok(ji);
				if (t->type == JT_IDENT)
				{
					node->str = t->str;
					ji->pos++;
				}
				JsEatPunct(ji, ')');
			}
			node->b = JsParseStmt(ji);
		}
		if (JsEatKw(ji, "finally"))
			node->c = JsParseStmt(ji);
		return node;
	}
	if (JsEatKw(ji, "class"))
		return JsParseClass(ji);
	if (JsEatKw(ji, "if"))
	{
		node = JsNode(ji, JN_IF);
		if (!JsEatPunct(ji, '('))
			JsErr(ji, "expected ( after if");
		node->a = JsParseExpr(ji);
		if (!JsEatPunct(ji, ')'))
			JsErr(ji, "expected ) after if");
		node->b = JsParseStmt(ji);
		if (JsEatKw(ji, "else"))
			node->c = JsParseStmt(ji);
		return node;
	}
	if (JsEatKw(ji, "while"))
	{
		node = JsNode(ji, JN_WHILE);
		if (!JsEatPunct(ji, '('))
			JsErr(ji, "expected ( after while");
		node->a = JsParseExpr(ji);
		if (!JsEatPunct(ji, ')'))
			JsErr(ji, "expected ) after while");
		node->b = JsParseStmt(ji);
		return node;
	}
	if (JsEatKw(ji, "for"))
	{
		node = JsNode(ji, JN_FOR);
		if (!JsEatPunct(ji, '('))
			JsErr(ji, "expected ( after for");
		// for ( [var|let|const] name of|in iterable ) body
		k = ji->pos;
		if (ji->toks[k].type == JT_IDENT &&
			(!StrCompare(ji->toks[k].str, "var") ||
			 !StrCompare(ji->toks[k].str, "let") ||
			 !StrCompare(ji->toks[k].str, "const")))
			k++;
		if (ji->toks[k].type == JT_IDENT && ji->toks[k + 1].type == JT_IDENT &&
			(!StrCompare(ji->toks[k + 1].str, "of") ||
			 !StrCompare(ji->toks[k + 1].str, "in")))
		{
			node->type = JN_FOROF;
			node->str = ji->toks[k].str;
			if (!StrCompare(ji->toks[k + 1].str, "in"))
				node->op = 1;
			ji->pos = k + 2;
			node->a = JsParseAssign(ji);
			if (!JsEatPunct(ji, ')'))
				JsErr(ji, "expected ) after for-of");
			node->d = JsParseStmt(ji);
			return node;
		}
		if (!JsIsPunct(ji, ';'))
		{
			if (JsIsKw(ji, "var") || JsIsKw(ji, "let") || JsIsKw(ji, "const"))
			{
				ji->pos++;
				node->a = JsParseVar(ji); // eats its ';'
			}
			else
			{
				node->a = JsNode(ji, JN_EXPR);
				node->a->a = JsParseExpr(ji);
				JsEatPunct(ji, ';');
			}
		}
		else
			JsEatPunct(ji, ';');
		if (!JsIsPunct(ji, ';'))
			node->b = JsParseExpr(ji);
		JsEatPunct(ji, ';');
		if (!JsIsPunct(ji, ')'))
			node->c = JsParseExpr(ji);
		if (!JsEatPunct(ji, ')'))
			JsErr(ji, "expected ) after for");
		node->d = JsParseStmt(ji);
		return node;
	}
	if (JsEatKw(ji, "return"))
	{
		node = JsNode(ji, JN_RETURN);
		if (!JsIsPunct(ji, ';') && !JsIsPunct(ji, '}') &&
			JsTok(ji)->type != JT_EOF)
			node->a = JsParseExpr(ji); // return a(), b;
		JsEatPunct(ji, ';');
		return node;
	}
	if (JsEatKw(ji, "break"))
	{
		if (JsTok(ji)->type == JT_IDENT)
			ji->pos++; // labeled break: approximated as innermost break
		JsEatPunct(ji, ';');
		return JsNode(ji, JN_BREAK);
	}
	if (JsEatKw(ji, "continue"))
	{
		if (JsTok(ji)->type == JT_IDENT)
			ji->pos++; // labeled continue: approximated as innermost continue
		JsEatPunct(ji, ';');
		return JsNode(ji, JN_CONTINUE);
	}
	if (JsEatKw(ji, "do"))
	{ // do body while (cond);
		node = JsNode(ji, JN_DO);
		node->a = JsParseStmt(ji);
		if (!JsEatKw(ji, "while") || !JsEatPunct(ji, '('))
			JsErr(ji, "expected while ( after do body");
		node->b = JsParseExpr(ji);
		if (!JsEatPunct(ji, ')'))
			JsErr(ji, "expected ) after do-while");
		JsEatPunct(ji, ';');
		return node;
	}
	if (JsEatKw(ji, "switch"))
	{
		node = JsNode(ji, JN_SWITCH);
		if (!JsEatPunct(ji, '('))
			JsErr(ji, "expected ( after switch");
		node->a = JsParseExpr(ji);
		if (!JsEatPunct(ji, ')'))
			JsErr(ji, "expected ) after switch");
		if (!JsEatPunct(ji, '{'))
			JsErr(ji, "expected { after switch");
		mtail = NULL;
		while (!ji->has_err && !JsEatPunct(ji, '}') && JsTok(ji)->type != JT_EOF)
		{
			item = JsNode(ji, JN_CASE);
			if (JsEatKw(ji, "default"))
				item->a = NULL;
			else if (JsEatKw(ji, "case"))
				item->a = JsParseExpr(ji);
			else
			{
				JsErr(ji, "expected case/default in switch");
				return node;
			}
			if (!JsEatPunct(ji, ':'))
				JsErr(ji, "expected : after case");
			ctail = NULL;
			while (!ji->has_err && !JsIsKw(ji, "case") && !JsIsKw(ji, "default") &&
				   !JsIsPunct(ji, '}') && JsTok(ji)->type != JT_EOF)
			{
				stmt2 = JsParseStmt(ji);
				if (stmt2)
				{
					if (ctail)
						ctail->next = stmt2;
					else
						item->b = stmt2;
					ctail = stmt2;
				}
			}
			if (mtail)
				mtail->next = item;
			else
				node->b = item;
			mtail = item;
		}
		return node;
	}

	if (JsTok(ji)->type == JT_IDENT &&
		ji->toks[ji->pos + 1].type == JT_PUNCT &&
		ji->toks[ji->pos + 1].punct == ':')
	{ // labeled statement (e: for(...)): label skipped; the labeled break/
	  // continue approximation targets the innermost loop instead.
		ji->pos += 2;
		return JsParseStmt(ji);
	}

	node = JsNode(ji, JN_EXPR);
	node->a = JsParseExpr(ji); // expression statement: a(), b(), c();
	JsEatPunct(ji, ';');

	return node;
}

/* ---- environment ---- */

CJsVal *JsEnvGet(CJsInterp *ji, U8 *name)
{
	CJsEnv	*env = ji->env;
	CJsProp *p;

	while (env)
	{
		p = env->vars;
		while (p)
		{
			if (!StrCompare(p->name, name))
				return p->val(CJsVal *);
			p = p->next;
		}
		env = env->parent;
	}

	return NULL;
}

U0 JsEnvDeclare(CJsInterp *ji, CJsEnv *env, U8 *name, CJsVal *val)
{
	CJsProp *p = env->vars;

	while (p)
	{
		if (!StrCompare(p->name, name))
		{
			p->val = val(U64);
			return;
		}
		p = p->next;
	}
	p = JsAlloc(ji, sizeof(CJsProp))(CJsProp *);
	p->name = JsStrDup(ji, name);
	p->val	= val(U64);
	p->next = env->vars;
	env->vars = p;
}

U0 JsEnvSet(CJsInterp *ji, U8 *name, CJsVal *val)
{ // assign to existing binding, else create a global
	CJsEnv	*env = ji->env;
	CJsProp *p;

	while (env)
	{
		p = env->vars;
		while (p)
		{
			if (!StrCompare(p->name, name))
			{
				p->val = val(U64);
				return;
			}
			p = p->next;
		}
		env = env->parent;
	}
	JsEnvDeclare(ji, ji->genv, name, val);
}

/* ---- DOM plumbing ---- */

CZNode *JsDocBody(CJsInterp *ji)
{
	CZNode *body = ZDomFindTag(ji->dom_root, "body");

	if (!body)
		body = ji->dom_root;

	return body;
}

U0 JsWriteAppend(CJsInterp *ji, U8 *s)
{
	I64 len = StrLen(s);

	if (ji->write_len + len >= JS_WRITE_BUF)
		return; // drop overflow
	MemCopy(ji->write_buf + ji->write_len, s, len);
	ji->write_len += len;
}

U0 JsFlushWrites(CJsInterp *ji)
{ // parse document.write output into the end of <body>
	if (!ji->write_len)
		return;
	ji->write_buf[ji->write_len] = 0;
	ZHtmlParseInto(JsDocBody(ji), ji->write_buf);
	ji->write_len = 0;
	ji->dom_dirty = TRUE;
}

U8 *JsEscDollars(CJsInterp *ji, U8 *s)
{ // double each dollar byte so text is safe to hand to DolDoc printers
	U8	*out = JsAlloc(ji, StrLen(s) * 2 + 1), *d = out;

	while (*s)
	{
		if (*s == 0x24)
			*d++ = 0x24;
		*d++ = *s++;
	}
	*d = 0;

	return out;
}

U0 JsCamelToKebab(U8 *src, U8 *dst, I64 max)
{ // backgroundColor -> background-color
	I64 n = 0;

	while (*src && n < max - 2)
	{
		if ('A' <= *src <= 'Z')
		{
			dst[n++] = '-';
			dst[n++] = *src + 0x20;
		}
		else
			dst[n++] = *src;
		src++;
	}
	dst[n] = 0;
}

U0 JsTextContentSet(CJsInterp *ji, CZNode *node, U8 *s)
{
	CZNode *text_node;

	ZNodeFreeChildren(node);
	text_node = ZNodeNew(ZH_TEXT, node);
	if (text_node)
		text_node->text = StrNew(s);
	ji->dom_dirty = TRUE;
}

U8 *JsCookieGet(CJsInterp *ji)
{ // document.cookie read -> bare "a=b; c=d" for this page's host. MAlloc'ed.
	CHttpUrl u;

	if (ji->url && HttpUrlParse(ji->url, &u) >= 0)
		return HttpDocCookieGet(&u);
	return StrNew("");
}

U0 JsCookieSet(CJsInterp *ji, U8 *s)
{ // document.cookie = "n=v; ..." -> store in the HTTP jar for this page's host
	CHttpUrl u;

	if (ji->url && HttpUrlParse(ji->url, &u) >= 0)
		HttpDocCookieSet(&u, s);
}

CJsVal *JsMemberGet(CJsInterp *ji, CJsVal *obj, U8 *name)
{
	CJsVal *v;
	CZNode *node, *snode, *scur;
	U8	   *attr;
	U8		buf[1024]; // stack frames stay small: this recurses via JsEval
	I64		len;

	switch (obj->type)
	{
		case JV_UNDEF:
		case JV_NULL:
			JsErr(ji, "member access on null/undefined");
			return JsUndefV(ji);
		case JV_STR:
			if (!StrCompare(name, "length"))
				return JsNumV(ji, StrLen(obj->str));
			if (!StrCompare(name, "charAt"))		return JsNativeV(ji, JSN_STR_CHARAT);
			if (!StrCompare(name, "repeat"))		return JsNativeV(ji, JSN_STR_REPEAT);
			if (!StrCompare(name, "padStart"))	return JsNativeV(ji, JSN_STR_PADSTART);
			if (!StrCompare(name, "padEnd"))		return JsNativeV(ji, JSN_STR_PADEND);
			if (!StrCompare(name, "substr"))		return JsNativeV(ji, JSN_STR_SUBSTR);
			if (!StrCompare(name, "indexOf"))		return JsNativeV(ji, JSN_STR_INDEXOF);
			if (!StrCompare(name, "substring"))		return JsNativeV(ji, JSN_STR_SUBSTRING);
			if (!StrCompare(name, "slice"))			return JsNativeV(ji, JSN_STR_SLICE);
			if (!StrCompare(name, "toUpperCase"))	return JsNativeV(ji, JSN_STR_TOUPPER);
			if (!StrCompare(name, "toLowerCase"))	return JsNativeV(ji, JSN_STR_TOLOWER);
			if (!StrCompare(name, "split"))			return JsNativeV(ji, JSN_STR_SPLIT);
			if (!StrCompare(name, "replace"))		return JsNativeV(ji, JSN_STR_REPLACE);
			if (!StrCompare(name, "trim"))			return JsNativeV(ji, JSN_STR_TRIM);
			if (!StrCompare(name, "includes"))		return JsNativeV(ji, JSN_STR_INCLUDES);
			if (!StrCompare(name, "startsWith"))	return JsNativeV(ji, JSN_STR_STARTS);
			if (!StrCompare(name, "endsWith"))		return JsNativeV(ji, JSN_STR_ENDS);
			if (!StrCompare(name, "charCodeAt"))	return JsNativeV(ji, JSN_STR_CHARCODE);
			return JsUndefV(ji);
		case JV_ARR:
			if (!StrCompare(name, "length"))
				return JsNumV(ji, obj->count);
			if (!StrCompare(name, "push"))		return JsNativeV(ji, JSN_ARR_PUSH);
			if (!StrCompare(name, "join"))		return JsNativeV(ji, JSN_ARR_JOIN);
			if (!StrCompare(name, "reduce"))	return JsNativeV(ji, JSN_ARR_REDUCE);
			if (!StrCompare(name, "reverse"))	return JsNativeV(ji, JSN_ARR_REVERSE);
			if (!StrCompare(name, "sort"))		return JsNativeV(ji, JSN_ARR_SORT);
			if (!StrCompare(name, "indexOf"))	return JsNativeV(ji, JSN_ARR_INDEXOF);
			if (!StrCompare(name, "map"))		return JsNativeV(ji, JSN_ARR_MAP);
			if (!StrCompare(name, "filter"))	return JsNativeV(ji, JSN_ARR_FILTER);
			if (!StrCompare(name, "forEach"))	return JsNativeV(ji, JSN_ARR_FOREACH);
			if (!StrCompare(name, "find"))		return JsNativeV(ji, JSN_ARR_FIND);
			if (!StrCompare(name, "slice"))		return JsNativeV(ji, JSN_ARR_SLICE);
			if (!StrCompare(name, "concat"))	return JsNativeV(ji, JSN_ARR_CONCAT);
			if (!StrCompare(name, "includes"))	return JsNativeV(ji, JSN_ARR_INCLUDES);
			if (!StrCompare(name, "pop"))		return JsNativeV(ji, JSN_ARR_POP);
			if (!StrCompare(name, "shift"))		return JsNativeV(ji, JSN_ARR_SHIFT);
			return JsUndefV(ji);
		case JV_NATIVE:
			if (obj->native_id == JSN_DATE_CTOR && !StrCompare(name, "now"))
				return JsNativeV(ji, JSN_DATE_NOW);
			if (obj->native_id == JSN_SYMBOL &&
				(!StrCompare(name, "iterator") || !StrCompare(name, "asyncIterator")))
				return JsStrV(ji, "@@iterator");
			if (obj->native_id == JSN_PROMISE_CTOR && !StrCompare(name, "resolve"))
				return JsNativeV(ji, JSN_PROMISE_SRESOLVE);
			v = JsPropGet(obj, name); // bound-fn slots (_t/_this) live here
			if (v)
				return v;
			if (!StrCompare(name, "call"))	return JsNativeV(ji, JSN_FN_CALL);
			if (!StrCompare(name, "apply"))	return JsNativeV(ji, JSN_FN_APPLY);
			if (!StrCompare(name, "bind"))	return JsNativeV(ji, JSN_FN_BIND);
			return JsUndefV(ji);
		case JV_FUNC:
			if (!StrCompare(name, "call"))	return JsNativeV(ji, JSN_FN_CALL);
			if (!StrCompare(name, "apply"))	return JsNativeV(ji, JSN_FN_APPLY);
			if (!StrCompare(name, "bind"))	return JsNativeV(ji, JSN_FN_BIND);
			if (!StrCompare(name, "length"))	return JsNumV(ji, 0);
			v = JsPropGet(obj, name); // fn.prototype and assigned static props
			if (v)
				return v;
			return JsUndefV(ji);
		case JV_OBJ:
			break;
		default:
			return JsUndefV(ji);
	}

	switch (obj->native_id)
	{
		case JSO_DOCUMENT:
			if (!StrCompare(name, "title"))
			{
				node = ZDomFindTag(ji->dom_root, "title");
				if (node && node->text)
					return JsStrV(ji, node->text);
				return JsStrV(ji, "");
			}
			if (!StrCompare(name, "body"))
				return JsElemV(ji, JsDocBody(ji));
			if (!StrCompare(name, "location"))
				return ji->loc_obj;
			if (!StrCompare(name, "URL"))
				return JsStrV(ji, ji->url);
			if (!StrCompare(name, "cookie"))
			{ // wired to the HTTP cookie jar so JS-set cookies ride later requests
				attr = JsCookieGet(ji);
				v	 = JsStrV(ji, attr);
				Free(attr);
				return v;
			}
			if (!StrCompare(name, "write") || !StrCompare(name, "writeln"))
				return JsNativeV(ji, JSN_DOC_WRITE);
			if (!StrCompare(name, "getElementById"))
				return JsNativeV(ji, JSN_DOC_GETBYID);
			if (!StrCompare(name, "getElementsByTagName"))
				return JsNativeV(ji, JSN_DOC_GETBYTAG);
			if (!StrCompare(name, "getElementsByClassName"))
				return JsNativeV(ji, JSN_DOC_GETBYCLASS);
			if (!StrCompare(name, "getElementsByName"))
				return JsNativeV(ji, JSN_DOC_GETBYNAME);
			if (!StrCompare(name, "createElement"))
				return JsNativeV(ji, JSN_DOC_CREATE_EL);
			if (!StrCompare(name, "createTextNode"))
				return JsNativeV(ji, JSN_DOC_CREATE_TX);
			if (!StrCompare(name, "querySelector"))
				return JsNativeV(ji, JSN_QSEL);
			if (!StrCompare(name, "querySelectorAll"))
				return JsNativeV(ji, JSN_QSELALL);
			if (!StrCompare(name, "head"))
			{
				node = ZDomFindTag(ji->dom_root, "head");
				if (node)
					return JsElemV(ji, node);
				return JsNullV(ji);
			}
			if (!StrCompare(name, "documentElement"))
			{
				node = ZDomFindTag(ji->dom_root, "html");
				if (node)
					return JsElemV(ji, node);
				return JsElemV(ji, ji->dom_root);
			}
			if (!StrCompare(name, "addEventListener"))
				return JsNativeV(ji, JSN_EL_ADDLISTEN); // binds to the DOM root
			if (!StrCompare(name, "removeEventListener"))
				return JsNativeV(ji, JSN_EL_REMLISTEN);
			return JsUndefV(ji);
		case JSO_LOCATION:
			if (!StrCompare(name, "href"))
				return JsStrV(ji, ji->url);
			if (!StrCompare(name, "assign") || !StrCompare(name, "replace"))
				return JsNativeV(ji, JSN_LOC_ASSIGN);
			if (!StrCompare(name, "reload"))
				return JsNativeV(ji, JSN_LOC_RELOAD);
			return JsUndefV(ji);
		case JSO_WINDOW:
			if (!StrCompare(name, "location"))
				return ji->loc_obj;
			if (!StrCompare(name, "document"))
				return ji->doc_obj;
			if (!StrCompare(name, "addEventListener"))
				return JsNativeV(ji, JSN_EL_ADDLISTEN); // binds to the DOM root
			if (!StrCompare(name, "removeEventListener"))
				return JsNativeV(ji, JSN_EL_REMLISTEN);
			v = JsEnvGet(ji, name);
			if (v)
				return v;
			return JsUndefV(ji);
		case JSO_ELEMENT:
			node = obj->node;
			if (!StrCompare(name, "innerHTML") || !StrCompare(name, "textContent") ||
				!StrCompare(name, "innerText"))
			{
				len = 0;
				ZNodeTextCollect(node, buf, 1020, &len);
				return JsStrV(ji, buf);
			}
			if (!StrCompare(name, "value"))
			{
				if (node->value)
					return JsStrV(ji, node->value);
				attr = ZNodeAttr(node, "value");
				if (attr)
					return JsStrV(ji, attr);
				return JsStrV(ji, "");
			}
			if (!StrCompare(name, "checked"))
				return JsBoolV(ji, node->checked);
			if (!StrCompare(name, "id"))
			{
				attr = ZNodeAttr(node, "id");
				if (attr)
					return JsStrV(ji, attr);
				return JsStrV(ji, "");
			}
			if (!StrCompare(name, "className"))
			{
				attr = ZNodeAttr(node, "class");
				if (attr)
					return JsStrV(ji, attr);
				return JsStrV(ji, "");
			}
			if (!StrCompare(name, "tagName"))
			{
				len = 0;
				while (node->tag[len] && len < 15)
				{
					buf[len] = ToUpper(node->tag[len]);
					len++;
				}
				buf[len] = 0;
				return JsStrV(ji, buf);
			}
			if (!StrCompare(name, "style"))
			{
				v = JsValNew(ji, JV_OBJ);
				v->native_id = JSO_STYLE;
				v->node = node;
				return v;
			}
			if (!StrCompare(name, "getAttribute"))
				return JsNativeV(ji, JSN_EL_GETATTR);
			if (!StrCompare(name, "setAttribute"))
				return JsNativeV(ji, JSN_EL_SETATTR);
			if (!StrCompare(name, "addEventListener"))
				return JsNativeV(ji, JSN_EL_ADDLISTEN);
			if (!StrCompare(name, "removeEventListener"))
				return JsNativeV(ji, JSN_EL_REMLISTEN);
			if (!StrCompare(name, "appendChild"))
				return JsNativeV(ji, JSN_EL_APPEND);
			if (!StrCompare(name, "removeChild"))
				return JsNativeV(ji, JSN_EL_REMOVE_CH);
			if (!StrCompare(name, "remove"))
				return JsNativeV(ji, JSN_EL_REMOVE);
			if (!StrCompare(name, "querySelector"))
				return JsNativeV(ji, JSN_QSEL);
			if (!StrCompare(name, "querySelectorAll"))
				return JsNativeV(ji, JSN_QSELALL);
			if (!StrCompare(name, "getElementsByTagName"))
				return JsNativeV(ji, JSN_DOC_GETBYTAG);
			if (!StrCompare(name, "getElementsByClassName"))
				return JsNativeV(ji, JSN_DOC_GETBYCLASS);
			if (!StrCompare(name, "contains"))
				return JsNativeV(ji, JSN_EL_CONTAINS);
			if (!StrCompare(name, "matches"))
				return JsNativeV(ji, JSN_EL_MATCHES);
			if (!StrCompare(name, "closest"))
				return JsNativeV(ji, JSN_EL_CLOSEST);
			if (!StrCompare(name, "hasAttribute"))
				return JsNativeV(ji, JSN_EL_HASATTR);
			if (!StrCompare(name, "removeAttribute"))
				return JsNativeV(ji, JSN_EL_RMATTR);
			if (!StrCompare(name, "cloneNode"))
				return JsNativeV(ji, JSN_EL_CLONE);
			if (!StrCompare(name, "insertBefore"))
				return JsNativeV(ji, JSN_EL_INSBEFORE);
			if (!StrCompare(name, "getBoundingClientRect"))
				return JsNativeV(ji, JSN_EL_RECT);
			if (!StrCompare(name, "classList"))
			{
				v = JsValNew(ji, JV_OBJ);
				v->native_id = JSO_CLASSLIST;
				v->node = node;
				return v;
			}
			if (!StrCompare(name, "parentNode") ||
				!StrCompare(name, "parentElement"))
			{
				if (node->parent)
					return JsElemV(ji, node->parent);
				return JsNullV(ji);
			}
			if (!StrCompare(name, "firstChild"))
			{
				if (node->first_child)
					return JsElemV(ji, node->first_child);
				return JsNullV(ji);
			}
			if (!StrCompare(name, "lastChild"))
			{
				if (node->last_child)
					return JsElemV(ji, node->last_child);
				return JsNullV(ji);
			}
			if (!StrCompare(name, "nextSibling") ||
				!StrCompare(name, "nextElementSibling"))
			{
				snode = node->next;
				if (!StrCompare(name, "nextElementSibling"))
					while (snode && snode->type != ZH_ELEM)
						snode = snode->next;
				if (snode)
					return JsElemV(ji, snode);
				return JsNullV(ji);
			}
			if (!StrCompare(name, "previousSibling") ||
				!StrCompare(name, "previousElementSibling"))
			{ // no back-pointer in CZNode: scan the parent's child list. name !=
			  // "previousElementSibling" means the text-inclusive variant.
				snode = NULL;
				if (node->parent)
				{
					scur = node->parent->first_child;
					while (scur && scur != node)
					{
						if (StrCompare(name, "previousElementSibling") ||
							scur->type == ZH_ELEM)
							snode = scur;
						scur = scur->next;
					}
				}
				if (snode)
					return JsElemV(ji, snode);
				return JsNullV(ji);
			}
			if (!StrCompare(name, "children"))
			{
				v = JsArrV(ji);
				node = node->first_child;
				while (node)
				{
					if (node->type == ZH_ELEM)
						JsArrPush(ji, v, JsElemV(ji, node));
					node = node->next;
				}
				return v;
			}
			attr = ZNodeAttr(node, name);
			if (attr)
				return JsStrV(ji, attr);
			return JsUndefV(ji);
		case JSO_XHR:
			if (!StrCompare(name, "open"))
				return JsNativeV(ji, JSN_XHR_OPEN);
			if (!StrCompare(name, "send"))
				return JsNativeV(ji, JSN_XHR_SEND);
			if (!StrCompare(name, "setRequestHeader"))
				return JsNativeV(ji, JSN_XHR_SETREQHDR);
			if (!StrCompare(name, "getAllResponseHeaders"))
				return JsNativeV(ji, JSN_XHR_GETALLHDR);
			if (!StrCompare(name, "getResponseHeader"))
				return JsNativeV(ji, JSN_XHR_GETHDR);
			v = JsPropGet(obj, name); // readyState/status/responseText/onload/...
			if (v)
				return v;
			return JsUndefV(ji);
		case JSO_PROMISE:
			if (!StrCompare(name, "then"))
				return JsNativeV(ji, JSN_PROMISE_THEN);
			if (!StrCompare(name, "catch"))
				return JsNativeV(ji, JSN_PROMISE_CATCH);
			if (!StrCompare(name, "finally"))
				return JsNativeV(ji, JSN_PROMISE_FINALLY);
			v = JsPropGet(obj, name);
			if (v)
				return v;
			return JsUndefV(ji);
		case JSO_CLASSLIST:
			if (!StrCompare(name, "add"))
				return JsNativeV(ji, JSN_CL_ADD);
			if (!StrCompare(name, "remove"))
				return JsNativeV(ji, JSN_CL_REMOVE);
			if (!StrCompare(name, "toggle"))
				return JsNativeV(ji, JSN_CL_TOGGLE);
			if (!StrCompare(name, "contains"))
				return JsNativeV(ji, JSN_CL_CONTAINS);
			return JsUndefV(ji);
	}

	v = JsPropGet(obj, name);
	if (v)
		return v;

	return JsUndefV(ji);
}

U0 JsMemberSet(CJsInterp *ji, CJsVal *obj, U8 *name, CJsVal *val)
{
	CZNode *node;
	U8	   *s;
	U8		kebab[64], style_buf[512];

	if (obj->type != JV_OBJ)
		return;

	switch (obj->native_id)
	{
		case JSO_DOCUMENT:
			if (!StrCompare(name, "title"))
			{
				node = ZDomFindTag(ji->dom_root, "title");
				if (node)
				{
					Free(node->text);
					node->text = StrNew(JsToStr(ji, val));
					ji->dom_dirty = TRUE;
				}
			}
			else if (!StrCompare(name, "cookie"))
				JsCookieSet(ji, JsToStr(ji, val)); // -> HTTP jar for this host
			return;
		case JSO_LOCATION:
			if (!StrCompare(name, "href"))
				ji->navigate = JsStrDup(ji, JsToStr(ji, val));
			return;
		case JSO_WINDOW:
			if (!StrCompare(name, "location"))
				ji->navigate = JsStrDup(ji, JsToStr(ji, val));
			else
				JsEnvDeclare(ji, ji->genv, name, val);
			return;
		case JSO_ELEMENT:
			node = obj->node;
			if (!StrCompare(name, "innerHTML"))
			{
				ZNodeFreeChildren(node);
				ZHtmlParseInto(node, JsToStr(ji, val));
				ji->dom_dirty = TRUE;
			}
			else if (!StrCompare(name, "textContent") || !StrCompare(name, "innerText"))
			{
				JsTextContentSet(ji, node, JsToStr(ji, val));
				JsStyleIngest(ji, node); // CSS-in-JS: styleEl.textContent = css
			}
			else if (!StrCompare(name, "value"))
			{
				Free(node->value);
				node->value = StrNew(JsToStr(ji, val));
				ji->dom_dirty = TRUE;
			}
			else if (!StrCompare(name, "checked"))
			{
				node->checked = JsToBool(val);
				ji->dom_dirty = TRUE;
			}
			else if (!StrCompare(name, "className"))
			{
				ZNodeAttrSet(node, "class", JsToStr(ji, val));
				ji->dom_dirty = TRUE;
			}
			else if (name[0] == 'o' && name[1] == 'n' && name[2] &&
					 (val->type == JV_FUNC || val->type == JV_NATIVE))
				JsListenerAdd(ji, node, name + 2, val, TRUE); // onclick -> "click"
			else
			{
				ZNodeAttrSet(node, name, JsToStr(ji, val));
				ji->dom_dirty = TRUE;
			}
			return;
		case JSO_STYLE:
			node = obj->node;
			JsCamelToKebab(name, kebab, 64);
			s = ZNodeAttr(node, "style");
			if (s && StrLen(s) + StrLen(JsToStr(ji, val)) < 380)
				StrPrint(style_buf, "%s;%s:%s", s, kebab, JsToStr(ji, val));
			else if (StrLen(JsToStr(ji, val)) < 380)
				StrPrint(style_buf, "%s:%s", kebab, JsToStr(ji, val));
			else
				return;
			ZNodeAttrSet(node, "style", style_buf);
			ji->dom_dirty = TRUE;
			return;
	}

	JsPropSet(ji, obj, name, val);
}

/* ---- equality ---- */

Bool JsStrictEq(CJsVal *a, CJsVal *b)
{
	if (a->type != b->type)
		return FALSE;
	switch (a->type)
	{
		case JV_UNDEF:
		case JV_NULL:
			return TRUE;
		case JV_BOOL:
		case JV_NUM:
			return a->num == b->num;
		case JV_STR:
			return !StrCompare(a->str, b->str);
		case JV_OBJ:
			if (a->node && b->node)
				return a->node == b->node;
	}

	return a == b;
}

Bool JsLooseEq(CJsVal *a, CJsVal *b)
{
	Bool a_nullish = (a->type == JV_UNDEF || a->type == JV_NULL);
	Bool b_nullish = (b->type == JV_UNDEF || b->type == JV_NULL);

	if (a_nullish || b_nullish)
		return a_nullish && b_nullish;
	if (a->type == b->type)
		return JsStrictEq(a, b);

	return JsToNum(a) == JsToNum(b);
}

F64 JsFmod(F64 a, F64 b)
{
	if (b == 0)
		return 0;

	return a - b * Trunc(a / b);
}

/* ---- evaluator ---- */

CJsVal *JsEvalBin(CJsInterp *ji, I64 op, CJsVal *a, CJsVal *b)
{
	U8		*sa, *sb, *cat;
	I64		 cmp, depth;
	F64		 na, nb;
	CJsVal	*pr, *w;

	if (op == '+')
	{
		if (a->type == JV_STR || b->type == JV_STR)
		{
			sa = JsToStr(ji, a);
			sb = JsToStr(ji, b);
			cmp	  = StrLen(sa);
			depth = StrLen(sb);
			// explicit copy into a margin-padded buffer (no CatPrint format pass)
			cat = JsAlloc(ji, cmp + depth + 8);
			MemCopy(cat, sa, cmp);
			MemCopy(cat + cmp, sb, depth + 1); // sb including its NUL
			return JsStrV(ji, cat);
		}
		return JsNumV(ji, JsToNum(a) + JsToNum(b));
	}
	if (op == '-')
		return JsNumV(ji, JsToNum(a) - JsToNum(b));
	if (op == '*')
		return JsNumV(ji, JsToNum(a) * JsToNum(b));
	if (op == '/')
	{
		na = JsToNum(a);
		nb = JsToNum(b);
		if (nb == 0)
			return JsNumV(ji, 0); // no Infinity; close enough
		return JsNumV(ji, na / nb);
	}
	if (op == '%')
		return JsNumV(ji, JsFmod(JsToNum(a), JsToNum(b)));
	if (op == JP_POW)
		return JsNumV(ji, Pow(JsToNum(a), JsToNum(b)));
	if (op == JP_IN)
	{ // key in obj
		if (b && b->type == JV_OBJ)
			return JsBoolV(ji, JsPropGet(b, JsToStr(ji, a)) != NULL);
		return JsBoolV(ji, FALSE);
	}
	if (op == JP_INSTOF)
	{ // a instanceof b : approximate via the prototype chain (+ Array special)
		if (a && a->type == JV_ARR)
			return JsBoolV(ji, FALSE); // Array handled by Array.isArray in practice
		if (a && a->type == JV_OBJ && b && (b->type == JV_FUNC || b->type == JV_NATIVE))
		{
			pr = JsPropGet(b, "prototype");
			w = a->proto;
			depth = 0;
			while (w && depth < 20)
			{
				if (w == pr)
					return JsBoolV(ji, TRUE);
				w = w->proto;
				depth++;
			}
		}
		return JsBoolV(ji, FALSE);
	}
	if (op == '&')
		return JsNumV(ji, ToI64(JsToNum(a)) & ToI64(JsToNum(b)));
	if (op == '|')
		return JsNumV(ji, ToI64(JsToNum(a)) | ToI64(JsToNum(b)));
	if (op == '^')
		return JsNumV(ji, ToI64(JsToNum(a)) ^ ToI64(JsToNum(b)));
	if (op == JP_SHL)
		return JsNumV(ji, ToI64(JsToNum(a)) << (ToI64(JsToNum(b)) & 31));
	if (op == JP_SHR)
		return JsNumV(ji, ToI64(JsToNum(a)) >> (ToI64(JsToNum(b)) & 31));
	if (op == JP_SHR3) // unsigned 32-bit shift
		return JsNumV(ji, (ToI64(JsToNum(a)) & 0xFFFFFFFF) >> (ToI64(JsToNum(b)) & 31));
	if (op == JP_EQ2)
		return JsBoolV(ji, JsLooseEq(a, b));
	if (op == JP_NE)
		return JsBoolV(ji, !JsLooseEq(a, b));
	if (op == JP_EQ3)
		return JsBoolV(ji, JsStrictEq(a, b));
	if (op == JP_NE3)
		return JsBoolV(ji, !JsStrictEq(a, b));

	// relational
	if (a->type == JV_STR && b->type == JV_STR)
	{
		cmp = StrCompare(a->str, b->str);
		na = cmp;
		nb = 0;
	}
	else
	{
		na = JsToNum(a);
		nb = JsToNum(b);
	}
	if (op == '<')
		return JsBoolV(ji, na < nb);
	if (op == '>')
		return JsBoolV(ji, na > nb);
	if (op == JP_LE)
		return JsBoolV(ji, na <= nb);
	if (op == JP_GE)
		return JsBoolV(ji, na >= nb);

	JsErr(ji, "bad operator");

	return JsUndefV(ji);
}

U0 JsAssignTo(CJsInterp *ji, CJsNode *target, CJsVal *val)
{
	CJsVal	*obj, *idx, *sub;
	CJsNode	*el;
	I64		 i;

	if (!target)
		return;
	switch (target->type)
	{
		case JN_IDENT:
			JsEnvSet(ji, target->str, val);
			break;
		case JN_MEMBER:
			obj = JsEval(ji, target->a);
			JsMemberSet(ji, obj, target->str, val);
			break;
		case JN_INDEX:
			obj = JsEval(ji, target->a);
			idx = JsEval(ji, target->b);
			if (obj->type == JV_ARR)
			{
				i = JsToNum(idx);
				if (0 <= i < 4096)
				{
					while (obj->count <= i)
						JsArrPush(ji, obj, JsUndefV(ji));
					obj->items[i] = val;
				}
			}
			else if (obj->type == JV_OBJ)
				JsMemberSet(ji, obj, JsToStr(ji, idx), val);
			break;
		case JN_ARRLIT:
			// array destructuring assignment: [a, b] = val
			el = target->a;
			i = 0;
			while (el)
			{
				if (el->type != JN_SPREAD)
				{
					sub = JsUndefV(ji);
					if (val && val->type == JV_ARR && i < val->count)
						sub = val->items[i];
					JsAssignTo(ji, el, sub);
				}
				el = el->next;
				i++;
			}
			break;
		case JN_OBJLIT:
			// object destructuring assignment: ({a, b: c} = val)
			el = target->a;
			while (el)
			{
				if (el->type == JN_PROP && el->str)
				{
					sub = JsUndefV(ji);
					if (val && val->type == JV_OBJ)
					{
						obj = JsPropGet(val, el->str);
						if (obj)
							sub = obj;
					}
					// {a} -> el->a is IDENT a; {a: c} -> el->a is IDENT c
					if (el->a)
						JsAssignTo(ji, el->a, sub);
				}
				el = el->next;
			}
			break;
	}
}

U8 *JsCtorName(CJsNode *n)
{ // best-effort name of a `new` target, for the diagnostic
	if (n && (n->type == JN_IDENT || n->type == JN_MEMBER) && n->str)
		return n->str;
	return "(expr)";
}

CJsVal *JsConstruct(CJsInterp *ji, CJsVal *fn, CJsVal **args, I64 argc, U8 *name)
{ // new-expression: fresh object, prototype link, constructor call with this
	CJsVal *obj, *pr, *r;
	U8		buf[80];
	I64		i;

	if (!fn || (fn->type != JV_FUNC && fn->type != JV_NATIVE))
	{ // name the missing constructor so the log says what to add next
		StrPrint(buf, "'%s' is not a constructor", name);
		for (i = 0; buf[i]; i++)
			if (buf[i] == 0x24)
				buf[i] = '?';
		JsErr(ji, buf);
		return JsUndefV(ji);
	}
	obj = JsValNew(ji, JV_OBJ);
	pr = JsPropGet(fn, "prototype");
	if (pr && pr->type == JV_OBJ)
		obj->proto = pr;
	r = JsCall(ji, fn, obj, args, argc);
	if (r && (r->type == JV_OBJ || r->type == JV_ARR))
		return r; // natives (XMLHttpRequest) and explicit object returns
	return obj;
}

CJsVal *JsEval(CJsInterp *ji, CJsNode *node)
{
	CJsVal	*v, *obj, *fn, *cur, *sv;
	CJsVal	*argv[JS_MAX_ARGS];
	CJsNode *child, *item;
	CJsProp *prp;
	I64		 i, argc, op, k;
	U8		 one[2], nmbuf[80];

	if (!node || ji->has_err)
		return JsUndefV(ji);
	ji->steps++;
	if (ji->steps > JS_MAX_STEPS)
	{
		JsErr(ji, "script ran too long");
		return JsUndefV(ji);
	}

	switch (node->type)
	{
		case JN_NUM:
			if (node->str)
				return JsBoolV(ji, node->num != 0);
			return JsNumV(ji, node->num);
		case JN_STR:
			return JsStrV(ji, node->str);
		case JN_NULLLIT:
			return JsNullV(ji);
		case JN_UNDEFLIT:
			return JsUndefV(ji);
		case JN_IDENT:
			v = JsEnvGet(ji, node->str);
			if (v)
				return v;
			return JsUndefV(ji);
		case JN_SEQ:
			// comma/sequence: evaluate each, yield the last (e.g. (0, fn) -> fn)
			v = JsUndefV(ji);
			child = node->a;
			while (child && !ji->has_err && ji->flow == JF_NORMAL)
			{
				v = JsEval(ji, child);
				child = child->next;
			}
			return v;
		case JN_REGEX:
			// Stub RegExp: parses + carries source/flags so bundles run past the
			// literal; test()/exec() report no-match. Real engine = future work.
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "source", JsStrV(ji, node->str));
			JsPropSet(ji, v, "global", JsBoolV(ji, node->op & 1));
			JsPropSet(ji, v, "lastIndex", JsNumV(ji, 0));
			JsPropSet(ji, v, "test", JsNativeV(ji, JSN_RE_TEST));
			JsPropSet(ji, v, "exec", JsNativeV(ji, JSN_RE_EXEC));
			return v;
		case JN_ARRLIT:
			v = JsArrV(ji);
			child = node->a;
			while (child)
			{
				if (child->type == JN_SPREAD)
				{ // [...a, b]
					sv = JsEval(ji, child->a);
					if (sv && sv->type == JV_ARR)
					{
						for (k = 0; k < sv->count; k++)
							JsArrPush(ji, v, sv->items[k]);
					}
					else if (sv)
						JsArrPush(ji, v, sv);
				}
				else
					JsArrPush(ji, v, JsEval(ji, child));
				child = child->next;
			}
			return v;
		case JN_OBJLIT:
			v = JsValNew(ji, JV_OBJ);
			child = node->a;
			while (child)
			{
				if (child->type == JN_SPREAD)
				{ // {...src}: shallow-merge the source object's props
					sv = JsEval(ji, child->a);
					if (sv && sv->type == JV_OBJ)
					{
						prp = sv->props;
						while (prp)
						{
							JsPropSet(ji, v, prp->name, prp->val(CJsVal *));
							prp = prp->next;
						}
					}
				}
				else if (!child->str && child->b)
					// computed key {[expr]: val}
					JsPropSet(ji, v, JsToStr(ji, JsEval(ji, child->b)),
							  JsEval(ji, child->a));
				else
					JsPropSet(ji, v, child->str, JsEval(ji, child->a));
				child = child->next;
			}
			return v;
		case JN_MEMBER:
			obj = JsEval(ji, node->a);
			return JsMemberGet(ji, obj, node->str);
		case JN_INDEX:
			obj = JsEval(ji, node->a);
			v	= JsEval(ji, node->b);
			if (obj->type == JV_ARR)
			{
				i = JsToNum(v);
				if (0 <= i < obj->count)
					return obj->items[i];
				return JsUndefV(ji);
			}
			if (obj->type == JV_STR)
			{
				i = JsToNum(v);
				if (0 <= i < StrLen(obj->str))
				{
					one[0] = obj->str[i];
					one[1] = 0;
					return JsStrV(ji, one);
				}
				return JsUndefV(ji);
			}
			if (obj->type == JV_OBJ)
				return JsMemberGet(ji, obj, JsToStr(ji, v));
			return JsUndefV(ji);
		case JN_BIN:
			op = node->op;
			if (op == JP_AND)
			{
				v = JsEval(ji, node->a);
				if (!JsToBool(v))
					return v;
				return JsEval(ji, node->b);
			}
			if (op == JP_OR)
			{
				v = JsEval(ji, node->a);
				if (JsToBool(v))
					return v;
				return JsEval(ji, node->b);
			}
			if (op == JP_NULLISH)
			{ // a ?? b: b only when a is null/undefined
				v = JsEval(ji, node->a);
				if (v && v->type != JV_UNDEF && v->type != JV_NULL)
					return v;
				return JsEval(ji, node->b);
			}
			v	= JsEval(ji, node->a);
			obj = JsEval(ji, node->b);
			return JsEvalBin(ji, op, v, obj);
		case JN_UN:
			op = node->op;
			if (op == 'd')
			{ // delete obj.prop / obj[key]: soft-delete (set undefined) -> true
				if (node->a && node->a->type == JN_MEMBER)
				{
					obj = JsEval(ji, node->a->a);
					if (obj && obj->type == JV_OBJ)
						JsPropSet(ji, obj, node->a->str, JsUndefV(ji));
				}
				else if (node->a && node->a->type == JN_INDEX)
				{
					obj = JsEval(ji, node->a->a);
					if (obj && obj->type == JV_OBJ)
						JsPropSet(ji, obj, JsToStr(ji, JsEval(ji, node->a->b)),
								  JsUndefV(ji));
				}
				return JsBoolV(ji, TRUE);
			}
			v = JsEval(ji, node->a);
			if (op == 'y') // yield x -> x (eager generator approximation)
				return v;
			if (op == 'v') // void x
				return JsUndefV(ji);
			if (op == 'p') // unary +
				return JsNumV(ji, JsToNum(v));
			if (op == '!')
				return JsBoolV(ji, !JsToBool(v));
			if (op == '-')
				return JsNumV(ji, -JsToNum(v));
			if (op == '~')
				return JsNumV(ji, ~ToI64(JsToNum(v)));
			// typeof
			switch (v->type)
			{
				case JV_UNDEF:	return JsStrV(ji, "undefined");
				case JV_BOOL:	return JsStrV(ji, "boolean");
				case JV_NUM:	return JsStrV(ji, "number");
				case JV_STR:	return JsStrV(ji, "string");
				case JV_FUNC:
				case JV_NATIVE:	return JsStrV(ji, "function");
			}
			return JsStrV(ji, "object");
		case JN_COND:
			if (JsToBool(JsEval(ji, node->a)))
				return JsEval(ji, node->b);
			return JsEval(ji, node->c);
		case JN_ASSIGN:
			op = node->op;
			if (op == '=')
			{
				v = JsEval(ji, node->b);
				JsAssignTo(ji, node->a, v);
				return v;
			}
			cur = JsEval(ji, node->a);
			if (op == JP_ANDEQ)
			{ // a &&= b : assign only when a is truthy
				if (!JsToBool(cur))
					return cur;
				v = JsEval(ji, node->b);
				JsAssignTo(ji, node->a, v);
				return v;
			}
			if (op == JP_OREQ)
			{
				if (JsToBool(cur))
					return cur;
				v = JsEval(ji, node->b);
				JsAssignTo(ji, node->a, v);
				return v;
			}
			if (op == JP_NULEQ)
			{
				if (cur && cur->type != JV_UNDEF && cur->type != JV_NULL)
					return cur;
				v = JsEval(ji, node->b);
				JsAssignTo(ji, node->a, v);
				return v;
			}
			v = JsEval(ji, node->b);
			if (op == JP_ADDEQ)		v = JsEvalBin(ji, '+', cur, v);
			else if (op == JP_SUBEQ)	v = JsEvalBin(ji, '-', cur, v);
			else if (op == JP_MULEQ)	v = JsEvalBin(ji, '*', cur, v);
			else if (op == JP_DIVEQ)	v = JsEvalBin(ji, '/', cur, v);
			else if (op == JP_MODEQ)	v = JsEvalBin(ji, '%', cur, v);
			else if (op == JP_POWEQ)	v = JsEvalBin(ji, JP_POW, cur, v);
			else if (op == JP_BANDEQ)	v = JsEvalBin(ji, '&', cur, v);
			else if (op == JP_BOREQ)	v = JsEvalBin(ji, '|', cur, v);
			else if (op == JP_BXOREQ)	v = JsEvalBin(ji, '^', cur, v);
			else if (op == JP_SHLEQ)	v = JsEvalBin(ji, JP_SHL, cur, v);
			else if (op == JP_SHREQ)	v = JsEvalBin(ji, JP_SHR, cur, v);
			JsAssignTo(ji, node->a, v);
			return v;
		case JN_PREINC:
			cur = JsEval(ji, node->a);
			v = JsNumV(ji, JsToNum(cur) + node->op);
			JsAssignTo(ji, node->a, v);
			return v;
		case JN_POSTINC:
			cur = JsEval(ji, node->a);
			v = JsNumV(ji, JsToNum(cur));
			JsAssignTo(ji, node->a, JsNumV(ji, v->num + node->op));
			return v;
		case JN_CALL:
			if (node->a && node->a->type == JN_NEW)
			{ // new X(args)
				fn = JsEval(ji, node->a->a);
				argc = 0;
				child = node->b;
				while (child && argc < JS_MAX_ARGS)
				{
					if (child->type == JN_SPREAD)
					{ // new X(...arr)
						sv = JsEval(ji, child->a);
						if (sv && sv->type == JV_ARR)
						{
							for (k = 0; k < sv->count && argc < JS_MAX_ARGS; k++)
								argv[argc++] = sv->items[k];
						}
						else if (sv)
							argv[argc++] = sv;
					}
					else
					{ // local first - see the arg-eval note in the call path below
						sv = JsEval(ji, child);
						argv[argc++] = sv;
					}
					child = child->next;
				}
				return JsConstruct(ji, fn, argv, argc, JsCtorName(node->a->a));
			}
			if (node->a && node->a->type == JN_MEMBER)
			{
				obj = JsEval(ji, node->a->a);
				fn	= JsMemberGet(ji, obj, node->a->str);
			}
			else
			{
				obj = NULL;
				fn	= JsEval(ji, node->a);
			}
			argc = 0;
			child = node->b;
			while (child && argc < JS_MAX_ARGS)
			{
				if (child->type == JN_SPREAD)
				{ // f(...arr): flatten the array into the arg vector
					sv = JsEval(ji, child->a);
					if (sv && sv->type == JV_ARR)
					{
						for (k = 0; k < sv->count && argc < JS_MAX_ARGS; k++)
							argv[argc++] = sv->items[k];
					}
					else if (sv)
						argv[argc++] = sv;
				}
				else
				{ // eval into a local FIRST: `argv[argc++] = JsEval(...)` computes
				  // the slot address before the call and a deep callee chain
				  // clobbers it -> the store misses argv and stale stack junk
				  // (old return addresses) is read back as the argument value.
					sv = JsEval(ji, child);
					argv[argc++] = sv;
				}
				child = child->next;
			}
			if (!fn || (fn->type != JV_FUNC && fn->type != JV_NATIVE))
			{ // name the non-callable so the log says which member/global is missing
				StrPrint(nmbuf, "not a function: %s", JsCtorName(node->a));
				for (i = 0; nmbuf[i]; i++)
					if (nmbuf[i] == 0x24)
						nmbuf[i] = '?';
				JsErr(ji, nmbuf);
				return JsUndefV(ji);
			}
			return JsCall(ji, fn, obj, argv, argc);
		case JN_VAR:
			child = node->a;
			while (child)
			{
				if (child->type == JN_DESTRUCT)
				{ // const {a, b: c} = e; / const [x, y] = e;
					v = NULL;
					if (child->a)
						v = JsEval(ji, child->a);
					item = child->b;
					k = 0;
					while (item)
					{
						if (item->op == 3)
						{ // hole / unbindable element: consume an array slot only
							if (child->op == 1)
								k++;
						}
						else if (item->op == 2)
						{ // ...rest
							if (child->op == 1)
							{ // array rest -> remaining items
								sv = JsArrV(ji);
								if (v && v->type == JV_ARR)
									while (k < v->count)
									{
										JsArrPush(ji, sv, v->items[k]);
										k++;
									}
							}
							else
								sv = JsValNew(ji, JV_OBJ); // object rest: approx empty
							JsEnvDeclare(ji, ji->env, item->str, sv);
						}
						else
						{
							sv = JsUndefV(ji);
							if (v && child->op == 1)
							{
								if (v->type == JV_ARR && k < v->count)
									sv = v->items[k];
							}
							else if (v && v->type == JV_OBJ)
							{
								cur = JsPropGet(v, item->str);
								if (cur)
									sv = cur;
							}
							if (sv->type == JV_UNDEF && item->c)
								sv = JsEval(ji, item->c); // default value
							if (item->a)
								JsEnvDeclare(ji, ji->env, item->a->str, sv);
							else
								JsEnvDeclare(ji, ji->env, item->str, sv);
							k++;
						}
						item = item->next;
					}
				}
				else
				{
					if (child->a)
						v = JsEval(ji, child->a);
					else
						v = JsUndefV(ji);
					JsEnvDeclare(ji, ji->env, child->str, v);
				}
				child = child->next;
			}
			return NULL;
		case JN_IF:
			if (JsToBool(JsEval(ji, node->a)))
				JsEval(ji, node->b);
			else if (node->c)
				JsEval(ji, node->c);
			return NULL;
		case JN_WHILE:
			while (!ji->has_err && ji->flow == JF_NORMAL &&
				   JsToBool(JsEval(ji, node->a)))
			{
				JsEval(ji, node->b);
				if (ji->flow == JF_CONTINUE)
					ji->flow = JF_NORMAL;
			}
			if (ji->flow == JF_BREAK)
				ji->flow = JF_NORMAL;
			return NULL;
		case JN_DO:
			while (!ji->has_err)
			{
				JsEval(ji, node->a);
				if (ji->flow == JF_CONTINUE)
					ji->flow = JF_NORMAL;
				if (ji->flow != JF_NORMAL)
					break;
				if (!JsToBool(JsEval(ji, node->b)))
					break;
			}
			if (ji->flow == JF_BREAK)
				ji->flow = JF_NORMAL;
			return NULL;
		case JN_CONTINUE:
			ji->flow = JF_CONTINUE;
			return NULL;
		case JN_SWITCH:
			// pass 1: find the matching case (JS also evaluates tests in order);
			// no match -> the default arm. Then execute with fallthrough.
			sv = JsEval(ji, node->a);
			item = NULL;
			child = node->b;
			while (child && !item && !ji->has_err)
			{
				if (child->a && JsStrictEq(sv, JsEval(ji, child->a)))
					item = child;
				child = child->next;
			}
			if (!item)
			{
				child = node->b;
				while (child && !item)
				{
					if (!child->a)
						item = child;
					child = child->next;
				}
			}
			child = item;
			while (child && !ji->has_err && ji->flow == JF_NORMAL)
			{
				item = child->b;
				while (item && !ji->has_err && ji->flow == JF_NORMAL)
				{
					JsEval(ji, item);
					item = item->next;
				}
				child = child->next; // fallthrough into the next arm
			}
			if (ji->flow == JF_BREAK)
				ji->flow = JF_NORMAL;
			return NULL;
		case JN_FOR:
			if (node->a)
				JsEval(ji, node->a);
			while (!ji->has_err && ji->flow == JF_NORMAL &&
				   (!node->b || JsToBool(JsEval(ji, node->b))))
			{
				JsEval(ji, node->d);
				if (ji->flow == JF_CONTINUE)
					ji->flow = JF_NORMAL; // continue still runs the update expr
				if (ji->flow == JF_NORMAL && node->c)
					JsEval(ji, node->c);
			}
			if (ji->flow == JF_BREAK)
				ji->flow = JF_NORMAL;
			return NULL;
		case JN_BLOCK:
			child = node->a;
			while (child && !ji->has_err && ji->flow == JF_NORMAL)
			{
				JsEval(ji, child);
				child = child->next;
			}
			return NULL;
		case JN_FUNC:
			v = JsValNew(ji, JV_FUNC);
			v->func = node(U64);
			v->fenv = ji->env; // capture the defining env: closures
			if (node->str)
				JsEnvDeclare(ji, ji->env, node->str, v);
			return v;
		case JN_RETURN:
			if (node->a)
				ji->ret_val = JsEval(ji, node->a);
			else
				ji->ret_val = JsUndefV(ji);
			ji->flow = JF_RETURN;
			return NULL;
		case JN_BREAK:
			ji->flow = JF_BREAK;
			return NULL;
		case JN_EXPR:
			return JsEval(ji, node->a);
		case JN_NEW: // new X (no argument parens)
			fn = JsEval(ji, node->a);
			return JsConstruct(ji, fn, NULL, 0, JsCtorName(node->a));
		case JN_THROW:
			ji->exc = JsEval(ji, node->a);
			ji->flow = JF_THROW;
			return NULL;
		case JN_AWAIT:
			v = JsEval(ji, node->a);
			if (v && v->type == JV_OBJ && v->native_id == JSO_PROMISE)
			{ // our promises settle synchronously: drain reactions, then unwrap
				JsMicroDrain(ji);
				sv	= JsPropGet(v, "_state");
				cur	= JsPropGet(v, "_value");
				if (sv && JsToNum(sv) == 2)
				{ // rejected -> throw into the surrounding try/catch
					if (cur)
						ji->exc = cur;
					else
						ji->exc = JsUndefV(ji);
					ji->flow = JF_THROW;
					return JsUndefV(ji);
				}
				if (cur)
					return cur;
				return JsUndefV(ji);
			}
			return v;
		case JN_SPREAD: // evaluated bare (defensive): act like the plain value
			return JsEval(ji, node->a);
		case JN_TRY:
			JsEval(ji, node->a);
			if (ji->flow == JF_THROW && node->b)
			{
				ji->flow = JF_NORMAL;
				v = ji->exc;
				if (!v)
					v = JsUndefV(ji);
				if (node->str)
					JsEnvDeclare(ji, ji->env, node->str, v);
				JsEval(ji, node->b);
			}
			if (node->c)
			{ // finally always runs, then any pending flow resumes
				op = ji->flow;
				ji->flow = JF_NORMAL;
				JsEval(ji, node->c);
				if (ji->flow == JF_NORMAL)
					ji->flow = op;
			}
			return NULL;
		case JN_FOROF:
			v = JsEval(ji, node->a);
			if (v->type == JV_ARR)
			{
				for (argc = 0; argc < v->count && !ji->has_err &&
					 ji->flow == JF_NORMAL; argc++)
				{
					if (node->op)
						JsEnvDeclare(ji, ji->env, node->str, JsNumV(ji, argc));
					else
						JsEnvDeclare(ji, ji->env, node->str, v->items[argc]);
					JsEval(ji, node->d);
					if (ji->flow == JF_CONTINUE)
						ji->flow = JF_NORMAL;
				}
			}
			else if (v->type == JV_STR && !node->op)
			{
				for (argc = 0; v->str[argc] && !ji->has_err &&
					 ji->flow == JF_NORMAL; argc++)
				{
					one[0] = v->str[argc];
					one[1] = 0;
					JsEnvDeclare(ji, ji->env, node->str, JsStrV(ji, one));
					JsEval(ji, node->d);
					if (ji->flow == JF_CONTINUE)
						ji->flow = JF_NORMAL;
				}
			}
			else if (v->type == JV_OBJ && node->op)
			{
				prp = v->props;
				while (prp && !ji->has_err && ji->flow == JF_NORMAL)
				{
					JsEnvDeclare(ji, ji->env, node->str, JsStrV(ji, prp->name));
					JsEval(ji, node->d);
					if (ji->flow == JF_CONTINUE)
						ji->flow = JF_NORMAL;
					prp = prp->next;
				}
			}
			if (ji->flow == JF_BREAK)
				ji->flow = JF_NORMAL;
			return NULL;
		case JN_CLASS:
			obj = JsValNew(ji, JV_OBJ); // the prototype object
			v = NULL;					// the constructor
			child = node->a;
			while (child)
			{
				fn = JsEval(ji, child->a); // JN_FUNC: closure value
				if (!StrCompare(child->str, "constructor"))
					v = fn;
				else
					JsPropSet(ji, obj, child->str, fn);
				child = child->next;
			}
			if (!v)
				v = JsNativeV(ji, JSN_EVT_NOOP); // default empty constructor
			JsPropSet(ji, v, "prototype", obj);
			if (node->str)
				JsEnvDeclare(ji, ji->env, node->str, v);
			return v;
	}

	return JsUndefV(ji);
}

/* ---- calls ---- */

CJsVal *JsArgOr(CJsInterp *ji, CJsVal **args, I64 argc, I64 i)
{
	if (i < argc)
		return args[i];

	return JsUndefV(ji);
}

/* ---- microtasks + promises (Phase B-2) ---- */

U0 JsMicroAdd(CJsInterp *ji, CJsVal *fn, CJsVal *arg, Bool has_arg)
{
	CJsMicro *m;

	if (!fn || (fn->type != JV_FUNC && fn->type != JV_NATIVE))
		return;
	m = JsAlloc(ji, sizeof(CJsMicro))(CJsMicro *);
	m->fn = fn;
	m->arg = arg;
	m->has_arg = has_arg;
	m->next = NULL;
	if (ji->micro_tail)
		ji->micro_tail->next = m;
	else
		ji->micro_head = m;
	ji->micro_tail = m;
}

U0 JsMicroDrain(CJsInterp *ji)
{ // run queued promise reactions; bounded so a self-queuing loop can't wedge
	CJsMicro *m;
	CJsVal	 *a1;
	I64		  ran = 0;

	while (ji->micro_head && ran < 512)
	{
		m = ji->micro_head;
		ji->micro_head = m->next;
		if (!ji->micro_head)
			ji->micro_tail = NULL;
		ji->steps = 0;
		ji->depth = 0;
		ji->flow = JF_NORMAL;
		ji->env = ji->genv;
		if (m->has_arg)
		{
			a1 = m->arg;
			JsCall(ji, m->fn, NULL, &a1, 1);
		}
		else
			JsCall(ji, m->fn, NULL, NULL, 0);
		if (ji->has_err)
		{
			NetLog("%s", ji->err);
			ji->has_err = FALSE;
		}
		ji->flow = JF_NORMAL;
		ran++;
	}
}

CJsVal *JsPromiseNew(CJsInterp *ji)
{
	CJsVal *pr = JsValNew(ji, JV_OBJ);

	pr->native_id = JSO_PROMISE;
	JsPropSet(ji, pr, "_state", JsNumV(ji, 0)); // 0 pending 1 resolved 2 rejected
	JsPropSet(ji, pr, "_onres", JsArrV(ji));
	JsPropSet(ji, pr, "_onrej", JsArrV(ji));
	return pr;
}

U0 JsPromiseSettle(CJsInterp *ji, CJsVal *pr, CJsVal *val, Bool rejected)
{
	CJsVal *st, *cbs;
	I64		i;

	if (!pr || pr->native_id != JSO_PROMISE)
		return;
	st = JsPropGet(pr, "_state");
	if (st && JsToNum(st) != 0.0)
		return; // already settled
	if (!val)
		val = JsUndefV(ji);
	if (rejected)
		JsPropSet(ji, pr, "_state", JsNumV(ji, 2));
	else
		JsPropSet(ji, pr, "_state", JsNumV(ji, 1));
	JsPropSet(ji, pr, "_value", val);
	if (rejected)
		cbs = JsPropGet(pr, "_onrej");
	else
		cbs = JsPropGet(pr, "_onres");
	if (cbs && cbs->type == JV_ARR)
		for (i = 0; i < cbs->count; i++)
			JsMicroAdd(ji, cbs->items[i], val, TRUE);
}

U0 JsPromiseReact(CJsInterp *ji, CJsVal *pr, CJsVal *cb, Bool on_rej)
{ // then/catch registration (or immediate microtask when already settled)
	CJsVal *st, *val, *cbs;
	I64		state;

	if (!pr || pr->native_id != JSO_PROMISE || !cb)
		return;
	st = JsPropGet(pr, "_state");
	state = 0;
	if (st)
		state = JsToNum(st);
	if (state == 0)
	{
		if (on_rej)
			cbs = JsPropGet(pr, "_onrej");
		else
			cbs = JsPropGet(pr, "_onres");
		if (cbs && cbs->type == JV_ARR)
			JsArrPush(ji, cbs, cb);
		return;
	}
	if ((state == 1 && !on_rej) || (state == 2 && on_rej))
	{
		val = JsPropGet(pr, "_value");
		JsMicroAdd(ji, cb, val, TRUE);
	}
}

CJsVal *JsFetch(CJsInterp *ji, CJsVal **args, I64 argc)
{ // fetch(url[, {method, body}]) -> promise of a response object. The network
  // request is synchronous underneath; then-callbacks fire on the next pump.
	U8			  *url, *abs = NULL, *method = NULL, *body = NULL;
	CJsVal		  *pr, *resp, *ov, *mv;
	CHttpUrl	   base;
	CHttpResponse *r;

	pr = JsPromiseNew(ji);
	if (!argc)
	{
		JsPromiseSettle(ji, pr, JsUndefV(ji), TRUE);
		return pr;
	}
	url = JsToStr(ji, args[0]);
	if (argc > 1 && args[1]->type == JV_OBJ)
	{
		ov = args[1];
		mv = JsPropGet(ov, "method");
		if (mv)
			method = JsToStr(ji, mv);
		mv = JsPropGet(ov, "body");
		if (mv && mv->type != JV_UNDEF && mv->type != JV_NULL)
			body = JsToStr(ji, mv);
	}
	if (HttpUrlParse(ji->url, &base) >= 0)
		abs = HttpUrlResolve(&base, url);
	if (!abs)
		abs = StrNew(url);
	if (method && !StrICompare(method, "POST") && body)
		r = HttpPost(abs, body);
	else
		r = HttpGet(abs);
	Free(abs);

	resp = JsValNew(ji, JV_OBJ);
	if (r)
	{
		JsPropSet(ji, resp, "status", JsNumV(ji, r->status));
		JsPropSet(ji, resp, "ok", JsBoolV(ji, 200 <= r->status < 300));
		JsPropSet(ji, resp, "_body", JsStrV(ji, r->body));
		HttpResponseFree(r);
		JsPropSet(ji, resp, "text", JsNativeV(ji, JSN_RESP_TEXT));
		JsPropSet(ji, resp, "json", JsNativeV(ji, JSN_RESP_JSON));
		JsPromiseSettle(ji, pr, resp, FALSE);
	}
	else
	{
		JsPropSet(ji, resp, "status", JsNumV(ji, 0));
		JsPropSet(ji, resp, "ok", JsBoolV(ji, FALSE));
		JsPromiseSettle(ji, pr, resp, TRUE);
	}
	return pr;
}

/* ---- JSON ---- */

CJsVal *JsJsonParseVal(CJsInterp *ji, U8 **pp, I64 depth)
{
	U8	   *p = *pp, buf[1024];
	I64		n;
	CJsVal *v, *item;
	Bool	neg;

	while (*p == ' ' || *p == '\t' || *p == '\n' || *p == '\r')
		p++;
	if (depth > 24 || !*p)
	{
		*pp = p;
		return JsNullV(ji);
	}
	if (*p == '{')
	{
		p++;
		v = JsValNew(ji, JV_OBJ);
		while (*p)
		{
			while (*p == ' ' || *p == '\t' || *p == '\n' || *p == '\r' || *p == ',')
				p++;
			if (*p == '}')
			{ p++; break; }
			if (*p != '"')
				break;
			p++;
			n = 0;
			while (*p && *p != '"' && n < 1020)
			{
				if (*p == '\\' && p[1])
					p++;
				buf[n++] = *p++;
			}
			buf[n] = 0;
			if (*p == '"')
				p++;
			while (*p == ' ' || *p == '\t')
				p++;
			if (*p == ':')
				p++;
			*pp = p;
			item = JsJsonParseVal(ji, pp, depth + 1);
			p = *pp;
			JsPropSet(ji, v, buf, item);
		}
		*pp = p;
		return v;
	}
	if (*p == '[')
	{
		p++;
		v = JsArrV(ji);
		while (*p)
		{
			while (*p == ' ' || *p == '\t' || *p == '\n' || *p == '\r' || *p == ',')
				p++;
			if (*p == ']')
			{ p++; break; }
			*pp = p;
			item = JsJsonParseVal(ji, pp, depth + 1);
			p = *pp;
			JsArrPush(ji, v, item);
		}
		*pp = p;
		return v;
	}
	if (*p == '"')
	{
		p++;
		n = 0;
		while (*p && *p != '"' && n < 1020)
		{
			if (*p == '\\' && p[1])
			{
				p++;
				if (*p == 'n')
				{ buf[n++] = '\n'; p++; }
				else if (*p == 't')
				{ buf[n++] = '\t'; p++; }
				else
					buf[n++] = *p++;
			}
			else
				buf[n++] = *p++;
		}
		buf[n] = 0;
		if (*p == '"')
			p++;
		*pp = p;
		return JsStrV(ji, buf);
	}
	if (!StrNCompare(p, "true", 4))
	{ *pp = p + 4; return JsBoolV(ji, TRUE); }
	if (!StrNCompare(p, "false", 5))
	{ *pp = p + 5; return JsBoolV(ji, FALSE); }
	if (!StrNCompare(p, "null", 4))
	{ *pp = p + 4; return JsNullV(ji); }
	neg = FALSE;
	if (*p == '-')
	{ neg = TRUE; }
	n = 0;
	while ((('0' <= *p <= '9') || *p == '.' || *p == '-' || *p == '+' ||
			*p == 'e' || *p == 'E') && n < 60)
		buf[n++] = *p++;
	buf[n] = 0;
	*pp = p;
	if (!n)
	{ (*pp)++; return JsNullV(ji); }
	no_warn neg;
	return JsNumV(ji, Str2F64(buf));
}

U0 JsJsonAppend(U8 *out, I64 *n, I64 max, U8 *s)
{
	while (*s && *n < max - 1)
		out[(*n)++] = *s++;
	out[*n] = 0;
}

U0 JsJsonStringify(CJsInterp *ji, CJsVal *v, U8 *out, I64 *n, I64 max, I64 depth)
{
	CJsProp *prp;
	I64		i;
	Bool	first;

	if (!v || depth > 12)
	{ JsJsonAppend(out, n, max, "null"); return; }
	switch (v->type)
	{
		case JV_NUM:
		case JV_BOOL:
			JsJsonAppend(out, n, max, JsToStr(ji, v));
			break;
		case JV_STR:
			JsJsonAppend(out, n, max, "\"");
			JsJsonAppend(out, n, max, v->str); // escaping: minimal
			JsJsonAppend(out, n, max, "\"");
			break;
		case JV_ARR:
			JsJsonAppend(out, n, max, "[");
			for (i = 0; i < v->count; i++)
			{
				if (i)
					JsJsonAppend(out, n, max, ",");
				JsJsonStringify(ji, v->items[i], out, n, max, depth + 1);
			}
			JsJsonAppend(out, n, max, "]");
			break;
		case JV_OBJ:
			JsJsonAppend(out, n, max, "{");
			first = TRUE;
			prp = v->props;
			while (prp)
			{
				if (prp->name[0] != '_') // skip internal slots
				{
					if (!first)
						JsJsonAppend(out, n, max, ",");
					first = FALSE;
					JsJsonAppend(out, n, max, "\"");
					JsJsonAppend(out, n, max, prp->name);
					JsJsonAppend(out, n, max, "\":");
					JsJsonStringify(ji, prp->val(CJsVal *), out, n, max, depth + 1);
				}
				prp = prp->next;
			}
			JsJsonAppend(out, n, max, "}");
			break;
		default:
			JsJsonAppend(out, n, max, "null");
			break;
	}
}

/* ---- DOM mutation + selectors + classList ---- */

U0 JsNodeDetach(CZNode *c)
{ // unlink c from its parent's child list (node stays allocated)
	CZNode *p = c->parent, *s;

	if (!p)
		return;
	if (p->first_child == c)
	{
		p->first_child = c->next;
		if (p->last_child == c)
			p->last_child = NULL;
	}
	else
	{
		s = p->first_child;
		while (s && s->next != c)
			s = s->next;
		if (s)
		{
			s->next = c->next;
			if (p->last_child == c)
				p->last_child = s;
		}
	}
	c->parent = NULL;
	c->next = NULL;
	zh_dom_gen++;
}

U0 JsStyleIngest(CJsInterp *ji, CZNode *node)
{ // a <style> element gained content: parse its text into live CSS rules.
  // This is how CSS-in-JS frameworks style the page.
	U8	*buf;
	I64	 len = 0;

	if (!node || StrCompare(node->tag, "style"))
		return;
	buf = MAlloc(32768);
	ZNodeTextCollect(node, buf, 32760, &len);
	if (len)
		ZCssParseRegion(buf, buf + len);
	Free(buf);
	ji->dom_dirty = TRUE;
}

U0 JsNodeAppend(CJsInterp *ji, CZNode *p, CZNode *c)
{
	if (!p || !c || p == c)
		return;
	JsNodeDetach(c);
	c->parent = p;
	c->next = NULL;
	if (p->last_child)
		p->last_child->next = c;
	else
		p->first_child = c;
	p->last_child = c;
	zh_dom_gen++;
	ji->dom_dirty = TRUE;
	JsStyleIngest(ji, c); // CSS-in-JS: appending a filled <style> applies it
}

U0 JsQSelSplit(U8 *sel, U8 *tag, U8 *cls, U8 *id)
{ // one compound selector: tag, .class, #id in any combination
	I64 tn = 0, cn = 0, in = 0, mode = 0;

	tag[0] = 0;
	cls[0] = 0;
	id[0] = 0;
	while (*sel == ' ')
		sel++;
	while (*sel && *sel != ' ' && *sel != ',')
	{
		if (*sel == '.')
		{ mode = 1; cn = 0; sel++; }
		else if (*sel == '#')
		{ mode = 2; in = 0; sel++; }
		else
		{
			if (mode == 0 && tn < 15)
				tag[tn++] = ZChLower(*sel);
			else if (mode == 1 && cn < 31)
				cls[cn++] = *sel;
			else if (mode == 2 && in < 31)
				id[in++] = *sel;
			sel++;
		}
	}
	tag[tn] = 0;
	cls[cn] = 0;
	id[in] = 0;
}

Bool JsClassHasTok(U8 *class_attr, U8 *tok)
{
	U8	*p = class_attr;
	I64	 tl = StrLen(tok);

	if (!p || !tl)
		return FALSE;
	while (*p)
	{
		while (*p == ' ')
			p++;
		if (!StrNICompare(p, tok, tl) && (p[tl] == 0 || p[tl] == ' '))
			return TRUE;
		while (*p && *p != ' ')
			p++;
	}
	return FALSE;
}

Bool JsQSelMatch(CZNode *node, U8 *tag, U8 *cls, U8 *id)
{
	U8 *a;

	if (node->type != ZH_ELEM)
		return FALSE;
	if (tag[0] && StrCompare(node->tag, tag))
		return FALSE;
	if (id[0])
	{
		a = ZNodeAttr(node, "id");
		if (!a || StrCompare(a, id))
			return FALSE;
	}
	if (cls[0])
	{
		a = ZNodeAttr(node, "class");
		if (!JsClassHasTok(a, cls))
			return FALSE;
	}
	return tag[0] || cls[0] || id[0];
}

CZNode *JsQSelWalk(CZNode *node, U8 *tag, U8 *cls, U8 *id,
				   CJsInterp *ji, CJsVal *all)
{ // depth-first; all != NULL collects every match, else returns the first
	CZNode *child, *hit;

	if (!node)
		return NULL;
	if (JsQSelMatch(node, tag, cls, id))
	{
		if (!all)
			return node;
		if (all->count < 400)
			JsArrPush(ji, all, JsElemV(ji, node));
	}
	child = node->first_child;
	while (child)
	{
		hit = JsQSelWalk(child, tag, cls, id, ji, all);
		if (hit && !all)
			return hit;
		child = child->next;
	}
	return NULL;
}

U0 JsClassListMod(CJsInterp *ji, CZNode *node, U8 *tok, I64 mode)
{ // mode 0 add, 1 remove, 2 toggle
	U8	 buf[512];
	U8	*a = ZNodeAttr(node, "class"), *p;
	I64	 n = 0, tl = StrLen(tok);
	Bool has = JsClassHasTok(a, tok), keep;

	if (mode == 2)
	{
		if (has)
			mode = 1;
		else
			mode = 0;
	}
	if (mode == 0 && has)
		return;
	buf[0] = 0;
	if (a)
	{ // copy tokens, dropping tok when removing
		p = a;
		while (*p)
		{
			while (*p == ' ')
				p++;
			if (!*p)
				break;
			keep = TRUE;
			if (mode == 1 && !StrNICompare(p, tok, tl) &&
				(p[tl] == 0 || p[tl] == ' '))
				keep = FALSE;
			while (*p && *p != ' ')
			{
				if (keep && n < 508)
					buf[n++] = *p;
				p++;
			}
			if (keep && n < 508)
				buf[n++] = ' ';
		}
	}
	if (mode == 0)
	{
		p = tok;
		while (*p && n < 508)
			buf[n++] = *p++;
	}
	while (n && buf[n - 1] == ' ')
		n--;
	buf[n] = 0;
	ZNodeAttrSet(node, "class", buf);
	ji->dom_dirty = TRUE;
	no_warn tl;
}

/* ---- event loop, events, and XMLHttpRequest ----
   These give the interpreter what dynamic pages assume: timers that fire later,
   event handlers that fire on user interaction, and JS-driven network requests.
   Callbacks are invoked from JsEventLoopPump / JsDispatchEvent, which the
   browser front-end (ZincGX) calls each frame and on clicks. JsCall is
   forward-declared above. */

CJsVal *JsEventObj(CJsInterp *ji, CZNode *node, U8 *type)
{ // the minimal Event passed to a handler
	CJsVal *e = JsValNew(ji, JV_OBJ);

	JsPropSet(ji, e, "type", JsStrV(ji, type));
	if (node)
		JsPropSet(ji, e, "target", JsElemV(ji, node));
	JsPropSet(ji, e, "preventDefault",  JsNativeV(ji, JSN_EVT_NOOP));
	JsPropSet(ji, e, "stopPropagation", JsNativeV(ji, JSN_EVT_NOOP));
	return e;
}

CJsTimer *JsTimerAdd(CJsInterp *ji, CJsVal *fn, CJsVal *this_val,
					 F64 ms, Bool repeat, Bool is_xhr)
{
	CJsTimer *t = JsAlloc(ji, sizeof(CJsTimer))(CJsTimer *);

	t->id = ++ji->next_timer_id;
	t->fn = fn;
	t->this_val = this_val;
	if (ms < 0.0)
		ms = 0.0;
	t->due = tS + ms / 1000.0;
	if (repeat)
	{
		t->interval = ms / 1000.0;
		if (t->interval < 0.004)
			t->interval = 0.004; // throttle a runaway setInterval(fn, 0)
	}
	else
		t->interval = 0.0;
	t->is_xhr = is_xhr;
	t->active = TRUE;
	t->next = ji->timers;
	ji->timers = t;
	return t;
}

U0 JsTimerClear(CJsInterp *ji, I64 id)
{
	CJsTimer *t = ji->timers;

	while (t)
	{
		if (t->id == id)
		{
			t->active = FALSE;
			return;
		}
		t = t->next;
	}
}

CJsListener *JsListenerAdd(CJsInterp *ji, CZNode *node, U8 *type,
						   CJsVal *fn, Bool is_prop)
{
	CJsListener *l;

	if (!node || !fn || (fn->type != JV_FUNC && fn->type != JV_NATIVE))
		return NULL;

	if (is_prop)
	{ // el.onX = fn replaces any earlier el.onX handler of the same type
		l = ji->listeners;
		while (l)
		{
			if (l->active && l->is_prop && l->node == node &&
				!StrCompare(l->type, type))
				l->active = FALSE;
			l = l->next;
		}
	}

	l = JsAlloc(ji, sizeof(CJsListener))(CJsListener *);
	l->node = node;
	l->type = JsStrDup(ji, type);
	l->fn = fn;
	l->is_prop = is_prop;
	l->active = TRUE;
	l->next = ji->listeners;
	ji->listeners = l;
	return l;
}

U0 JsListenerRemove(CJsInterp *ji, CZNode *node, U8 *type, CJsVal *fn)
{
	CJsListener *l = ji->listeners;

	while (l)
	{
		if (l->active && l->node == node && !StrCompare(l->type, type) &&
			l->fn == fn)
			l->active = FALSE;
		l = l->next;
	}
}

U0 JsXhrFire(CJsInterp *ji, CJsVal *xhr)
{ // deliver a completed request: onreadystatechange, then onload/onerror
	CJsVal *cb, *st;
	I64		status = 0;

	if (!xhr || xhr->type != JV_OBJ)
		return;
	st = JsPropGet(xhr, "status");
	if (st)
		status = JsToNum(st);

	cb = JsPropGet(xhr, "onreadystatechange");
	if (cb && (cb->type == JV_FUNC || cb->type == JV_NATIVE))
	{
		ji->steps = 0; ji->depth = 0; ji->flow = JF_NORMAL; ji->env = ji->genv;
		JsCall(ji, cb, xhr, NULL, 0);
	}

	if (status > 0)
		cb = JsPropGet(xhr, "onload");
	else
		cb = JsPropGet(xhr, "onerror");
	if (cb && (cb->type == JV_FUNC || cb->type == JV_NATIVE))
	{
		ji->steps = 0; ji->depth = 0; ji->flow = JF_NORMAL; ji->env = ji->genv;
		JsCall(ji, cb, xhr, NULL, 0);
	}

	if (ji->has_err)
	{
		NetLog("%s", ji->err);
		ji->has_err = FALSE;
	}
}

U0 JsXhrSend(CJsInterp *ji, CJsVal *xhr, CJsVal *body_val)
{ // resolve the URL against the page, fetch, then stash the result on the XHR.
  // The fetch is synchronous here (the net stack is already blocking); async
  // requests just defer their callbacks to the next event-loop pump.
	U8			  *method = NULL, *url, *abs = NULL, *body = NULL;
	CJsVal		  *pm, *pu, *pa;
	CHttpUrl	   base;
	CHttpResponse *r;
	Bool		   is_async = TRUE;

	if (!xhr || xhr->type != JV_OBJ)
		return;
	pu = JsPropGet(xhr, "_url");
	if (!pu)
	{ // send() before open(): report a failed, completed request
		JsPropSet(ji, xhr, "status", JsNumV(ji, 0));
		JsPropSet(ji, xhr, "readyState", JsNumV(ji, 4));
		JsXhrFire(ji, xhr);
		return;
	}
	url = JsToStr(ji, pu);
	pm = JsPropGet(xhr, "_method");
	if (pm)
		method = JsToStr(ji, pm);
	pa = JsPropGet(xhr, "_async");
	if (pa && !JsToBool(pa))
		is_async = FALSE;

	if (HttpUrlParse(ji->url, &base) >= 0)
		abs = HttpUrlResolve(&base, url);
	if (!abs)
		abs = StrNew(url);

	if (body_val && body_val->type != JV_UNDEF && body_val->type != JV_NULL)
		body = JsToStr(ji, body_val);

	if (method && !StrICompare(method, "POST") && body)
		r = HttpPost(abs, body);
	else
		r = HttpGet(abs);
	Free(abs);

	if (r)
	{
		JsPropSet(ji, xhr, "status", JsNumV(ji, r->status));
		JsPropSet(ji, xhr, "responseText", JsStrV(ji, r->body));
		JsPropSet(ji, xhr, "response", JsStrV(ji, r->body));
		if (r->headers)
			JsPropSet(ji, xhr, "_respHeaders", JsStrV(ji, r->headers));
		JsPropSet(ji, xhr, "readyState", JsNumV(ji, 4));
		HttpResponseFree(r);
	}
	else
	{
		JsPropSet(ji, xhr, "status", JsNumV(ji, 0));
		JsPropSet(ji, xhr, "readyState", JsNumV(ji, 4));
	}

	if (is_async)
		JsTimerAdd(ji, NULL, xhr, 0.0, FALSE, TRUE); // fire callbacks next pump
	else
		JsXhrFire(ji, xhr);
}

Bool JsDispatchEvent(CJsInterp *ji, CZNode *node, U8 *type)
{ // fire every active handler bound to (node, type). Returns TRUE if any ran.
	CJsListener *l;
	CJsVal		*evt, *a1;
	Bool		 ran = FALSE;

	if (!ji || !node || !type)
		return FALSE;

	evt = JsEventObj(ji, node, type);
	l = ji->listeners;
	while (l)
	{
		if (l->active && l->node == node && !StrCompare(l->type, type))
		{
			ji->has_err = FALSE;
			ji->steps = 0; ji->depth = 0; ji->flow = JF_NORMAL; ji->env = ji->genv;
			a1 = evt;
			JsCall(ji, l->fn, JsElemV(ji, node), &a1, 1);
			ran = TRUE;
			if (ji->has_err)
			{
				NetLog("%s", ji->err);
				ji->has_err = FALSE;
			}
		}
		l = l->next;
	}
	if (ran)
	{
		JsMicroDrain(ji); // promise chains started by the handlers
		JsFlushWrites(ji);
	}
	return ran;
}

U0 JsEventLoopPump(CJsInterp *ji)
{ // drain promise microtasks, then fire due timers / async XHRs.
  // Bounded per call so a storm of 0ms timers cannot wedge the frame.
	CJsTimer *t;
	I64		  fired = 0;
	F64		  now;

	if (!ji)
		return;
	JsMicroDrain(ji); // promise reactions run before (and after) timers
	now = tS;
	t = ji->timers;
	while (t && fired < 256)
	{
		if (t->active && now >= t->due)
		{
			ji->has_err = FALSE;
			ji->steps = 0; ji->depth = 0; ji->flow = JF_NORMAL; ji->env = ji->genv;
			if (t->is_xhr)
			{
				t->active = FALSE;
				JsXhrFire(ji, t->this_val);
			}
			else
			{
				if (t->interval > 0.0)
					t->due = now + t->interval;
				else
					t->active = FALSE;
				if (t->fn)
					JsCall(ji, t->fn, t->this_val, NULL, 0);
			}
			fired++;
			if (ji->has_err)
			{
				NetLog("%s", ji->err);
				ji->has_err = FALSE;
			}
		}
		t = t->next;
	}
	if (fired)
		JsFlushWrites(ji);
	JsMicroDrain(ji); // reactions queued by the timers that just fired
}

/* ---- localStorage (session-wide, in-memory) ----
   Survives page loads within one browser session (statics initialize once per
   BrowserBoot compile). File persistence is a possible follow-up. */
#define JS_LS_MAX	48
U8	js_ls_keys[JS_LS_MAX][64];
U8	js_ls_vals[JS_LS_MAX][512];
I64	js_ls_count = 0; // statically initialized; JIT does not zero plain globals
I64	js_sym_n = 0;	 // Symbol() uniqueness counter

U0 JsAbsUrl(U8 *base, U8 *src, U8 *out)
{ // resolve src against base (an absolute http(s) URL) -> out (>= 1024 bytes)
	U8	*p, *lastslash = NULL;
	I64	 n;

	if (!src)
	{
		out[0] = 0;
		return;
	}
	if (StrFind("://", src) || !base || !StrFind("://", base))
	{ // already absolute (or no usable base): use as-is
		StrCopy(out, src);
		return;
	}
	if (src[0] == '/')
	{ // origin (scheme://host) + src
		p = StrFind("://", base) + 3;
		while (*p && *p != '/')
			p++;
		n = p - base;
		MemCopy(out, base, n);
		StrCopy(out + n, src);
		return;
	}
	// relative to the directory of base
	StrCopy(out, base);
	p = StrFind("://", out) + 3;
	while (*p)
	{
		if (*p == '/')
			lastslash = p;
		p++;
	}
	if (lastslash)
		StrCopy(lastslash + 1, src);
	else
	{
		n = StrLen(out);
		out[n] = '/';
		StrCopy(out + n + 1, src);
	}
}

U0 JsElemCollect(CJsInterp *ji, CZNode *root, I64 mode, U8 *key, CJsVal *arr)
{ // collect matching DESCENDANTS of root (never root itself) into arr. mode 0 =
  // tag (key or "*"), 1 = class token, 2 = name attr. Backs
  // getElementsByTagName/ClassName/Name (both are descendant-only per spec).
	CZNode *child;
	U8	   *a;
	Bool	hit;

	if (!root)
		return;
	child = root->first_child;
	while (child)
	{
		if (child->type == ZH_ELEM && arr->count < 400)
		{
			hit = FALSE;
			if (mode == 0)
				hit = !StrCompare(key, "*") || !StrICompare(child->tag, key);
			else if (mode == 1)
				hit = JsClassHasTok(ZNodeAttr(child, "class"), key);
			else
			{
				a	= ZNodeAttr(child, "name");
				hit = a && !StrCompare(a, key);
			}
			if (hit)
				JsArrPush(ji, arr, JsElemV(ji, child));
		}
		JsElemCollect(ji, child, mode, key, arr);
		child = child->next;
	}
}

Bool JsNodeContains(CZNode *root, CZNode *target)
{ // TRUE if target is root or a descendant of root
	CZNode *child;

	if (!root || !target)
		return FALSE;
	if (root == target)
		return TRUE;
	child = root->first_child;
	while (child)
	{
		if (JsNodeContains(child, target))
			return TRUE;
		child = child->next;
	}
	return FALSE;
}

CJsVal *JsCallNative(CJsInterp *ji, CJsVal *self, I64 id, CJsVal *this_val,
					 CJsVal **args, I64 argc)
{ // self = the native function value itself (carries promise binding in proto)
	U8	 buf[1024];
	U8	*s, *sep, *bb;
	I64	 i, a, b, len;
	F64	 best, ms;
	CJsVal *v, *w, *pr, *resv, *rej;
	CJsVal *pa[2];
	CZNode *node, *nd2;
	CDateStruct ds;
	CJsTimer *t;
	CJsProp *prp;
	U8	 qtag[16], qcls[32], qid[32];

	switch (id)
	{
		case JSN_FN_CALL: // fn.call(thisArg, ...rest) - this_val IS the target fn
			if (argc >= 1)
				return JsCall(ji, this_val, args[0], &args[1], argc - 1);
			return JsCall(ji, this_val, JsUndefV(ji), NULL, 0);
		case JSN_FN_APPLY: // fn.apply(thisArg, argsArray)
			w = JsArgOr(ji, args, argc, 1);
			if (w && w->type == JV_ARR)
				return JsCall(ji, this_val, JsArgOr(ji, args, argc, 0),
							  w->items, w->count);
			return JsCall(ji, this_val, JsArgOr(ji, args, argc, 0), NULL, 0);
		case JSN_FN_BIND: // fn.bind(thisArg) -> a bound native remembering _t/_this
			v = JsNativeV(ji, JSN_FN_BOUND);
			JsPropSet(ji, v, "_t", this_val);
			JsPropSet(ji, v, "_this", JsArgOr(ji, args, argc, 0));
			return v;
		case JSN_FN_BOUND: // invoking a bound fn: ignore call-site this, use _this
			pr = JsPropGet(self, "_t");
			if (pr)
				return JsCall(ji, pr, JsPropGet(self, "_this"), args, argc);
			return JsUndefV(ji);
		case JSN_ALERT:
			s = JsEscDollars(ji, JsToStr(ji, JsArgOr(ji, args, argc, 0)));
			PopUpOk(s);
			return JsUndefV(ji);
		case JSN_CONSOLE_LOG:
			buf[0] = 0;
			for (i = 0; i < argc; i++)
			{
				if (i)
					CatPrint(buf, " ");
				s = JsToStr(ji, args[i]);
				if (StrLen(buf) + StrLen(s) < 1000)
					CatPrint(buf, "%s", s);
			}
			NetLog("JS log: %s", buf);
			return JsUndefV(ji);
		case JSN_DOC_WRITE:
			for (i = 0; i < argc; i++)
				JsWriteAppend(ji, JsToStr(ji, args[i]));
			ji->dom_dirty = TRUE;
			return JsUndefV(ji);
		case JSN_DOC_GETBYID:
			node = ZDomFindId(ji->dom_root, JsToStr(ji, JsArgOr(ji, args, argc, 0)));
			if (node)
				return JsElemV(ji, node);
			return JsNullV(ji);
		case JSN_DOC_GETBYTAG:
		case JSN_DOC_GETBYCLASS:
		case JSN_DOC_GETBYNAME:
			node = ji->dom_root;
			if (this_val->type == JV_OBJ && this_val->node)
				node = this_val->node; // element-scoped variant
			v = JsArrV(ji);
			s = JsToStr(ji, JsArgOr(ji, args, argc, 0));
			if (id == JSN_DOC_GETBYTAG)
				JsElemCollect(ji, node, 0, s, v);
			else if (id == JSN_DOC_GETBYCLASS)
				JsElemCollect(ji, node, 1, s, v);
			else
				JsElemCollect(ji, node, 2, s, v);
			return v;
		case JSN_EL_CONTAINS:
			w = JsArgOr(ji, args, argc, 0);
			if (this_val->type == JV_OBJ && w && w->type == JV_OBJ)
				return JsBoolV(ji, JsNodeContains(this_val->node, w->node));
			return JsBoolV(ji, FALSE);
		case JSN_EL_MATCHES:
			JsQSelSplit(JsToStr(ji, JsArgOr(ji, args, argc, 0)), qtag, qcls, qid);
			if (this_val->type == JV_OBJ && this_val->node)
				return JsBoolV(ji, JsQSelMatch(this_val->node, qtag, qcls, qid));
			return JsBoolV(ji, FALSE);
		case JSN_EL_CLOSEST:
			JsQSelSplit(JsToStr(ji, JsArgOr(ji, args, argc, 0)), qtag, qcls, qid);
			node = NULL;
			if (this_val->type == JV_OBJ)
				node = this_val->node;
			while (node)
			{
				if (JsQSelMatch(node, qtag, qcls, qid))
					return JsElemV(ji, node);
				node = node->parent;
			}
			return JsNullV(ji);
		case JSN_EL_HASATTR:
			if (this_val->type == JV_OBJ && this_val->node)
				return JsBoolV(ji, ZNodeAttr(this_val->node,
							   JsToStr(ji, JsArgOr(ji, args, argc, 0))) != NULL);
			return JsBoolV(ji, FALSE);
		case JSN_EL_RMATTR:
			if (this_val->type == JV_OBJ && this_val->node)
			{ // no true attr removal helper: blank it (visually equivalent here)
				ZNodeAttrSet(this_val->node,
							 JsToStr(ji, JsArgOr(ji, args, argc, 0)), "");
				ji->dom_dirty = TRUE;
			}
			return JsUndefV(ji);
		case JSN_EL_CLONE:
			if (this_val->type == JV_OBJ && this_val->node)
				return JsElemV(ji, this_val->node); // shallow alias (no deep copy)
			return JsNullV(ji);
		case JSN_EL_INSBEFORE: // approximate: append (ref-node ordering not honored)
			w = JsArgOr(ji, args, argc, 0);
			if (this_val->type == JV_OBJ && this_val->node &&
				w && w->type == JV_OBJ && w->node)
				JsNodeAppend(ji, this_val->node, w->node);
			return w;
		case JSN_EL_RECT: // no layout coords in the JS layer: a zeroed DOMRect
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "x", JsNumV(ji, 0));
			JsPropSet(ji, v, "y", JsNumV(ji, 0));
			JsPropSet(ji, v, "top", JsNumV(ji, 0));
			JsPropSet(ji, v, "left", JsNumV(ji, 0));
			JsPropSet(ji, v, "right", JsNumV(ji, 0));
			JsPropSet(ji, v, "bottom", JsNumV(ji, 0));
			JsPropSet(ji, v, "width", JsNumV(ji, 0));
			JsPropSet(ji, v, "height", JsNumV(ji, 0));
			return v;
		case JSN_LOC_ASSIGN: // location.assign(url) / location.replace(url)
			ji->navigate = JsStrDup(ji, JsToStr(ji, JsArgOr(ji, args, argc, 0)));
			return JsUndefV(ji);
		case JSN_LOC_RELOAD: // location.reload()
			ji->navigate = JsStrDup(ji, ji->url);
			return JsUndefV(ji);
		case JSN_LS_GET:
			s = JsToStr(ji, JsArgOr(ji, args, argc, 0));
			for (i = 0; i < js_ls_count; i++)
				if (!StrCompare(js_ls_keys[i], s))
					return JsStrV(ji, js_ls_vals[i]);
			return JsNullV(ji);
		case JSN_LS_SET:
			s	= JsToStr(ji, JsArgOr(ji, args, argc, 0));
			sep	= JsToStr(ji, JsArgOr(ji, args, argc, 1));
			if (StrLen(s) > 62)
				return JsUndefV(ji);
			b = -1;
			for (i = 0; i < js_ls_count; i++)
				if (!StrCompare(js_ls_keys[i], s))
					b = i;
			if (b < 0)
			{
				if (js_ls_count >= JS_LS_MAX)
					return JsUndefV(ji);
				b = js_ls_count++;
				StrCopy(js_ls_keys[b], s);
			}
			len = StrLen(sep);
			if (len > 510)
				len = 510;
			MemCopy(js_ls_vals[b], sep, len);
			js_ls_vals[b][len] = 0;
			return JsUndefV(ji);
		case JSN_LS_REMOVE:
			s = JsToStr(ji, JsArgOr(ji, args, argc, 0));
			for (i = 0; i < js_ls_count; i++)
				if (!StrCompare(js_ls_keys[i], s))
				{
					if (i != js_ls_count - 1)
					{
						StrCopy(js_ls_keys[i], js_ls_keys[js_ls_count - 1]);
						StrCopy(js_ls_vals[i], js_ls_vals[js_ls_count - 1]);
					}
					js_ls_count--;
					return JsUndefV(ji);
				}
			return JsUndefV(ji);
		case JSN_LS_CLEAR:
			js_ls_count = 0;
			return JsUndefV(ji);
		case JSN_RE_TEST: // stub regex: no engine yet, never matches
			return JsBoolV(ji, FALSE);
		case JSN_RE_EXEC:
			return JsNullV(ji);
		case JSN_ERROR_CTOR: // Error/TypeError/... -> object with message
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "name", JsStrV(ji, "Error"));
			if (argc)
				JsPropSet(ji, v, "message", JsStrV(ji, JsToStr(ji, args[0])));
			else
				JsPropSet(ji, v, "message", JsStrV(ji, ""));
			JsPropSet(ji, v, "stack", JsStrV(ji, ""));
			return v;
		case JSN_REGEXP_CTOR: // new RegExp(pat, flags) -> stub regex object
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "source", JsStrV(ji, JsToStr(ji, JsArgOr(ji, args, argc, 0))));
			JsPropSet(ji, v, "lastIndex", JsNumV(ji, 0));
			JsPropSet(ji, v, "test", JsNativeV(ji, JSN_RE_TEST));
			JsPropSet(ji, v, "exec", JsNativeV(ji, JSN_RE_EXEC));
			return v;
		case JSN_MAP_CTOR:
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "_ent", JsArrV(ji)); // entries: array of [key, value]
			JsPropSet(ji, v, "size", JsNumV(ji, 0));
			JsPropSet(ji, v, "get",		JsNativeV(ji, JSN_MAP_GET));
			JsPropSet(ji, v, "set",		JsNativeV(ji, JSN_MAP_SET));
			JsPropSet(ji, v, "has",		JsNativeV(ji, JSN_MAP_HAS));
			JsPropSet(ji, v, "delete",	JsNativeV(ji, JSN_MAP_DEL));
			JsPropSet(ji, v, "forEach",	JsNativeV(ji, JSN_MAP_FOREACH));
			JsPropSet(ji, v, "clear",	JsNativeV(ji, JSN_MAP_CLEAR));
			return v;
		case JSN_MAP_GET:
		case JSN_MAP_HAS:
		case JSN_MAP_DEL:
			w = JsPropGet(this_val, "_ent");
			if (!w || w->type != JV_ARR)
			{
				if (id == JSN_MAP_GET)
					return JsUndefV(ji);
				return JsBoolV(ji, FALSE);
			}
			StrCopy(buf, JsToStr(ji, JsArgOr(ji, args, argc, 0)));
			for (i = 0; i < w->count; i++)
			{
				pr = w->items[i];
				if (pr && pr->type == JV_ARR && pr->count >= 2 &&
					!StrCompare(buf, JsToStr(ji, pr->items[0])))
				{
					if (id == JSN_MAP_GET)
						return pr->items[1];
					if (id == JSN_MAP_HAS)
						return JsBoolV(ji, TRUE);
					for (b = i; b < w->count - 1; b++)
						w->items[b] = w->items[b + 1];
					w->count--;
					JsPropSet(ji, this_val, "size", JsNumV(ji, w->count));
					return JsBoolV(ji, TRUE);
				}
			}
			if (id == JSN_MAP_GET)
				return JsUndefV(ji);
			return JsBoolV(ji, FALSE);
		case JSN_MAP_SET:
			w = JsPropGet(this_val, "_ent");
			if (!w || w->type != JV_ARR)
				return this_val;
			StrCopy(buf, JsToStr(ji, JsArgOr(ji, args, argc, 0)));
			for (i = 0; i < w->count; i++)
			{
				pr = w->items[i];
				if (pr && pr->type == JV_ARR && pr->count >= 2 &&
					!StrCompare(buf, JsToStr(ji, pr->items[0])))
				{
					pr->items[1] = JsArgOr(ji, args, argc, 1);
					return this_val;
				}
			}
			v = JsArrV(ji);
			JsArrPush(ji, v, JsArgOr(ji, args, argc, 0));
			JsArrPush(ji, v, JsArgOr(ji, args, argc, 1));
			JsArrPush(ji, w, v);
			JsPropSet(ji, this_val, "size", JsNumV(ji, w->count));
			return this_val; // chainable
		case JSN_MAP_FOREACH:
			w = JsPropGet(this_val, "_ent");
			if (!w || w->type != JV_ARR || !argc)
				return JsUndefV(ji);
			for (i = 0; i < w->count; i++)
			{
				pr = w->items[i];
				if (pr && pr->type == JV_ARR && pr->count >= 2)
				{
					pa[0] = pr->items[1]; // value
					pa[1] = pr->items[0]; // key
					JsCall(ji, args[0], NULL, pa, 2);
				}
			}
			return JsUndefV(ji);
		case JSN_MAP_CLEAR: // shared by Set
			JsPropSet(ji, this_val, "_ent", JsArrV(ji));
			JsPropSet(ji, this_val, "size", JsNumV(ji, 0));
			return JsUndefV(ji);
		case JSN_SET_CTOR:
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "_ent", JsArrV(ji)); // entries: array of values
			JsPropSet(ji, v, "size", JsNumV(ji, 0));
			JsPropSet(ji, v, "add",		JsNativeV(ji, JSN_SET_ADD));
			JsPropSet(ji, v, "has",		JsNativeV(ji, JSN_SET_HAS));
			JsPropSet(ji, v, "delete",	JsNativeV(ji, JSN_SET_DEL));
			JsPropSet(ji, v, "forEach",	JsNativeV(ji, JSN_SET_FOREACH));
			JsPropSet(ji, v, "clear",	JsNativeV(ji, JSN_MAP_CLEAR));
			return v;
		case JSN_SET_ADD:
			w = JsPropGet(this_val, "_ent");
			if (!w || w->type != JV_ARR)
				return this_val;
			StrCopy(buf, JsToStr(ji, JsArgOr(ji, args, argc, 0)));
			for (i = 0; i < w->count; i++)
				if (!StrCompare(buf, JsToStr(ji, w->items[i])))
					return this_val; // already a member
			JsArrPush(ji, w, JsArgOr(ji, args, argc, 0));
			JsPropSet(ji, this_val, "size", JsNumV(ji, w->count));
			return this_val;
		case JSN_SET_HAS:
		case JSN_SET_DEL:
			w = JsPropGet(this_val, "_ent");
			if (!w || w->type != JV_ARR)
				return JsBoolV(ji, FALSE);
			StrCopy(buf, JsToStr(ji, JsArgOr(ji, args, argc, 0)));
			for (i = 0; i < w->count; i++)
				if (!StrCompare(buf, JsToStr(ji, w->items[i])))
				{
					if (id == JSN_SET_HAS)
						return JsBoolV(ji, TRUE);
					for (b = i; b < w->count - 1; b++)
						w->items[b] = w->items[b + 1];
					w->count--;
					JsPropSet(ji, this_val, "size", JsNumV(ji, w->count));
					return JsBoolV(ji, TRUE);
				}
			return JsBoolV(ji, FALSE);
		case JSN_SET_FOREACH:
			w = JsPropGet(this_val, "_ent");
			if (!w || w->type != JV_ARR || !argc)
				return JsUndefV(ji);
			for (i = 0; i < w->count; i++)
			{
				pa[0] = w->items[i];
				pa[1] = w->items[i];
				JsCall(ji, args[0], NULL, pa, 2);
			}
			return JsUndefV(ji);
		case JSN_AUDIO_CTOR: // new Audio(url) -> media element (subset)
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "src", JsStrV(ji, JsToStr(ji, JsArgOr(ji, args, argc, 0))));
			JsPropSet(ji, v, "volume", JsNumV(ji, 1));
			JsPropSet(ji, v, "paused", JsBoolV(ji, TRUE));
			JsPropSet(ji, v, "loop", JsBoolV(ji, FALSE));
			JsPropSet(ji, v, "currentTime", JsNumV(ji, 0));
			JsPropSet(ji, v, "play",	JsNativeV(ji, JSN_AUDIO_PLAY));
			JsPropSet(ji, v, "pause",	JsNativeV(ji, JSN_AUDIO_PAUSE));
			JsPropSet(ji, v, "load",	JsNativeV(ji, JSN_NOOP_UNDEF));
			JsPropSet(ji, v, "canPlayType", JsNativeV(ji, JSN_NOOP_UNDEF));
			JsPropSet(ji, v, "addEventListener",	JsNativeV(ji, JSN_NOOP_UNDEF));
			JsPropSet(ji, v, "removeEventListener",	JsNativeV(ji, JSN_NOOP_UNDEF));
			return v;
		case JSN_AUDIO_PLAY: // element.play(): fetch+decode+stream to AC97
			w = JsPropGet(this_val, "src");
			if (w)
			{
				JsAbsUrl(ji->url, JsToStr(ji, w), buf);
				if (*buf)
					ZAudioPlay(buf);
			}
			JsPropSet(ji, this_val, "paused", JsBoolV(ji, FALSE));
			return JsUndefV(ji); // (real play() returns a Promise; undefined here)
		case JSN_AUDIO_PAUSE:
			ZAudioStop();
			JsPropSet(ji, this_val, "paused", JsBoolV(ji, TRUE));
			return JsUndefV(ji);
		case JSN_NOOP_UNDEF: // generic stub method
			return JsUndefV(ji);
		case JSN_NOOP_ARR:
			return JsArrV(ji);
		case JSN_OBSERVER_CTOR: // observers: constructable, never fire
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "observe",		JsNativeV(ji, JSN_NOOP_UNDEF));
			JsPropSet(ji, v, "unobserve",	JsNativeV(ji, JSN_NOOP_UNDEF));
			JsPropSet(ji, v, "disconnect",	JsNativeV(ji, JSN_NOOP_UNDEF));
			JsPropSet(ji, v, "takeRecords",	JsNativeV(ji, JSN_NOOP_ARR));
			return v;
		case JSN_SYMBOL:
			js_sym_n++;
			StrPrint(buf, "@@sym%d", js_sym_n);
			return JsStrV(ji, buf);
		case JSN_MATCHMEDIA:
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "matches", JsBoolV(ji, FALSE));
			JsPropSet(ji, v, "media", JsStrV(ji, JsToStr(ji, JsArgOr(ji, args, argc, 0))));
			JsPropSet(ji, v, "addListener",			JsNativeV(ji, JSN_NOOP_UNDEF));
			JsPropSet(ji, v, "removeListener",		JsNativeV(ji, JSN_NOOP_UNDEF));
			JsPropSet(ji, v, "addEventListener",	JsNativeV(ji, JSN_NOOP_UNDEF));
			JsPropSet(ji, v, "removeEventListener",	JsNativeV(ji, JSN_NOOP_UNDEF));
			return v;
		case JSN_GETCOMPUTED:
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "getPropertyValue", JsNativeV(ji, JSN_CSS_GETPROP));
			return v;
		case JSN_CSS_GETPROP:
			return JsStrV(ji, "");
		case JSN_ABORT_CTOR:
			v = JsValNew(ji, JV_OBJ);
			w = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, w, "aborted", JsBoolV(ji, FALSE));
			JsPropSet(ji, w, "addEventListener", JsNativeV(ji, JSN_NOOP_UNDEF));
			JsPropSet(ji, v, "signal", w);
			JsPropSet(ji, v, "abort", JsNativeV(ji, JSN_NOOP_UNDEF));
			return v;
		case JSN_EVENT_CTOR: // Event / CustomEvent
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "type", JsStrV(ji, JsToStr(ji, JsArgOr(ji, args, argc, 0))));
			JsPropSet(ji, v, "preventDefault",	JsNativeV(ji, JSN_NOOP_UNDEF));
			JsPropSet(ji, v, "stopPropagation",	JsNativeV(ji, JSN_NOOP_UNDEF));
			return v;
		case JSN_DATE_CTOR:
			v = JsValNew(ji, JV_OBJ);
			if (argc)
				JsPropSet(ji, v, "_t", JsNumV(ji, JsToNum(args[0])));
			else
				JsPropSet(ji, v, "_t", JsNumV(ji, tS * 1000.0));
			JsPropSet(ji, v, "getTime",		JsNativeV(ji, JSN_DATE_GETTIME));
			JsPropSet(ji, v, "valueOf",		JsNativeV(ji, JSN_DATE_GETTIME));
			JsPropSet(ji, v, "getFullYear",	JsNativeV(ji, JSN_DATE_GETFULLYEAR));
			JsPropSet(ji, v, "getMonth",	JsNativeV(ji, JSN_DATE_GETMONTH));
			JsPropSet(ji, v, "getDate",		JsNativeV(ji, JSN_DATE_GETDATE));
			JsPropSet(ji, v, "getDay",		JsNativeV(ji, JSN_DATE_GETDAY));
			JsPropSet(ji, v, "getHours",	JsNativeV(ji, JSN_DATE_GETHOURS));
			JsPropSet(ji, v, "getMinutes",	JsNativeV(ji, JSN_DATE_GETMIN));
			JsPropSet(ji, v, "getSeconds",	JsNativeV(ji, JSN_DATE_GETSEC));
			JsPropSet(ji, v, "toISOString",	JsNativeV(ji, JSN_DATE_TOISO));
			return v;
		case JSN_DATE_GETTIME:
			w = JsPropGet(this_val, "_t");
			if (w)
				return w;
			return JsNumV(ji, 0);
		case JSN_DATE_GETFULLYEAR:
		case JSN_DATE_GETMONTH:
		case JSN_DATE_GETDATE:
		case JSN_DATE_GETDAY:
		case JSN_DATE_GETHOURS:
		case JSN_DATE_GETMIN:
		case JSN_DATE_GETSEC:
		case JSN_DATE_TOISO:
			// calendar getters report the CURRENT wall clock (RTC): right for the
			// dominant `new Date()` uses; a Date built from a ms argument does not
			// shift them (no epoch<->civil math yet).
			Date2Struct(&ds, Now);
			if (id == JSN_DATE_GETFULLYEAR)
				return JsNumV(ji, ds.year);
			if (id == JSN_DATE_GETMONTH)
				return JsNumV(ji, ds.mon - 1); // JS months are 0-based
			if (id == JSN_DATE_GETDATE)
				return JsNumV(ji, ds.day_of_mon);
			if (id == JSN_DATE_GETDAY)
				return JsNumV(ji, ds.day_of_week);
			if (id == JSN_DATE_GETHOURS)
				return JsNumV(ji, ds.hour);
			if (id == JSN_DATE_GETMIN)
				return JsNumV(ji, ds.min);
			if (id == JSN_DATE_GETSEC)
				return JsNumV(ji, ds.sec);
			StrPrint(buf, "%04d-%02d-%02dT%02d:%02d:%02dZ",
					 ds.year, ds.mon, ds.day_of_mon, ds.hour, ds.min, ds.sec);
			return JsStrV(ji, buf);
		case JSN_ARR_REDUCE:
			if (this_val->type != JV_ARR || !argc)
				return JsUndefV(ji);
			if (argc > 1)
			{
				w = args[1];
				i = 0;
			}
			else
			{
				if (!this_val->count)
					return JsUndefV(ji);
				w = this_val->items[0];
				i = 1;
			}
			while (i < this_val->count && !ji->has_err)
			{
				pa[0] = w;
				pa[1] = this_val->items[i];
				w = JsCall(ji, args[0], NULL, pa, 2);
				i++;
			}
			return w;
		case JSN_ARR_REVERSE:
			if (this_val->type != JV_ARR)
				return this_val;
			for (i = 0; i < this_val->count / 2; i++)
			{
				v = this_val->items[i];
				this_val->items[i] = this_val->items[this_val->count - 1 - i];
				this_val->items[this_val->count - 1 - i] = v;
			}
			return this_val;
		case JSN_ARR_SORT:
			if (this_val->type != JV_ARR)
				return this_val;
			for (i = 1; i < this_val->count && !ji->has_err; i++)
			{ // insertion sort; comparator if given, else lexicographic
				b = i;
				while (b > 0)
				{
					a = 0;
					if (argc && (args[0]->type == JV_FUNC || args[0]->type == JV_NATIVE))
					{
						pa[0] = this_val->items[b - 1];
						pa[1] = this_val->items[b];
						if (JsToNum(JsCall(ji, args[0], NULL, pa, 2)) > 0)
							a = 1;
					}
					else if (StrCompare(JsToStr(ji, this_val->items[b - 1]),
										JsToStr(ji, this_val->items[b])) > 0)
						a = 1;
					if (!a)
						break;
					v = this_val->items[b - 1];
					this_val->items[b - 1] = this_val->items[b];
					this_val->items[b] = v;
					b--;
				}
			}
			return this_val;
		case JSN_STR_REPEAT:
			if (this_val->type != JV_STR)
				return this_val;
			a	= JsToNum(JsArgOr(ji, args, argc, 0));
			len	= StrLen(this_val->str);
			if (a < 0)
				a = 0;
			b = 0;
			while (a > 0 && b + len < 1020)
			{
				MemCopy(buf + b, this_val->str, len);
				b += len;
				a--;
			}
			buf[b] = 0;
			return JsStrV(ji, buf);
		case JSN_STR_PADSTART:
		case JSN_STR_PADEND:
			if (this_val->type != JV_STR)
				return this_val;
			a = JsToNum(JsArgOr(ji, args, argc, 0));
			if (a > 1020)
				a = 1020;
			len = StrLen(this_val->str);
			if (a <= len)
				return this_val;
			sep = " ";
			if (argc > 1)
				sep = JsToStr(ji, args[1]);
			if (!*sep)
				sep = " ";
			i = 0;
			if (id == JSN_STR_PADEND)
			{
				MemCopy(buf, this_val->str, len);
				b = len;
				while (b < a)
				{
					if (!sep[i])
						i = 0;
					buf[b++] = sep[i++];
				}
			}
			else
			{
				b = 0;
				while (b < a - len)
				{
					if (!sep[i])
						i = 0;
					buf[b++] = sep[i++];
				}
				MemCopy(buf + b, this_val->str, len);
				b += len;
			}
			buf[b] = 0;
			return JsStrV(ji, buf);
		case JSN_STR_SUBSTR:
			if (this_val->type != JV_STR)
				return this_val;
			len = StrLen(this_val->str);
			a = JsToNum(JsArgOr(ji, args, argc, 0));
			if (a < 0)
				a = len + a;
			if (a < 0)
				a = 0;
			if (a > len)
				a = len;
			b = len - a;
			if (argc > 1)
				b = JsToNum(args[1]);
			if (b < 0)
				b = 0;
			if (b > len - a)
				b = len - a;
			if (b > 1020)
				b = 1020;
			MemCopy(buf, this_val->str + a, b);
			buf[b] = 0;
			return JsStrV(ji, buf);
		case JSN_PARSEINT:
			s = JsToStr(ji, JsArgOr(ji, args, argc, 0));
			while (*s == ' ' || *s == '\t')
				s++;
			a = 10;
			if (argc > 1)
				a = JsToNum(args[1]);
			if (a == 16 || (s[0] == '0' && (s[1] == 'x' || s[1] == 'X')))
			{
				if (s[0] == '0' && (s[1] == 'x' || s[1] == 'X'))
					s += 2;
				return JsNumV(ji, Str2I64(s, 16));
			}
			return JsNumV(ji, Str2I64(s));
		case JSN_PARSEFLOAT:
			return JsNumV(ji, Str2F64(JsToStr(ji, JsArgOr(ji, args, argc, 0))));
		case JSN_STRING:
			return JsStrV(ji, JsToStr(ji, JsArgOr(ji, args, argc, 0)));
		case JSN_NUMBER:
			return JsNumV(ji, JsToNum(JsArgOr(ji, args, argc, 0)));
		case JSN_ISNAN:
			return JsBoolV(ji, FALSE); // parse failures read as 0 here
		case JSN_DATE_NOW:
			return JsNumV(ji, tS * 1000.0);
		case JSN_SETTIMEOUT:
		case JSN_SETINTERVAL:
			v = JsArgOr(ji, args, argc, 0);
			if (v->type == JV_FUNC || v->type == JV_NATIVE)
			{
				ms = 0.0;
				if (argc > 1)
					ms = JsToNum(args[1]);
				t = JsTimerAdd(ji, v, NULL, ms, id == JSN_SETINTERVAL, FALSE);
				return JsNumV(ji, t->id);
			}
			return JsNumV(ji, 0);
		case JSN_CLEARTIMER:
			JsTimerClear(ji, JsToNum(JsArgOr(ji, args, argc, 0)));
			return JsUndefV(ji);
		case JSN_XHR_NEW:
			v = JsValNew(ji, JV_OBJ);
			v->native_id = JSO_XHR;
			JsPropSet(ji, v, "readyState", JsNumV(ji, 0));
			JsPropSet(ji, v, "status", JsNumV(ji, 0));
			JsPropSet(ji, v, "responseText", JsStrV(ji, ""));
			return v;
		case JSN_PROMISE_CTOR:
			pr = JsPromiseNew(ji);
			if (argc && (args[0]->type == JV_FUNC || args[0]->type == JV_NATIVE))
			{ // run the executor now with bound resolve/reject
				resv = JsNativeV(ji, JSN_PROMISE_RESOLVE);
				resv->proto = pr;
				rej = JsNativeV(ji, JSN_PROMISE_REJECT);
				rej->proto = pr;
				pa[0] = resv;
				pa[1] = rej;
				JsCall(ji, args[0], NULL, pa, 2);
			}
			return pr;
		case JSN_PROMISE_RESOLVE:
			if (self && self->proto)
				JsPromiseSettle(ji, self->proto, JsArgOr(ji, args, argc, 0), FALSE);
			return JsUndefV(ji);
		case JSN_PROMISE_REJECT:
			if (self && self->proto)
				JsPromiseSettle(ji, self->proto, JsArgOr(ji, args, argc, 0), TRUE);
			return JsUndefV(ji);
		case JSN_PROMISE_SRESOLVE:
			pr = JsPromiseNew(ji);
			JsPromiseSettle(ji, pr, JsArgOr(ji, args, argc, 0), FALSE);
			return pr;
		case JSN_FETCH:
			return JsFetch(ji, args, argc);
		case JSN_JSON_PARSE:
			s = JsToStr(ji, JsArgOr(ji, args, argc, 0));
			return JsJsonParseVal(ji, &s, 0);
		case JSN_JSON_STR:
			bb = MAlloc(16384);
			i = 0;
			bb[0] = 0;
			JsJsonStringify(ji, JsArgOr(ji, args, argc, 0), bb, &i, 16384, 0);
			v = JsStrV(ji, bb);
			Free(bb);
			return v;
		case JSN_DOC_CREATE_EL:
			nd2 = ZNodeNew(ZH_ELEM, NULL);
			if (!nd2)
				return JsNullV(ji);
			s = JsToStr(ji, JsArgOr(ji, args, argc, 0));
			i = 0;
			while (s[i] && i < 15)
			{
				nd2->tag[i] = ZChLower(s[i]);
				i++;
			}
			nd2->tag[i] = 0;
			return JsElemV(ji, nd2);
		case JSN_DOC_CREATE_TX:
			nd2 = ZNodeNew(ZH_TEXT, NULL);
			if (!nd2)
				return JsNullV(ji);
			nd2->text = StrNew(JsToStr(ji, JsArgOr(ji, args, argc, 0)));
			return JsElemV(ji, nd2);
		case JSN_OBJ_KEYS:
			v = JsArrV(ji);
			w = JsArgOr(ji, args, argc, 0);
			if (w->type == JV_OBJ)
			{
				prp = w->props;
				while (prp)
				{
					JsArrPush(ji, v, JsStrV(ji, prp->name));
					prp = prp->next;
				}
			}
			return v;
		case JSN_OBJ_ASSIGN:
			if (!argc)
				return JsUndefV(ji);
			v = args[0];
			for (a = 1; a < argc; a++)
			{
				if (args[a]->type == JV_OBJ && v->type == JV_OBJ)
				{
					prp = args[a]->props;
					while (prp)
					{
						JsPropSet(ji, v, prp->name, prp->val(CJsVal *));
						prp = prp->next;
					}
				}
			}
			return v;
		case JSN_OBJ_VALUES:
			v = JsArrV(ji);
			w = JsArgOr(ji, args, argc, 0);
			if (w->type == JV_OBJ)
			{
				prp = w->props;
				while (prp)
				{
					JsArrPush(ji, v, prp->val(CJsVal *));
					prp = prp->next;
				}
			}
			return v;
		case JSN_OBJ_ENTRIES:
			v = JsArrV(ji);
			w = JsArgOr(ji, args, argc, 0);
			if (w->type == JV_OBJ)
			{
				prp = w->props;
				while (prp)
				{ // each entry is a [key, value] pair array
					pr = JsArrV(ji);
					JsArrPush(ji, pr, JsStrV(ji, prp->name));
					JsArrPush(ji, pr, prp->val(CJsVal *));
					JsArrPush(ji, v, pr);
					prp = prp->next;
				}
			}
			return v;
		case JSN_OBJ_FROMENTRIES:
			v = JsValNew(ji, JV_OBJ);
			w = JsArgOr(ji, args, argc, 0);
			if (w->type == JV_ARR)
			{
				for (a = 0; a < w->count; a++)
				{
					pr = w->items[a];
					if (pr && pr->type == JV_ARR && pr->count >= 2)
						JsPropSet(ji, v, JsToStr(ji, pr->items[0]), pr->items[1]);
				}
			}
			return v;
		case JSN_OBJ_DEFINEPROP:
			v = JsArgOr(ji, args, argc, 0); // target
			w = JsArgOr(ji, args, argc, 2); // descriptor
			if (v->type == JV_OBJ && w->type == JV_OBJ)
			{
				s	= JsToStr(ji, JsArgOr(ji, args, argc, 1)); // key
				pr	= JsPropGet(w, "value");
				if (!pr)
				{ // accessor descriptor: run the getter once, store its result
					rej = JsPropGet(w, "get");
					if (rej && (rej->type == JV_FUNC || rej->type == JV_NATIVE))
						pr = JsCall(ji, rej, v, NULL, 0);
				}
				if (!pr)
					pr = JsUndefV(ji);
				JsPropSet(ji, v, s, pr);
			}
			return v;
		case JSN_OBJ_DEFINEPROPS:
			v = JsArgOr(ji, args, argc, 0);
			w = JsArgOr(ji, args, argc, 1); // { key: descriptor, ... }
			if (v->type == JV_OBJ && w->type == JV_OBJ)
			{
				prp = w->props;
				while (prp)
				{
					pr = prp->val(CJsVal *);
					if (pr && pr->type == JV_OBJ)
					{
						resv = JsPropGet(pr, "value");
						if (!resv)
						{
							rej = JsPropGet(pr, "get");
							if (rej && (rej->type == JV_FUNC || rej->type == JV_NATIVE))
								resv = JsCall(ji, rej, v, NULL, 0);
						}
						if (resv)
							JsPropSet(ji, v, prp->name, resv);
					}
					prp = prp->next;
				}
			}
			return v;
		case JSN_OBJ_CREATE:
			v = JsValNew(ji, JV_OBJ);
			w = JsArgOr(ji, args, argc, 0);
			if (w->type == JV_OBJ)
				v->proto = w; // null proto (Object.create(null)) leaves it NULL
			w = JsArgOr(ji, args, argc, 1);
			if (w->type == JV_OBJ)
			{
				prp = w->props;
				while (prp)
				{
					pr = prp->val(CJsVal *);
					if (pr && pr->type == JV_OBJ)
					{
						resv = JsPropGet(pr, "value");
						if (resv)
							JsPropSet(ji, v, prp->name, resv);
					}
					prp = prp->next;
				}
			}
			return v;
		case JSN_OBJ_GETPROTO:
			w = JsArgOr(ji, args, argc, 0);
			if (w->type == JV_OBJ && w->proto)
				return w->proto;
			return JsNullV(ji);
		case JSN_OBJ_SETPROTO:
			v = JsArgOr(ji, args, argc, 0);
			w = JsArgOr(ji, args, argc, 1);
			if (v->type == JV_OBJ)
			{
				if (w->type == JV_OBJ)
					v->proto = w;
				else
					v->proto = NULL;
			}
			return v;
		case JSN_OBJ_GETDESC:
			w	 = JsArgOr(ji, args, argc, 0);
			resv = NULL;
			if (w->type == JV_OBJ)
				resv = JsPropGet(w, JsToStr(ji, JsArgOr(ji, args, argc, 1)));
			if (!resv)
				return JsUndefV(ji);
			v = JsValNew(ji, JV_OBJ);
			JsPropSet(ji, v, "value", resv);
			JsPropSet(ji, v, "writable", JsBoolV(ji, TRUE));
			JsPropSet(ji, v, "enumerable", JsBoolV(ji, TRUE));
			JsPropSet(ji, v, "configurable", JsBoolV(ji, TRUE));
			return v;
		case JSN_OBJ_FREEZE:
			return JsArgOr(ji, args, argc, 0); // no enforcement; return the object
		case JSN_OBJ_ISFROZEN:
			return JsBoolV(ji, FALSE); // we never freeze, so all three report false
		case JSN_ARR_ISARR:
			return JsBoolV(ji, JsArgOr(ji, args, argc, 0)->type == JV_ARR);
		case JSN_MATH_FLOOR:
			return JsNumV(ji, Floor(JsToNum(JsArgOr(ji, args, argc, 0))));
		case JSN_MATH_CEIL:
			return JsNumV(ji, Ceil(JsToNum(JsArgOr(ji, args, argc, 0))));
		case JSN_MATH_ROUND:
			return JsNumV(ji, Round(JsToNum(JsArgOr(ji, args, argc, 0))));
		case JSN_MATH_ABS:
			return JsNumV(ji, Abs(JsToNum(JsArgOr(ji, args, argc, 0))));
		case JSN_MATH_SQRT:
			return JsNumV(ji, Sqrt(JsToNum(JsArgOr(ji, args, argc, 0))));
		case JSN_MATH_POW:
			return JsNumV(ji, Pow(JsToNum(JsArgOr(ji, args, argc, 0)),
								  JsToNum(JsArgOr(ji, args, argc, 1))));
		case JSN_MATH_RANDOM:
			return JsNumV(ji, (RandU32 & 0xFFFFFF) / 16777216.0);
		case JSN_MATH_MAX:
		case JSN_MATH_MIN:
			if (!argc)
				return JsNumV(ji, 0);
			best = JsToNum(args[0]);
			for (i = 1; i < argc; i++)
			{
				if (id == JSN_MATH_MAX && JsToNum(args[i]) > best)
					best = JsToNum(args[i]);
				if (id == JSN_MATH_MIN && JsToNum(args[i]) < best)
					best = JsToNum(args[i]);
			}
			return JsNumV(ji, best);
	}

	if (!this_val)
		this_val = JsUndefV(ji);

	switch (id)
	{
		case JSN_STR_CHARAT:
			if (this_val->type != JV_STR)
				return JsStrV(ji, "");
			i = JsToNum(JsArgOr(ji, args, argc, 0));
			if (0 <= i < StrLen(this_val->str))
			{
				buf[0] = this_val->str[i];
				buf[1] = 0;
				return JsStrV(ji, buf);
			}
			return JsStrV(ji, "");
		case JSN_STR_INDEXOF:
			if (this_val->type != JV_STR)
				return JsNumV(ji, -1);
			s = StrFind(JsToStr(ji, JsArgOr(ji, args, argc, 0)), this_val->str);
			if (s)
				return JsNumV(ji, s - this_val->str);
			return JsNumV(ji, -1);
		case JSN_STR_SUBSTRING:
		case JSN_STR_SLICE:
			if (this_val->type != JV_STR)
				return JsStrV(ji, "");
			len = StrLen(this_val->str);
			a = JsToNum(JsArgOr(ji, args, argc, 0));
			if (argc > 1)
				b = JsToNum(args[1]);
			else
				b = len;
			if (id == JSN_STR_SLICE)
			{
				if (a < 0)
					a += len;
				if (b < 0)
					b += len;
			}
			if (a < 0)	a = 0;
			if (b < 0)	b = 0;
			if (a > len) a = len;
			if (b > len) b = len;
			if (id == JSN_STR_SUBSTRING && a > b)
			{
				i = a;
				a = b;
				b = i;
			}
			if (b <= a)
				return JsStrV(ji, "");
			if (b - a > 1000)
				b = a + 1000;
			MemCopy(buf, this_val->str + a, b - a);
			buf[b - a] = 0;
			return JsStrV(ji, buf);
		case JSN_STR_TOUPPER:
		case JSN_STR_TOLOWER:
			if (this_val->type != JV_STR)
				return JsStrV(ji, "");
			s = JsStrDup(ji, this_val->str);
			i = 0;
			while (s[i])
			{
				if (id == JSN_STR_TOUPPER)
					s[i] = ToUpper(s[i]);
				else
					s[i] = ZChLower(s[i]);
				i++;
			}
			v = JsValNew(ji, JV_STR);
			v->str = s;
			return v;
		case JSN_ARR_PUSH:
			if (this_val->type != JV_ARR)
				return JsNumV(ji, 0);
			for (i = 0; i < argc; i++)
				JsArrPush(ji, this_val, args[i]);
			return JsNumV(ji, this_val->count);
		case JSN_ARR_JOIN:
			if (this_val->type != JV_ARR)
				return JsStrV(ji, "");
			sep = ",";
			if (argc > 0)
				sep = JsToStr(ji, args[0]);
			len = 1;
			for (i = 0; i < this_val->count; i++)
				len += StrLen(JsToStr(ji, this_val->items[i])) + StrLen(sep);
			s = JsAlloc(ji, len + 1);
			*s = 0;
			for (i = 0; i < this_val->count; i++)
			{
				if (i)
					CatPrint(s, "%s", sep);
				CatPrint(s, "%s", JsToStr(ji, this_val->items[i]));
			}
			v = JsValNew(ji, JV_STR);
			v->str = s;
			return v;
		case JSN_ARR_INDEXOF:
			if (this_val->type != JV_ARR)
				return JsNumV(ji, -1);
			for (i = 0; i < this_val->count; i++)
			{
				if (JsStrictEq(this_val->items[i], JsArgOr(ji, args, argc, 0)))
					return JsNumV(ji, i);
			}
			return JsNumV(ji, -1);
		case JSN_EL_GETATTR:
			if (this_val->type == JV_OBJ && this_val->node)
			{
				s = ZNodeAttr(this_val->node, JsToStr(ji, JsArgOr(ji, args, argc, 0)));
				if (s)
					return JsStrV(ji, s);
			}
			return JsNullV(ji);
		case JSN_EL_SETATTR:
			if (this_val->type == JV_OBJ && this_val->node && argc >= 2)
			{
				ZNodeAttrSet(this_val->node, JsToStr(ji, args[0]), JsToStr(ji, args[1]));
				ji->dom_dirty = TRUE;
			}
			return JsUndefV(ji);
		case JSN_EL_ADDLISTEN:
			if (this_val->type == JV_OBJ && argc >= 2)
			{
				node = this_val->node;
				if (!node)
					node = ji->dom_root; // document/window listeners
				JsListenerAdd(ji, node, JsToStr(ji, args[0]), args[1], FALSE);
			}
			return JsUndefV(ji);
		case JSN_EL_REMLISTEN:
			if (this_val->type == JV_OBJ && this_val->node && argc >= 2)
				JsListenerRemove(ji, this_val->node, JsToStr(ji, args[0]), args[1]);
			return JsUndefV(ji);
		case JSN_XHR_OPEN:
			if (this_val->type == JV_OBJ)
			{
				JsPropSet(ji, this_val, "_method",
						  JsStrV(ji, JsToStr(ji, JsArgOr(ji, args, argc, 0))));
				JsPropSet(ji, this_val, "_url",
						  JsStrV(ji, JsToStr(ji, JsArgOr(ji, args, argc, 1))));
				b = TRUE; // async unless the 3rd arg is explicitly false
				if (argc > 2 && !JsToBool(args[2]))
					b = FALSE;
				JsPropSet(ji, this_val, "_async", JsBoolV(ji, b));
				JsPropSet(ji, this_val, "readyState", JsNumV(ji, 1));
			}
			return JsUndefV(ji);
		case JSN_XHR_SEND:
			JsXhrSend(ji, this_val, JsArgOr(ji, args, argc, 0));
			return JsUndefV(ji);
		case JSN_XHR_SETREQHDR:
			return JsUndefV(ji); // request headers not threaded through HttpGet yet
		case JSN_XHR_GETALLHDR:
			v = JsPropGet(this_val, "_respHeaders");
			if (v)
				return v;
			return JsStrV(ji, "");
		case JSN_XHR_GETHDR:
			return JsNullV(ji); // minimal: no single-header lookup yet
		case JSN_EVT_NOOP:
			return JsUndefV(ji);
		case JSN_PROMISE_THEN:
			if (this_val->native_id == JSO_PROMISE)
			{
				JsPromiseReact(ji, this_val, JsArgOr(ji, args, argc, 0), FALSE);
				if (argc > 1)
					JsPromiseReact(ji, this_val, args[1], TRUE);
			}
			return this_val;
		case JSN_PROMISE_CATCH:
			if (this_val->native_id == JSO_PROMISE)
				JsPromiseReact(ji, this_val, JsArgOr(ji, args, argc, 0), TRUE);
			return this_val;
		case JSN_PROMISE_FINALLY:
			if (this_val->native_id == JSO_PROMISE)
			{
				JsPromiseReact(ji, this_val, JsArgOr(ji, args, argc, 0), FALSE);
				JsPromiseReact(ji, this_val, JsArgOr(ji, args, argc, 0), TRUE);
			}
			return this_val;
		case JSN_RESP_TEXT:
		case JSN_RESP_JSON:
			pr = JsPromiseNew(ji);
			v = JsPropGet(this_val, "_body");
			if (!v)
				v = JsStrV(ji, "");
			if (id == JSN_RESP_JSON)
			{
				s = JsToStr(ji, v);
				w = JsJsonParseVal(ji, &s, 0);
			}
			else
				w = v;
			JsPromiseSettle(ji, pr, w, FALSE);
			return pr;
		case JSN_EL_APPEND:
			if (this_val->type == JV_OBJ && this_val->node && argc &&
				args[0]->type == JV_OBJ && args[0]->node)
				JsNodeAppend(ji, this_val->node, args[0]->node);
			return JsArgOr(ji, args, argc, 0);
		case JSN_EL_REMOVE_CH:
			if (argc && args[0]->type == JV_OBJ && args[0]->node)
			{
				JsNodeDetach(args[0]->node);
				ji->dom_dirty = TRUE;
			}
			return JsArgOr(ji, args, argc, 0);
		case JSN_EL_REMOVE:
			if (this_val->type == JV_OBJ && this_val->node)
			{
				JsNodeDetach(this_val->node);
				ji->dom_dirty = TRUE;
			}
			return JsUndefV(ji);
		case JSN_QSEL:
		case JSN_QSELALL:
			JsQSelSplit(JsToStr(ji, JsArgOr(ji, args, argc, 0)), qtag, qcls, qid);
			nd2 = NULL;
			if (this_val->type == JV_OBJ)
				nd2 = this_val->node;
			if (!nd2)
				nd2 = ji->dom_root; // document / window scope
			if (id == JSN_QSELALL)
			{
				v = JsArrV(ji);
				JsQSelWalk(nd2, qtag, qcls, qid, ji, v);
				return v;
			}
			nd2 = JsQSelWalk(nd2, qtag, qcls, qid, ji, NULL);
			if (nd2)
				return JsElemV(ji, nd2);
			return JsNullV(ji);
		case JSN_CL_ADD:
		case JSN_CL_REMOVE:
		case JSN_CL_TOGGLE:
			if (this_val->type == JV_OBJ && this_val->node && argc)
			{
				if (id == JSN_CL_ADD)
					i = 0;
				else if (id == JSN_CL_REMOVE)
					i = 1;
				else
					i = 2;
				JsClassListMod(ji, this_val->node, JsToStr(ji, args[0]), i);
			}
			return JsUndefV(ji);
		case JSN_CL_CONTAINS:
			if (this_val->type == JV_OBJ && this_val->node && argc)
				return JsBoolV(ji, JsClassHasTok(ZNodeAttr(this_val->node, "class"),
												 JsToStr(ji, args[0])));
			return JsBoolV(ji, FALSE);
		case JSN_STR_SPLIT:
			v = JsArrV(ji);
			if (this_val->type != JV_STR)
				return v;
			sep = JsToStr(ji, JsArgOr(ji, args, argc, 0));
			s = this_val->str;
			if (!*sep)
			{ // split into characters
				while (*s)
				{
					buf[0] = *s++;
					buf[1] = 0;
					JsArrPush(ji, v, JsStrV(ji, buf));
				}
				return v;
			}
			len = StrLen(sep);
			while (TRUE)
			{
				bb = StrFind(sep, s);
				if (!bb)
				{
					JsArrPush(ji, v, JsStrV(ji, s));
					break;
				}
				i = bb - s;
				if (i > 1020)
					i = 1020;
				MemCopy(buf, s, i);
				buf[i] = 0;
				JsArrPush(ji, v, JsStrV(ji, buf));
				s = bb + len;
			}
			return v;
		case JSN_STR_REPLACE:
			if (this_val->type != JV_STR || argc < 2)
				return this_val;
			sep = JsToStr(ji, args[0]); // pattern (string only, first hit)
			bb = StrFind(sep, this_val->str);
			if (!bb || !*sep)
				return this_val;
			s = MAlloc(StrLen(this_val->str) + StrLen(JsToStr(ji, args[1])) + 2);
			i = bb - this_val->str;
			MemCopy(s, this_val->str, i);
			s[i] = 0;
			CatPrint(s, "%s%s", JsToStr(ji, args[1]), bb + StrLen(sep));
			v = JsStrV(ji, s);
			Free(s);
			return v;
		case JSN_STR_TRIM:
			if (this_val->type != JV_STR)
				return this_val;
			s = this_val->str;
			while (*s == ' ' || *s == '\t' || *s == '\n' || *s == '\r')
				s++;
			len = StrLen(s);
			while (len && (s[len - 1] == ' ' || s[len - 1] == '\t' ||
						   s[len - 1] == '\n' || s[len - 1] == '\r'))
				len--;
			if (len > 1020)
				len = 1020;
			MemCopy(buf, s, len);
			buf[len] = 0;
			return JsStrV(ji, buf);
		case JSN_STR_INCLUDES:
			if (this_val->type != JV_STR)
				return JsBoolV(ji, FALSE);
			return JsBoolV(ji,
				StrFind(JsToStr(ji, JsArgOr(ji, args, argc, 0)), this_val->str) != NULL);
		case JSN_STR_STARTS:
			if (this_val->type != JV_STR)
				return JsBoolV(ji, FALSE);
			sep = JsToStr(ji, JsArgOr(ji, args, argc, 0));
			return JsBoolV(ji, !StrNCompare(this_val->str, sep, StrLen(sep)));
		case JSN_STR_ENDS:
			if (this_val->type != JV_STR)
				return JsBoolV(ji, FALSE);
			sep = JsToStr(ji, JsArgOr(ji, args, argc, 0));
			len = StrLen(this_val->str);
			i = StrLen(sep);
			if (i > len)
				return JsBoolV(ji, FALSE);
			return JsBoolV(ji, !StrCompare(this_val->str + len - i, sep));
		case JSN_STR_CHARCODE:
			if (this_val->type != JV_STR)
				return JsNumV(ji, 0);
			i = JsToNum(JsArgOr(ji, args, argc, 0));
			if (0 <= i < StrLen(this_val->str))
				return JsNumV(ji, this_val->str[i]);
			return JsNumV(ji, 0);
		case JSN_ARR_MAP:
		case JSN_ARR_FILTER:
		case JSN_ARR_FOREACH:
		case JSN_ARR_FIND:
			if (this_val->type != JV_ARR || !argc)
			{
				if (id == JSN_ARR_FIND)
					return JsUndefV(ji);
				if (id == JSN_ARR_FOREACH)
					return JsUndefV(ji);
				return JsArrV(ji);
			}
			v = JsArrV(ji);
			for (i = 0; i < this_val->count && !ji->has_err; i++)
			{
				pa[0] = this_val->items[i];
				pa[1] = JsNumV(ji, i);
				w = JsCall(ji, args[0], NULL, pa, 2);
				if (id == JSN_ARR_MAP)
					JsArrPush(ji, v, w);
				else if (id == JSN_ARR_FILTER)
				{
					if (JsToBool(w))
						JsArrPush(ji, v, this_val->items[i]);
				}
				else if (id == JSN_ARR_FIND)
				{
					if (JsToBool(w))
						return this_val->items[i];
				}
			}
			if (id == JSN_ARR_FOREACH)
				return JsUndefV(ji);
			if (id == JSN_ARR_FIND)
				return JsUndefV(ji);
			return v;
		case JSN_ARR_SLICE:
			v = JsArrV(ji);
			if (this_val->type != JV_ARR)
				return v;
			a = 0;
			b = this_val->count;
			if (argc > 0)
				a = JsToNum(args[0]);
			if (argc > 1)
				b = JsToNum(args[1]);
			if (a < 0)
				a = this_val->count + a;
			if (b < 0)
				b = this_val->count + b;
			if (a < 0)
				a = 0;
			if (b > this_val->count)
				b = this_val->count;
			for (i = a; i < b; i++)
				JsArrPush(ji, v, this_val->items[i]);
			return v;
		case JSN_ARR_CONCAT:
			v = JsArrV(ji);
			if (this_val->type == JV_ARR)
				for (i = 0; i < this_val->count; i++)
					JsArrPush(ji, v, this_val->items[i]);
			for (a = 0; a < argc; a++)
			{
				if (args[a]->type == JV_ARR)
					for (i = 0; i < args[a]->count; i++)
						JsArrPush(ji, v, args[a]->items[i]);
				else
					JsArrPush(ji, v, args[a]);
			}
			return v;
		case JSN_ARR_INCLUDES:
			if (this_val->type != JV_ARR)
				return JsBoolV(ji, FALSE);
			for (i = 0; i < this_val->count; i++)
				if (JsStrictEq(this_val->items[i], JsArgOr(ji, args, argc, 0)))
					return JsBoolV(ji, TRUE);
			return JsBoolV(ji, FALSE);
		case JSN_ARR_POP:
			if (this_val->type != JV_ARR || !this_val->count)
				return JsUndefV(ji);
			this_val->count--;
			return this_val->items[this_val->count];
		case JSN_ARR_SHIFT:
			if (this_val->type != JV_ARR || !this_val->count)
				return JsUndefV(ji);
			v = this_val->items[0];
			for (i = 1; i < this_val->count; i++)
				this_val->items[i - 1] = this_val->items[i];
			this_val->count--;
			return v;
	}

	JsErr(ji, "unknown native");

	return JsUndefV(ji);
}

CJsVal *JsCall(CJsInterp *ji, CJsVal *fn, CJsVal *this_val,
			   CJsVal **args, I64 argc)
{
	CJsEnv	*saved_env, *call_env;
	CJsNode *func, *param;
	CJsVal	*result, *rest;
	I64		 i, k;

	if (ji->has_err)
		return JsUndefV(ji);
	if (ji->depth >= JS_MAX_DEPTH)
	{
		JsErr(ji, "call depth exceeded");
		return JsUndefV(ji);
	}
	ji->depth++;

	if (fn->type == JV_NATIVE)
	{
		result = JsCallNative(ji, fn, fn->native_id, this_val, args, argc);
		ji->depth--;
		return result;
	}
	if (fn->type != JV_FUNC)
	{
		JsErr(ji, "not a function");
		ji->depth--;
		return JsUndefV(ji);
	}

	func = fn->func(CJsNode *);
	call_env = JsAlloc(ji, sizeof(CJsEnv))(CJsEnv *);
	if (fn->fenv)
		call_env->parent = fn->fenv(CJsEnv *); // closure: defining environment
	else
		call_env->parent = ji->genv;

	// bind params in call_env. Set env FIRST so default-value expressions can
	// reference earlier parameters.
	saved_env = ji->env;
	ji->env = call_env;
	if (this_val)
		JsEnvDeclare(ji, call_env, "this", this_val);
	param = func->a;
	i = 0;
	while (param)
	{
		if (param->op == 1)
		{ // rest parameter: collect the remaining args into an array
			rest = JsArrV(ji);
			k = i;
			while (k < argc)
			{
				JsArrPush(ji, rest, args[k]);
				k++;
			}
			JsEnvDeclare(ji, call_env, param->str, rest);
		}
		else if (i < argc && args[i]->type != JV_UNDEF)
			JsEnvDeclare(ji, call_env, param->str, args[i]);
		else if (param->a) // default value (arg missing or explicitly undefined)
			JsEnvDeclare(ji, call_env, param->str, JsEval(ji, param->a));
		else
			JsEnvDeclare(ji, call_env, param->str, JsUndefV(ji));
		param = param->next;
		i++;
	}
	ji->ret_val = NULL;

	JsEval(ji, func->b);

	if (ji->flow == JF_RETURN && ji->ret_val)
		result = ji->ret_val;
	else
		result = JsUndefV(ji);
	if (ji->flow != JF_THROW)
		ji->flow = JF_NORMAL; // a throw crosses the call boundary to try/catch
	ji->env = saved_env;
	ji->depth--;

	return result;
}

/* ---- interpreter lifecycle ---- */

U0 JsGlobalNative(CJsInterp *ji, U8 *name, I64 id)
{
	JsEnvDeclare(ji, ji->genv, name, JsNativeV(ji, id));
}

CJsInterp *JsInterpNew(CZNode *dom_root, U8 *url)
{
	CJsInterp *ji = CAlloc(sizeof(CJsInterp));
	CJsVal	  *math, *console_obj, *date;

	ji->dom_root = dom_root;
	ji->genv = JsAlloc(ji, sizeof(CJsEnv))(CJsEnv *);
	ji->env	 = ji->genv;
	ji->url	 = JsStrDup(ji, url);
	ji->write_buf = JsAlloc(ji, JS_WRITE_BUF);

	ji->doc_obj = JsValNew(ji, JV_OBJ);
	ji->doc_obj->native_id = JSO_DOCUMENT;
	ji->loc_obj = JsValNew(ji, JV_OBJ);
	ji->loc_obj->native_id = JSO_LOCATION;
	ji->win_obj = JsValNew(ji, JV_OBJ);
	ji->win_obj->native_id = JSO_WINDOW;

	JsEnvDeclare(ji, ji->genv, "document", ji->doc_obj);
	JsEnvDeclare(ji, ji->genv, "location", ji->loc_obj);
	JsEnvDeclare(ji, ji->genv, "window",   ji->win_obj);

	math = JsValNew(ji, JV_OBJ);
	JsPropSet(ji, math, "floor",  JsNativeV(ji, JSN_MATH_FLOOR));
	JsPropSet(ji, math, "ceil",	  JsNativeV(ji, JSN_MATH_CEIL));
	JsPropSet(ji, math, "round",  JsNativeV(ji, JSN_MATH_ROUND));
	JsPropSet(ji, math, "abs",	  JsNativeV(ji, JSN_MATH_ABS));
	JsPropSet(ji, math, "sqrt",	  JsNativeV(ji, JSN_MATH_SQRT));
	JsPropSet(ji, math, "pow",	  JsNativeV(ji, JSN_MATH_POW));
	JsPropSet(ji, math, "random", JsNativeV(ji, JSN_MATH_RANDOM));
	JsPropSet(ji, math, "max",	  JsNativeV(ji, JSN_MATH_MAX));
	JsPropSet(ji, math, "min",	  JsNativeV(ji, JSN_MATH_MIN));
	JsEnvDeclare(ji, ji->genv, "Math", math);

	console_obj = JsValNew(ji, JV_OBJ);
	JsPropSet(ji, console_obj, "log",	JsNativeV(ji, JSN_CONSOLE_LOG));
	JsPropSet(ji, console_obj, "info",	JsNativeV(ji, JSN_CONSOLE_LOG));
	JsPropSet(ji, console_obj, "warn",	JsNativeV(ji, JSN_CONSOLE_LOG));
	JsPropSet(ji, console_obj, "error", JsNativeV(ji, JSN_CONSOLE_LOG));
	JsEnvDeclare(ji, ji->genv, "console", console_obj);

	JsGlobalNative(ji, "Date", JSN_DATE_CTOR); // new Date(); Date.now via member case
	date = NULL; // (local kept for the compiler; the old Date object is retired)

	JsGlobalNative(ji, "alert",		 JSN_ALERT);
	JsGlobalNative(ji, "parseInt",	 JSN_PARSEINT);
	JsGlobalNative(ji, "parseFloat", JSN_PARSEFLOAT);
	JsGlobalNative(ji, "String",	 JSN_STRING);
	JsGlobalNative(ji, "Number",	 JSN_NUMBER);
	JsGlobalNative(ji, "isNaN",		 JSN_ISNAN);
	JsGlobalNative(ji, "setTimeout",	JSN_SETTIMEOUT);
	JsGlobalNative(ji, "setInterval",	JSN_SETINTERVAL);
	JsGlobalNative(ji, "clearTimeout",	JSN_CLEARTIMER);
	JsGlobalNative(ji, "clearInterval",	JSN_CLEARTIMER);
	JsGlobalNative(ji, "XMLHttpRequest",JSN_XHR_NEW);
	JsGlobalNative(ji, "Promise",		JSN_PROMISE_CTOR);
	JsGlobalNative(ji, "fetch",			JSN_FETCH);
	JsGlobalNative(ji, "Map",			JSN_MAP_CTOR);
	JsGlobalNative(ji, "WeakMap",		JSN_MAP_CTOR);
	JsGlobalNative(ji, "Set",			JSN_SET_CTOR);
	JsGlobalNative(ji, "WeakSet",		JSN_SET_CTOR);
	JsGlobalNative(ji, "Error",			JSN_ERROR_CTOR);
	JsGlobalNative(ji, "TypeError",		JSN_ERROR_CTOR);
	JsGlobalNative(ji, "RangeError",	JSN_ERROR_CTOR);
	JsGlobalNative(ji, "SyntaxError",	JSN_ERROR_CTOR);
	JsGlobalNative(ji, "RegExp",		JSN_REGEXP_CTOR);
	JsGlobalNative(ji, "MutationObserver",		JSN_OBSERVER_CTOR);
	JsGlobalNative(ji, "IntersectionObserver",	JSN_OBSERVER_CTOR);
	JsGlobalNative(ji, "ResizeObserver",		JSN_OBSERVER_CTOR);
	JsGlobalNative(ji, "PerformanceObserver",	JSN_OBSERVER_CTOR);
	JsGlobalNative(ji, "Symbol",				JSN_SYMBOL);
	JsGlobalNative(ji, "matchMedia",			JSN_MATCHMEDIA);
	JsGlobalNative(ji, "getComputedStyle",		JSN_GETCOMPUTED);
	JsGlobalNative(ji, "AbortController",		JSN_ABORT_CTOR);
	JsGlobalNative(ji, "Event",					JSN_EVENT_CTOR);
	JsGlobalNative(ji, "CustomEvent",			JSN_EVENT_CTOR);
	JsGlobalNative(ji, "requestAnimationFrame",	JSN_SETTIMEOUT); // ~immediate timer
	JsGlobalNative(ji, "cancelAnimationFrame",	JSN_CLEARTIMER);
	JsGlobalNative(ji, "queueMicrotask",		JSN_SETTIMEOUT);
	JsGlobalNative(ji, "Audio",					JSN_AUDIO_CTOR);

	math = JsValNew(ji, JV_OBJ); // history: no real session stack, calls are no-ops
	JsPropSet(ji, math, "pushState",	JsNativeV(ji, JSN_NOOP_UNDEF));
	JsPropSet(ji, math, "replaceState",	JsNativeV(ji, JSN_NOOP_UNDEF));
	JsPropSet(ji, math, "back",			JsNativeV(ji, JSN_NOOP_UNDEF));
	JsPropSet(ji, math, "forward",		JsNativeV(ji, JSN_NOOP_UNDEF));
	JsPropSet(ji, math, "length",		JsNumV(ji, 1));
	JsEnvDeclare(ji, ji->genv, "history", math);

	math = JsValNew(ji, JV_OBJ); // navigator
	JsPropSet(ji, math, "userAgent", JsStrV(ji, "Mozilla/5.0 (X11; Linux x86_64) "
			  "AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36"));
	JsPropSet(ji, math, "language",  JsStrV(ji, "en-US"));
	JsPropSet(ji, math, "platform",  JsStrV(ji, "Linux x86_64"));
	JsPropSet(ji, math, "onLine",	 JsBoolV(ji, TRUE));
	// props feature-detection scripts commonly probe (Google's JS-enabled check)
	JsPropSet(ji, math, "appName",		JsStrV(ji, "Netscape"));
	JsPropSet(ji, math, "appVersion",	JsStrV(ji, "5.0 (X11)"));
	JsPropSet(ji, math, "vendor",		JsStrV(ji, "Google Inc."));
	JsPropSet(ji, math, "product",		JsStrV(ji, "Gecko"));
	JsPropSet(ji, math, "cookieEnabled", JsBoolV(ji, TRUE));
	JsPropSet(ji, math, "doNotTrack",	JsNullV(ji));
	JsPropSet(ji, math, "maxTouchPoints", JsNumV(ji, 0));
	JsPropSet(ji, math, "hardwareConcurrency", JsNumV(ji, 4));
	JsEnvDeclare(ji, ji->genv, "navigator", math);

	math = JsValNew(ji, JV_OBJ); // reuse the local for the JSON namespace
	JsPropSet(ji, math, "parse",	 JsNativeV(ji, JSN_JSON_PARSE));
	JsPropSet(ji, math, "stringify", JsNativeV(ji, JSN_JSON_STR));
	JsEnvDeclare(ji, ji->genv, "JSON", math);

	math = JsValNew(ji, JV_OBJ); // Object namespace
	JsPropSet(ji, math, "keys",   JsNativeV(ji, JSN_OBJ_KEYS));
	JsPropSet(ji, math, "assign", JsNativeV(ji, JSN_OBJ_ASSIGN));
	JsPropSet(ji, math, "values",  JsNativeV(ji, JSN_OBJ_VALUES));
	JsPropSet(ji, math, "entries", JsNativeV(ji, JSN_OBJ_ENTRIES));
	JsPropSet(ji, math, "fromEntries", JsNativeV(ji, JSN_OBJ_FROMENTRIES));
	JsPropSet(ji, math, "defineProperty",   JsNativeV(ji, JSN_OBJ_DEFINEPROP));
	JsPropSet(ji, math, "defineProperties", JsNativeV(ji, JSN_OBJ_DEFINEPROPS));
	JsPropSet(ji, math, "create",  JsNativeV(ji, JSN_OBJ_CREATE));
	JsPropSet(ji, math, "getPrototypeOf", JsNativeV(ji, JSN_OBJ_GETPROTO));
	JsPropSet(ji, math, "setPrototypeOf", JsNativeV(ji, JSN_OBJ_SETPROTO));
	JsPropSet(ji, math, "getOwnPropertyDescriptor", JsNativeV(ji, JSN_OBJ_GETDESC));
	JsPropSet(ji, math, "getOwnPropertyNames", JsNativeV(ji, JSN_OBJ_KEYS));
	JsPropSet(ji, math, "freeze",  JsNativeV(ji, JSN_OBJ_FREEZE));
	JsPropSet(ji, math, "seal",	   JsNativeV(ji, JSN_OBJ_FREEZE));
	JsPropSet(ji, math, "preventExtensions", JsNativeV(ji, JSN_OBJ_FREEZE));
	JsPropSet(ji, math, "isFrozen",		 JsNativeV(ji, JSN_OBJ_ISFROZEN));
	JsPropSet(ji, math, "isSealed",		 JsNativeV(ji, JSN_OBJ_ISFROZEN));
	JsPropSet(ji, math, "isExtensible",	 JsNativeV(ji, JSN_OBJ_ISFROZEN));
	JsEnvDeclare(ji, ji->genv, "Object", math);

	math = JsValNew(ji, JV_OBJ); // Array namespace
	JsPropSet(ji, math, "isArray", JsNativeV(ji, JSN_ARR_ISARR));
	JsEnvDeclare(ji, ji->genv, "Array", math);

	math = JsValNew(ji, JV_OBJ); // localStorage: in-memory, session-wide store
	JsPropSet(ji, math, "getItem",	  JsNativeV(ji, JSN_LS_GET));
	JsPropSet(ji, math, "setItem",	  JsNativeV(ji, JSN_LS_SET));
	JsPropSet(ji, math, "removeItem", JsNativeV(ji, JSN_LS_REMOVE));
	JsPropSet(ji, math, "clear",	  JsNativeV(ji, JSN_LS_CLEAR));
	JsEnvDeclare(ji, ji->genv, "localStorage", math);
	JsEnvDeclare(ji, ji->genv, "sessionStorage", math); // same backing store

	return ji;
}

U0 JsInterpFree(CJsInterp *ji)
{
	CJsAllocHdr *h, *next;

	if (!ji)
		return;
	h = ji->allocs;
	while (h)
	{
		next = h->next;
		Free(h);
		h = next;
	}
	Free(ji);
}

Bool JsRun(CJsInterp *ji, U8 *src)
{ // lex + parse + run one script; errors are logged, never fatal
	CJsNode *stmt;
	I64		 before;

	if (!src || !*src)
		return TRUE;
	if (StrLen(src) > JS_MAX_SRC)
	{
		NetLog("JS: script too big, skipped.");
		return FALSE;
	}

	ji->has_err = FALSE;
	ji->steps	= 0;
	ji->depth	= 0;
	ji->flow	= JF_NORMAL;
	ji->env		= ji->genv;
	js_soft_errs = 0; // fresh soft-error log budget per script

	if (!JsLex(ji, src))
	{
		NetLog("%s", ji->err);
		if (ji->toks)
		{ // token array is a plain CAlloc, not arena: free on every exit
			Free(ji->toks);
			ji->toks = NULL;
		}
		return FALSE;
	}

	while (JsTok(ji)->type != JT_EOF && !ji->has_err)
	{
		before = ji->pos;
		stmt = JsParseStmt(ji);
		if (stmt)
			JsEval(ji, stmt);
		if (ji->flow == JF_THROW)
			NetLog("JS: uncaught exception."); // log, then keep executing
		ji->flow = JF_NORMAL; // stray top-level break/return/throw
		if (ji->pos == before)
			ji->pos++;
	}

	if (ji->toks)
	{ // parse done: the AST owns arena strings, the token array can go. This is
	  // what makes big-bundle caps affordable (toks = 32B x source chars).
		Free(ji->toks);
		ji->toks = NULL;
	}

	JsFlushWrites(ji);

	if (ji->has_err)
	{
		NetLog("%s", ji->err);
		return FALSE;
	}

	return TRUE;
}

