/* token types */
#define JT_EOF		0
#define JT_NUM		1
#define JT_STR		2
#define JT_IDENT	3
#define JT_PUNCT	4
#define JT_REGEX	5	// /pattern/flags literal; str = pattern, num = flag bits

/* multi-char puncts; single-char puncts use their ASCII code */
#define JP_EQ2		256
#define JP_NE		257
#define JP_EQ3		258
#define JP_NE3		259
