// YKD browser audio - <audio> / new Audio(url) playback. Fetches the media
// file, decodes WAV (inline) or MP3 (ZealAmp's pure decoder), nearest-resamples
// to 48kHz stereo, then decode-ahead-feeds the AC97 mixer one frame at a time so
// a full song fits the 5.4s stream fifo. FINITE files only - our HTTP buffers
// the whole body (<=2MB), so live/endless radio streams are out.
//
// A play() cancels any prior playback (single logical <audio> at a time, which
// covers game SFX/music). Included in BrowserBoot AFTER the MP3 decoder and
// BEFORE the Zinc engine, so JS.ZC's Audio binding can call ZAudioPlay.

U8	 zaudio_url[1024];
I64	 zaudio_gen	   = 0;	// bumped on each play/stop; the play task checks it
I64	 zaudio_stream = -1;

I16 *ZAudioWav(U8 *raw, I64 size, I64 *frames, I64 *rate, I64 *ch)
{//16-bit PCM WAV -> pointer INTO raw's data chunk (no copy). NULL if unsupported.
	U8	*p = raw + 12, *epos = raw + size, *data = NULL;
	I64	 csz, channels = 2, srate = 44100, bits = 16, dsz = 0;

	if (size < 44 || MemCompare(raw, "RIFF", 4) || MemCompare(raw + 8, "WAVE", 4))
		return NULL;
	while (p + 8 <= epos)
	{
		csz = p[4] | p[5] << 8 | p[6] << 16 | p[7] << 24;
		if (csz < 0 || p + 8 + csz > epos)
			csz = epos - (p + 8);
		if (!MemCompare(p, "fmt ", 4) && csz >= 16)
		{
			channels = p[10] | p[11] << 8;
			srate	 = p[12] | p[13] << 8 | p[14] << 16 | p[15] << 24;
			bits	 = p[22] | p[23] << 8;
		}
		else if (!MemCompare(p, "data", 4))
		{
			data = p + 8;
			dsz	 = csz;
		}
		p += 8 + csz + (csz & 1);
	}
	if (!data || bits != 16 || channels < 1 || srate < 1)
		return NULL;
	*ch		= channels;
	*rate	= srate;
	*frames	= dsz / (channels * 2);

	return data(I16 *);
}

U0 ZAudioTask()
{//Fetch zaudio_url, decode, resample to 48kHz stereo, decode-ahead-feed AC97.
	CHttpResponse	*r;
	U8				*body;
	I16				*pcm16;
	U32				*pcm;
	I64				 size, frames = 0, rate = 0, chn = 0, of = 0, i, src;
	I64				 gen = zaudio_gen;
	Bool			 mp3_owned = FALSE;

	r = HttpGet(zaudio_url);
	if (!r || r->status != 200 || !r->body || r->body_length < 44)
	{
		if (r)
			HttpResponseFree(r);
		return;
	}
	body = r->body;
	size = r->body_length;

	pcm16 = NULL;
	if (!MemCompare(body, "RIFF", 4))
		pcm16 = ZAudioWav(body, size, &frames, &rate, &chn); // into body, no free
	else
	{ // assume MP3 (ID3 tag or MPEG sync); MP3Decode MAllocs a fresh I16 buffer
		pcm16	  = MP3Decode(body, size, &frames, &rate, &chn);
		mp3_owned = TRUE;
	}
	if (!pcm16 || frames < 1 || rate < 1 || chn < 1 || gen != zaudio_gen)
	{
		if (mp3_owned && pcm16)
			Free(pcm16);
		HttpResponseFree(r);
		return;
	}

	of = frames * 48000 / rate;
	if (of < 1)
	{
		if (mp3_owned)
			Free(pcm16);
		HttpResponseFree(r);
		return;
	}
	pcm = MAlloc(of * sizeof(U32), sys_task);
	for (i = 0; i < of; i++)
	{ // nearest-sample resample + widen mono to stereo, pack L16|R16
		src = i * rate / 48000;
		if (chn == 1)
		{
			pcm[i].i16[0] = pcm16[src];
			pcm[i].i16[1] = pcm16[src];
		}
		else
		{
			pcm[i].i16[0] = pcm16[src * chn];
			pcm[i].i16[1] = pcm16[src * chn + 1];
		}
	}
	if (mp3_owned)
		Free(pcm16);
	HttpResponseFree(r); // pcm16 (into body) already copied into pcm

	if (gen != zaudio_gen)
	{
		Free(pcm);
		return;
	}
	zaudio_stream = AudioStreamOpen;
	i = 0;
	while (i < of && gen == zaudio_gen)
	{ // feed one frame; sleep + retry while the fifo is full
		if (AudioStreamPush(zaudio_stream, pcm[i]))
			i++;
		else
			Sleep(15);
	}
	if (gen == zaudio_gen)
		zaudio_stream = -1; // played to the end on our own generation
	Free(pcm);
}

public U0 ZAudioPlay(U8 *url)
{//Start playing url (absolute). Cancels any current playback.
	if (!url || !*url)
		return;
	zaudio_gen++;
	if (zaudio_stream >= 0)
	{
		AudioStreamStop(zaudio_stream);
		zaudio_stream = -1;
	}
	StrCopy(zaudio_url, url);
	zaudio_url[1023] = 0;
	Spawn(&ZAudioTask, NULL, "Audio");
}

public U0 ZAudioStop()
{//Stop playback (pause == stop; no resume-at-position yet).
	zaudio_gen++;
	if (zaudio_stream >= 0)
	{
		AudioStreamStop(zaudio_stream);
		zaudio_stream = -1;
	}
}
