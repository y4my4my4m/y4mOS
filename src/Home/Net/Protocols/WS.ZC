//WebSocket client (RFC 6455) for YDE - ws:// over native TCP, wss:// over
//the native TLS 1.3. Pure ZealC.
//
//  CWs *ws = WsOpen("wss://host/path");     NULL on failure
//  WsSendStr(ws, "hi");                     text frame
//  n = WsRecv(ws, &buf, 5000);              >0 payload bytes (MAlloc'ed buf),
//                                           0 timeout, -1 closed/error.
//                                           Ping/pong handled internally.
//  WsClose(ws);
//
//Notes: Sec-WebSocket-Accept is NOT verified (needs SHA1; we ship SHA256).
//Fragmented messages are concatenated; max message 1MB.

#define WS_MAX_MSG	1048576

class CWs
{
	CTCPSocket	*sock;
	CTLS		*tls;
	Bool		 open;
};

I64 WsRawRead(CWs *ws, U8 *buf, I64 n)
{//Exactly n bytes, or -1.
	I64 got = 0, r;

	while (got < n)
	{
		if (ws->tls)
			r = TLSRead(ws->tls, buf + got, n - got);
		else
			r = TCPSocketReceive(ws->sock, buf + got, n - got);
		if (r <= 0)
			return -1;
		got += r;
	}

	return n;
}

I64 WsRawWrite(CWs *ws, U8 *buf, I64 n)
{
	if (ws->tls)
		return TLSWrite(ws->tls, buf, n);

	return TCPSocketSend(ws->sock, buf, n);
}

U0 WsB64(U8 *src, I64 n, U8 *dst)
{//Minimal base64 encode (for the 16-byte handshake key).
	U8	*tab = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
	I64	 i, v, o = 0;

	for (i = 0; i < n; i += 3)
	{
		v = src[i] << 16;
		if (i + 1 < n)
			v |= src[i + 1] << 8;
		if (i + 2 < n)
			v |= src[i + 2];
		dst[o++] = tab[v >> 18 & 63];
		dst[o++] = tab[v >> 12 & 63];
		if (i + 1 < n)
			dst[o++] = tab[v >> 6 & 63];
		else
			dst[o++] = '=';
		if (i + 2 < n)
			dst[o++] = tab[v & 63];
		else
			dst[o++] = '=';
	}
	dst[o] = 0;
}

I64 WsSend(CWs *ws, U8 *data, I64 len, I64 op=1)
{//One masked client frame. op 1=text 2=binary 8=close 9=ping 10=pong.
	U8	 hdr[14], mask[4];
	I64	 h = 0, i;
	U8	*payload;
	I64	 res;

	if (!ws || !ws->open)
		return -1;
	hdr[h++] = 0x80 | op;	//FIN + opcode.
	if (len < 126)
		hdr[h++] = 0x80 | len;
	else if (len < 65536)
	{
		hdr[h++] = 0x80 | 126;
		hdr[h++] = len >> 8 & 0xFF;
		hdr[h++] = len & 0xFF;
	}
	else
	{
		hdr[h++] = 0x80 | 127;
		for (i = 7; i >= 0; i--)
			hdr[h++] = len >> (i * 8) & 0xFF;
	}
	for (i = 0; i < 4; i++)
	{
		mask[i] = RandU16 & 0xFF;
		hdr[h++] = mask[i];
	}
	if (WsRawWrite(ws, hdr, h) < 0)
		return -1;
	if (!len)
		return 0;
	payload = MAlloc(len);
	for (i = 0; i < len; i++)
		payload[i] = data[i] ^ mask[i & 3];
	res = WsRawWrite(ws, payload, len);
	Free(payload);
	if (res < 0)
		return -1;

	return len;
}

I64 WsSendStr(CWs *ws, U8 *s)
{
	return WsSend(ws, s, StrLen(s), 1);
}

I64 WsRecv(CWs *ws, U8 **out, I64 timeout_ms=5000)
{//Next text/binary message. >0 = bytes (caller frees *out), 0 = timeout,
//-1 = closed. Control frames are handled inside the loop.
	U8	 hb[8], mask[4];
	I64	 op, fin, len, i, masked;
	U8	*payload, *msg = NULL, *p2;
	I64	 msg_len = 0;

	*out = NULL;
	if (!ws || !ws->open)
		return -1;
	ws->sock->timeout = timeout_ms; //Reads give up after this.
	while (TRUE)
	{
		if (WsRawRead(ws, hb, 2) < 0)
			goto ws_recv_dead;
		fin	   = hb[0] >> 7 & 1;
		op	   = hb[0] & 0xF;
		masked = hb[1] >> 7 & 1;
		len	   = hb[1] & 0x7F;
		if (len == 126)
		{
			if (WsRawRead(ws, hb, 2) < 0)
				goto ws_recv_dead;
			len = hb[0] << 8 | hb[1];
		}
		else if (len == 127)
		{
			if (WsRawRead(ws, hb, 8) < 0)
				goto ws_recv_dead;
			len = 0;
			for (i = 0; i < 8; i++)
				len = len << 8 | hb[i];
		}
		if (masked)
		{
			if (WsRawRead(ws, mask, 4) < 0)
				goto ws_recv_dead;
		}
		if (len < 0 || len > WS_MAX_MSG)
			goto ws_recv_dead;
		payload = MAlloc(len + 1);
		if (len && WsRawRead(ws, payload, len) < 0)
		{
			Free(payload);
			goto ws_recv_dead;
		}
		if (masked)
			for (i = 0; i < len; i++)
				payload[i] ^= mask[i & 3];
		payload[len] = 0;

		switch (op)
		{
			case 8:		//Close.
				Free(payload);
				WsSend(ws, NULL, 0, 8);
				goto ws_recv_dead;
			case 9:		//Ping -> pong with same payload.
				WsSend(ws, payload, len, 10);
				Free(payload);
				break;
			case 10:	//Pong: ignore.
				Free(payload);
				break;
			case 0:		//Continuation.
			case 1:		//Text.
			case 2:		//Binary.
				if (msg_len + len > WS_MAX_MSG)
				{
					Free(payload);
					goto ws_recv_dead;
				}
				if (!msg)
				{
					msg = payload;
					msg_len = len;
				}
				else
				{//Append fragment.
					p2 = MAlloc(msg_len + len + 1);
					MemCopy(p2, msg, msg_len);
					MemCopy(p2 + msg_len, payload, len);
					msg_len += len;
					p2[msg_len] = 0;
					Free(msg);
					Free(payload);
					msg = p2;
				}
				if (fin)
				{
					*out = msg;
					return msg_len;
				}
				break;
			default:
				Free(payload);
				break;
		}
	}

ws_recv_dead:
	Free(msg);
	ws->open = FALSE;
	return -1;
}

U0 WsClose(CWs *ws)
{
	if (!ws)
		return;
	if (ws->open)
	{
		WsSend(ws, NULL, 0, 8);
		ws->open = FALSE;
	}
	if (ws->tls)
		TLSClose(ws->tls);	//Closes the socket too.
	else
		TCPSocketClose(ws->sock);
	Free(ws);
}

CWs *WsOpen(U8 *url)
{//"ws://host[:port]/path" or "wss://...". NULL on any failure.
	CWs		*ws;
	CHttpUrl parsed;
	U8		*http_url, *req, *p;
	U8		 key_raw[16], key_b64[32], resp[2048];
	I64		 i, got, r;

	//Reuse the HTTP URL parser by mapping the scheme.
	if (!StrNICompare(url, "ws://", 5))
		http_url = MStrPrint("http://%s", url + 5);
	else if (!StrNICompare(url, "wss://", 6))
		http_url = MStrPrint("https://%s", url + 6);
	else
		return NULL;
	r = HttpUrlParse(http_url, &parsed);
	Free(http_url);
	if (r < 0)
		return NULL;

	ws = CAlloc(sizeof(CWs));
	ws->sock = TCPConnectionCreate(parsed.host, parsed.port);
	if (ws->sock <= 0)
	{
		NetErr("WS: connection to %s:%d failed.", parsed.host, parsed.port);
		Free(ws);
		return NULL;
	}
	ws->sock->timeout = 8000;
	if (parsed.is_https)
	{
		ws->tls = TLSConnect(parsed.host, ws->sock);
		if (!ws->tls)
		{
			NetErr("WS: TLS handshake to %s failed.", parsed.host);
			TCPSocketClose(ws->sock);
			Free(ws);
			return NULL;
		}
	}

	for (i = 0; i < 16; i++)
		key_raw[i] = RandU16 & 0xFF;
	WsB64(key_raw, 16, key_b64);
	req = MStrPrint("GET %s HTTP/1.1\r\n"
					"Host: %s\r\n"
					"Upgrade: websocket\r\n"
					"Connection: Upgrade\r\n"
					"Sec-WebSocket-Key: %s\r\n"
					"Sec-WebSocket-Version: 13\r\n"
					"\r\n", parsed.path, parsed.host, key_b64);
	WsRawWrite(ws, req, StrLen(req));
	Free(req);

	//Read the 101 response up to the blank line.
	got = 0;
	while (got < 2047)
	{
		if (WsRawRead(ws, resp + got, 1) < 0)
			break;
		got++;
		resp[got] = 0;
		if (got >= 4 && !MemCompare(resp + got - 4, "\r\n\r\n", 4))
			break;
	}
	p = StrFind(" 101", resp);
	if (!p || p > resp + 12)
	{
		NetErr("WS: upgrade refused by %s (no 101).", parsed.host);
		WsClose(ws);
		return NULL;
	}
	ws->open = TRUE;
	NetLog("WS: connected to %s:%d%s.", parsed.host, parsed.port, parsed.path);

	return ws;
}

public U0 WsEcho(U8 *url="ws://10.0.2.2:8765/")
{//Round-trip self-test against an echo server.
	CWs *ws = WsOpen(url);
	U8	*msg;
	I64	 n;

	if (!ws)
	{
		"WS: open failed.\n";
		return;
	}
	WsSendStr(ws, "Hello from YDE over WebSocket!");
	n = WsRecv(ws, &msg, 8000);
	if (n > 0)
	{
		"WS ECHO OK (%d bytes): %s\n", n, msg;
		Free(msg);
	}
	else
		"WS: no echo (%d).\n", n;
	WsClose(ws);
}
